    "input": {
      "path": "/Users/mango/workspace/geode/artifacts/eval/harnesses/mcpmark/.mcpmark_backups/backup_filesystem_votenet_dataset_comparison_21289/scannet/model_util_scannet.py",
      "tail": 2000,
