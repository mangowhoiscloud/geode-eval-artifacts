_backups/backup_filesystem_votenet_requirements_writing_35714/utils/box_util.py\\n/Users/mango/workspace/geode/artifacts/eval/harnesses/mcpmark/.mcpmark_backups/backup_filesystem_votenet_requirements_writing_35714/utils/eval_det.py\\n/Users/mango/workspace/geode/artifacts/eval/harnesses/mcpmark/.mcpmark_backups/backup_filesystem_votenet_requirements_writing_35714/utils/metric_util.py\\n/Users/mango/workspace/geode/artifacts/eval/harnesses/mcpmark/.mcpmark_backups/backup_filesystem_votenet_requirements_writing_35714/utils/nms.py\\n/Users/mango/workspace/geode/artifacts/eval/harnesses/mcpmark/.mcpmark_backups/backup_filesystem_votenet_requirements_writing_35714/utils/nn_distance.py\\n/Users/mango/workspace/geode/artifacts/eval/harnesses/mcpmark/.mcpmark_backups/backup_filesystem_votenet_requirements_writing_35714/utils/pc_util.py\\n/Users/mango/workspace/geode/artifacts/eval/harnesses/mcpmark/.mcpmark_backups/backup_filesystem_votenet_requirements_writing_35714/utils/tf_logger.py\\n/Users/mango/workspace/geode/artifacts/eval/harnesses/mcpmark/.mcpmark_backups/backup_filesystem_votenet_requirements_writing_35714/utils/tf_visualizer.py\"}, \"isError\": false}"
