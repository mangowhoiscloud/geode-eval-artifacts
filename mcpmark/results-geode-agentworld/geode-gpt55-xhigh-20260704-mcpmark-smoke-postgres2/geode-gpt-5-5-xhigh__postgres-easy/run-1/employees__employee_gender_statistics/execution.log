      "sql": "DROP TABLE IF EXISTS employees.gender_statistics;\n\nCREATE TABLE employees.gender_statistics (\n    gender varchar,\n    total_employees integer,\n    current_employees integer,\n    percentage_of_workforce decimal\n);\n\nWITH total_counts AS (\n    SELECT\n        gender::varchar AS gender,\n        COUNT(*)::integer AS total_employees\n    FROM employees.employee\n    WHERE gender::varchar IN ('M', 'F')\n    GROUP BY gender::varchar\n),\ncurrent_counts AS (\n    SELECT\n        e.gender::varchar AS gender,\n        COUNT(DISTINCT e.id)::integer AS current_employees\n    FROM employees.employee e\n    JOIN employees.salary s\n      ON s.employee_id = e.id\n     AND s.to_date = DATE '9999-01-01'\n    WHERE e.gender::varchar IN ('M', 'F')\n    GROUP BY e.gender::varchar\n),\ncurrent_workforce AS (\n    SELECT COUNT(DISTINCT e.id)::decimal AS total_current_employees\n    FROM employees.employee e\n    JOIN employees.salary s\n      ON s.employee_id = e.id\n     AND s.to_date = DATE '9999-01-01'\n    WHERE e.gender::varchar IN ('M', 'F')\n)\nINSERT INTO employees.gender_statistics (\n    gender,\n    total_employees,\n    current_employees,\n    percentage_of_workforce\n)\nSELECT\n    g.gender,\n    COALESCE(t.total_employees, 0)::integer AS total_employees,\n    COALESCE(c.current_employees, 0)::integer AS current_employees,\n    CASE\n        WHEN cw.total_current_employees = 0 THEN 0::decimal\n        ELSE (COALESCE(c.current_employees, 0)::decimal / cw.total_current_employees) * 100\n    END AS percentage_of_workforce\nFROM (VALUES ('F'::varchar), ('M'::varchar)) AS g(gender)\nLEFT JOIN total_counts t ON t.gender = g.gender\nLEFT JOIN current_counts c ON c.gender = g.gender\nCROSS JOIN current_workforce cw\nORDER BY g.gender;\n\nSELECT\n    gender,\n    total_employees,\n    current_employees,\n    percentage_of_workforce\nFROM employees.gender_statistics\nORDER BY gender;\n\nSELECT COUNT(*) AS row_count\nFROM employees.gender_statistics;"
