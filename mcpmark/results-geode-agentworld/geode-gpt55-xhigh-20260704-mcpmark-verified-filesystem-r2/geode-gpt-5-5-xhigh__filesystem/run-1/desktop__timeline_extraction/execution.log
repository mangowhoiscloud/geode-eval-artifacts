       self.inventory_file = Path(inventory_file)\\n        self.inventory = self.load_inventory()\\n    \\n    def load_inventory(self) -> Dict:\\n        \\\"\\\"\\\"Load inventory\\\"\\\"\\\"\\n        if self.inventory_file.exists():\\n            try:\\n                with open(self.inventory_file, 'r', encoding='utf-8') as f:\\n                    return json.load(f)\\n            except json.JSONDecodeError:\\n                print(\\\"Inventory file corrupted, creating new inventory file\\\")\\n                return {\\\"items\\\": [], \\\"categories\\\": [], \\\"total_value\\\": 0}\\n        return {\\\"items\\\": [], \\\"categories\\\": [], \\\"total_value\\\": 0}\\n    \\n    def save_inventory(self):\\n        \\\"\\\"\\\"Save inventory\\\"\\\"\\\"\\n        with open(self.inventory_file, 'w', encoding='utf-8') as f:\\n            json.dump(self.inventory, f, ensure_ascii=False, indent=2)\\n    \\n    def add_item(self, name: str, item_type: ItemType, brand: str, \\n                 price: float, purchase_date: str, condition: str = \\\"New\\\"):\\n        \\\"\\\"\\\"Add item to collection\\\"\\\"\\\"\\n        item = {\\n            \\\"id\\\": len(self.inventory[\\\"items\\\"]) + 1,\\n            \\\"name\\\": name,\\n            \\\"type\\\": item_type.value,\\n            \\\"brand\\\": brand,\\n            \\\"price\\\": price,\\n            \\\"purchase_date\\\": purchase_date,\\n            \\\"condition\\\": condition,\\n            \\\"added_date\\\": datetime.datetime.now().isoformat(),\\n            \\\"last_worn\\\": None,\\n            \\\"notes\\\": \\\"\\\"\\n        }\\n        \\n        self.inventory[\\\"items\\\"].append(item)\\n        self.inventory[\\\"total_value\\\"] += price\\n        \\n        # Add new category\\n        if item_type.value not in self.inventory[\\\"categories\\\"]:\\n            self.inventory[\\\"categories\\\"].append(item_type.value)\\n        \\n        self.save_inventory()\\n        print(f\\\"Item '{name}' has been added to collection\\\")\\n    \\n    def remove_item(self, item_id: int):\\n        \\\"\\\"\\\"Remove item from collection\\\"\\\"\\\"\\n        for i, item in enumerate(self.inventory[\\\"items\\\"]):\\n            if item[\\\"id\\\"] == item_id:\\n                removed_item = self.inventory[\\\"items\\\"].pop(i)\\n                self.inventory[\\\"total_value\\\"] -= removed_item[\\\"price\\\"]\\n                self.save_inventory()\\n                print(f\\\"Item '{removed_item['name']}' has been removed from collection\\\")\\n                return\\n        print(f\\\"Item with ID {item_id} not found\\\")\\n    \\n    def update_item_condition(self, item_id: int, new_condition: str):\\n        \\\"\\\"\\\"Update item condition\\\"\\\"\\\"\\n        for item in self.inventory[\\\"items\\\"]:\\n            if item[\\\"id\\\"] == item_id:\\n                item[\\\"condition\\\"] = new_condition\\n                item[\\\"last_worn\\\"] = datetime.datetime.now().isoformat()\\n                self.save_inventory()\\n                print(f\\\"Item '{item['name']}' condition updated to {new_condition}\\\")\\n                return\\n        print(f\\\"Item with ID {item_id} not found\\\")\\n    \\n    def search_items(self, keyword: str) -> List[Dict]:\\n        \\\"\\\"\\\"Search items\\\"\\\"\\\"\\n        results = []\\n        for item in self.inventory[\\\"items\\\"]:\\n            if (keyword.lower() in item[\\\"name\\\"].lower() or \\n                keyword.lower() in item[\\\"brand\\\"].lower() or\\n                keyword.lower() in item[\\\"type\\\"].lower()):\\n                results.append(item)\\n        return results\\n    \\n    def get_items_by_type(self, item_type: ItemType) -> List[Dict]:\\n        \\\"\\\"\\\"Get items by type\\\"\\\"\\\"\\n        return [item for item in self.inventory[\\\"items\\\"] if item[\\\"type\\\"] == item_type.value]\\n    \\n    def get_collection_summary(self) -> Dict:\\n        \\\"\\\"\\\"Get collection summary\\\"\\\"\\\"\\n        summary = {\\n            \\\"total_items\\\": len(self.inventory[\\\"items\\\"]),\\n            \\\"total_value\\\": self.inventory[\\\"total_value\\\"],\\n            \\\"by_type\\\": {},\\n            \\\"by_brand\\\": {}\\n        }\\n        \\n        # Statistics by type\\n        for item_type in self.inventory[\\\"categories\\\"]:\\n            type_items = [item for item in self.inventory[\\\"items\\\"] if item[\\\"type\\\"] == item_type]\\n            summary[\\\"by_type\\\"][item_type] = {\\n                \\\"count\\\": len(type_items),\\n                \\\"value\\\": sum(item[\\\"price\\\"] for item in type_items)\\n            }\\n        \\n        # Statistics by brand\\n        brands = set(item[\\\"brand\\\"] for item in self.inventory[\\\"items\\\"])\\n        for brand in brands:\\n            brand_items = [item for item in self.inventory[\\\"items\\\"] if item[\\\"brand\\\"] == brand]\\n            summary[\\\"by_brand\\\"][brand] = {\\n                \\\"count\\\": len(brand_items),\\n                \\\"value\\\": sum(item[\\\"price\\\"] for item in brand_items)\\n            }\\n        \\n        return summary\\n\\ndef main():\\n    \\\"\\\"\\\"Main function example\\\"\\\"\\\"\\n    manager = CollectionManager()\\n    \\n    # Add example items\\n    manager.add_item(\\n        \\\"Air Jordan 1 Retro High OG\\\",\\n        ItemType.SHOES,\\n        \\\"Nike\\\",\\n        1299.0,\\n        \\\"2024-01-15\\\",\\n        \\\"New\\\"\\n    )\\n    \\n    manager.add_item(\\n        \\\"Yeezy Boost 350 V2\\\",\\n        ItemType.SHOES,\\n        \\\"Adidas\\\",\\n        1899.0,\\n        \\\"2024-01-10\\\",\\n        \\\"New\\\"\\n    )\\n    \\n    manager.add_item(\\n        \\\"Supreme Box Logo Hoodie\\\",\\n        ItemType.CLOTHING,\\n        \\\"Supreme\\\",\\n        899.0,\\n        \\\"2024-01-05\\\",\\n        \\\"New\\\"\\n    )\\n    \\n    # Display collection summary\\n    summar