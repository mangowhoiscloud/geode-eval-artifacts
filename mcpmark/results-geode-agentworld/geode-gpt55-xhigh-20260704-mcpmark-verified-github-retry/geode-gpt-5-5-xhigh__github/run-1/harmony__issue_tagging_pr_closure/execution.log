      "result": "{\"meta\": null, \"content\": [{\"type\": \"text\", \"text\": \"{\\\"ref\\\":\\\"refs/heads/feat/esm-migration-attempt\\\",\\\"url\\\":\\\"https://api.github.com/repos/mangowhoiscloud/harmony/git/refs/heads/feat/esm-migration-attempt\\\",\\\"object\\\":{\\\"type\\\":\\\"commit\\\",\\\"sha\\\":\\\"41159a9c2bae3510e20e2246e1873f1f035f6846\\\",\\\"url\\\":\\\"https://api.github.com/repos/mangowhoiscloud/harmony/git/commits/41159a9c2bae3510e20e2246e1873f1f035f6846\\\"},\\\"node_id\\\":\\\"REF_kwDOTNWqZ9oAJXJlZnMvaGVhZHMvZmVhdC9lc20tbWlncmF0aW9uLWF0dGVtcHQ\\\"}\", \"annotations\": null, \"meta\": null}], \"structuredContent\": null, \"isError\": false}"
