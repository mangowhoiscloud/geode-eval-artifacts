ithub.com/Keno/ClaudeBox.jl\\\\n\\\\n## Expected Behavior\\\\nIt launches the first time\\\\n\\\\n## Actual Behavior\\\\nIt errors the first time as above, works the second time.\\\\n\\\",\\\"author_association\\\":\\\"OWNER\\\",\\\"user\\\":{\\\"login\\\":\\\"mangowhoiscloud\\\",\\\"id\\\":191002565,\\\"node_id\\\":\\\"U_kgDOC2J3xQ\\\",\\\"avatar_url\\\":\\\"https://avatars.githubusercontent.com/u/191002565?v=4\\\",\\\"html_url\\\":\\\"https://github.com/mangowhoiscloud\\\",\\\"gravatar_id\\\":\\\"\\\",\\\"type\\\":\\\"User\\\",\\\"site_admin\\\":false,\\\"url\\\":\\\"https://api.github.com/users/mangowhoiscloud\\\",\\\"events_url\\\":\\\"https://api.github.com/users/mangowhoiscloud/events{/privacy}\\\",\\\"following_url\\\":\\\"https://api.github.com/users/mangowhoiscloud/following{/other_user}\\\",\\\"followers_url\\\":\\\"https://api.github.com/users/mangowhoiscloud/followers\\\",\\\"gists_url\\\":\\\"https://api.github.com/users/mangowhoiscloud/gists{/gist_id}\\\",\\\"organizations_url\\\":\\\"https://api.github.com/users/mangowhoiscloud/orgs\\\",\\\"received_events_url\\\":\\\"https://api.github.com/users/mangowhoiscloud/received_events\\\",\\\"repos_url\\\":\\\"https://api.github.com/users/mangowhoiscloud/repos\\\",\\\"starred_url\\\":\\\"https://api.github.com/users/mangowhoiscloud/starred{/owner}{/repo}\\\",\\\"subscriptions_url\\\":\\\"https://api.github.com/users/mangowhoiscloud/subscriptions\\\"},\\\"labels\\\":[{\\\"id\\\":11413102134,\\\"url\\\":\\\"https://api.github.com/repos/mangowhoiscloud/claude-code/labels/bug\\\",\\\"name\\\":\\\"bug\\\",\\\"color\\\":\\\"d73a4a\\\",\\\"description\\\":\\\"Something isn't working\\\",\\\"default\\\":true,\\\"node_id\\\":\\\"LA_kwDOTNEKgM8AAAACqEYeNg\\\"},{\\\"id\\\":11413102318,\\\"url\\\":\\\"https://api.github.com/repos/mangowhoiscloud/claude-code/labels/has%20repro\\\",\\\"name\\\":\\\"has repro\\\",\\\"color\\\":\\\"ededed\\\",\\\"default\\\":false,\\\"node_id\\\":\\\"LA_kwDOTNEKgM8AAAACqEYe7g\\\"},{\\\"id\\