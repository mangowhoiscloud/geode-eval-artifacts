rl\\\":\\\"https://api.github.com/repos/mangowhoiscloud/claude-code/issues/54/reactions\\\"},\\\"node_id\\\":\\\"I_kwDOTNEKgM8AAAABHoW7kA\\\"}\", \"annotations\": null, \"meta\": null}], \"structuredContent\": null, \"isError\": false}"
