"node\\\",\\n    \\\"collectCoverageFrom\\\": [\\n      \\\"src/**/*.js\\\",\\n      \\\"!src/app.js\\\"\\n    ],\\n    \\\"testTimeout\\\": 5000,\\n    \\\"coverageThreshold\\\": {\\n      \\\"global\\\": {\\n        \\\"branches\\\": 70,\\n        \\\"functions\\\": 70,\\n        \\\"lines\\\": 70,\\n        \\\"statements\\\": 70\\n      }\\n    }\\n  }\\n}\\n\"}, \"annotations\": null, \"meta\": null}], \"structuredContent\": null, \"isError\": false}"
