        {
          "content": "name: Deployment Status\n\non:\n  push:\n    branches:\n      - main\n\npermissions:\n  contents: read\n  issues: write\n  actions: read\n\njobs:\n  pre-deployment:\n    name: pre-deployment\n    runs-on: ubuntu-latest\n    outputs:\n      issue_number: ${{ steps.create_issue.outputs.issue_number }}\n      previous_sha: ${{ steps.deployment_info.outputs.previous_sha }}\n      current_sha: ${{ steps.deployment_info.outputs.current_sha }}\n      package_version: ${{ steps.deployment_info.outputs.package_version }}\n    steps:\n      - name: Checkout repository\n        uses: actions/checkout@v4\n        with:\n          fetch-depth: 2\n\n      - name: Setup Node.js\n        uses: actions/setup-node@v4\n        with:\n          node-version: 18\n          cache: npm\n\n      - name: Install dependencies\n        run: npm ci\n\n      - name: Run lint\n        run: npm run lint\n\n      - name: Run tests\n        run: npm test\n\n      - name: Capture deployment information\n        id: deployment_info\n        shell: bash\n        run: |\n          set -euo pipefail\n\n          current_sha=\"${GITHUB_SHA}\"\n          event_before=\"${{ github.event.before }}\"\n\n          if [[ \"${event_before}\" != \"0000000000000000000000000000000000000000\" ]]; then\n            previous_sha=\"${event_before}\"\n          elif git rev-parse HEAD^ >/dev/null 2>&1; then\n            previous_sha=\"$(git rev-parse HEAD^)\"\n          else\n            previous_sha=\"unavailable\"\n          fi\n\n          package_version=\"$(node -p \"require('./package.json').version\")\"\n\n          echo \"current_sha=${current_sha}\" >> \"${GITHUB_OUTPUT}\"\n          echo \"previous_sha=${previous_sha}\" >> \"${GITHUB_OUTPUT}\"\n          echo \"package_version=${package_version}\" >> \"${GITHUB_OUTPUT}\"\n\n      - name: Create deployment tracking issue\n        id: create_issue\n        uses: actions/github-script@v7\n        env:\n          CURRENT_SHA: ${{ steps.deployment_info.outputs.current_sha }}\n          PREVIOUS_SHA: ${{ steps.deployment_info.outputs.previous_sha }}\n          PACKAGE_VERSION: ${{ steps.deployment_info.outputs.package_version }}\n        with:\n          script: |\n            const { owner, repo } = context.repo;\n            const labels = [\n              { name: 'deployment', color: '5319E7', description: 'Deployment status tracking' },\n              { name: 'in-progress', color: 'FBCA04', description: 'Deployment is in progress' },\n              { name: 'completed', color: '0E8A16', description: 'Deployment completed successfully' }\n            ];\n\n            for (const label of labels) {\n              try {\n                await github.rest.issues.getLabel({ owner, repo, name: label.name });\n              } catch (error) {\n                if (error.status === 404) {\n                  await github.rest.issues.createLabel({ owner, repo, ...label });\n                } else {\n                  throw error;\n                }\n              }\n            }\n\n            const issue = await github.rest.issues.create({\n              owner,\n              repo,\n              title: `Deployment Tracking - ${process.env.CURRENT_SHA}`,\n              body: [\n                'Deployment tracking issue created after pre-deployment validation.',\n                '',\n                `Current Commit: ${process.env.CURRENT_SHA}`,\n                `Previous Commit: ${process.env.PREVIOUS_SHA}`,\n                `Package Version: ${process.env.PACKAGE_VERSION}`,\n                '',\n                'Quality gates completed before rollback preparation.'\n              ].join('\\n'),\n              labels: ['deployment', 'in-progress']\n            });\n\n            core.setOutput('issue_number', issue.data.number);\n\n            await github.rest.issues.createComment({\n              owner,\n              repo,\n              issue_number: issue.data.number,\n              body: [\n                'Pre-deployment checks completed',\n                '',\n                `Current Commit: ${process.env.CURRENT_SHA}`,\n                `Previous Commit: ${process.env.PREVIOUS_SHA}`,\n                `Package Version: ${process.env.PACKAGE_VERSION}`,\n                '',\n                '- Lint: passed',\n                '- Tests: passed'\n              ].join('\\n')\n            });\n\n  rollback-preparation:\n    name: rollback-preparation\n    runs-on: ubuntu-latest\n    needs: pre-deployment\n    outputs:\n      artifact_name: ${{ steps.rollback_artifact.outputs.artifact_name }}\n      artifact_checksum: ${{ steps.rollback_artifact.outputs.artifact_checksum }}\n      rollback_script_created: ${{ steps.rollback_artifact.outputs.rollback_script_created }}\n      configuration_backup: ${{ steps.rollback_artifact.outputs.configuration_backup }}\n    steps:\n      - name: Checkout repository\n        uses: actions/checkout@v4\n        with:\n          fetch-depth: 0\n\n      - name: Create rollback package\n        id: rollback_artifact\n        shell: bash\n        env:\n          CURRENT_SHA: ${{ needs.pre-deployment.outputs.current_sha }}\n          PREVIOUS_SHA: ${{ needs.pre-deployment.outputs.previous_sha }}\n          PACKAGE_VERSION: ${{ needs.pre-deployment.outputs.package_version }}\n        run: |\n          set -Eeuo pipefail\n          trap 'echo \"::error::Rollback artifact creation failed on line ${LINENO}\"; exit 1' ERR\n\n          artifact_name=\"rollback-package-${CURRENT_SHA}\"\n          artifact_root=\"${RUNNER_TEMP}/${artifact_name}\"\n          staging_dir=\"${GITHUB_WORKSPACE}/rollback-artifacts\"\n\n          rm -rf \"${artifact_root}\" \"${staging_dir}\"\n          mkdir -p \\\n            \"${artifact_root}/scripts\" \\\n            \"${artifact_root}/config-backups/environment-templates\" \\\n            \"${artifact_root}/docs\" \\\n            \"${artifact_root}/checksums\" \\\n            \"${staging_dir}\"\n\n          for required_config in package.json package-lock.json; do\n            if [[ ! -f \"${required_config}\" ]]; then\n              echo \"::error::Missing required configuration file: ${required_config}\"\n              exit 1\n            fi\n            cp \"${required_config}\" \"${artifact_root}/config-backups/${required_config}\"\n          done\n\n          env_template_count=0\n          while IFS= read -r -d '' env_file; do\n            relative_path=\"${env_file#./}\"\n            target_file=\"${artifact_root}/config-backups/environment-templates/${relative_path}\"\n            mkdir -p \"$(dirname \"${target_file}\")\"\n            cp \"${env_file}\" \"${target_file}\"\n            env_template_count=$((env_template_count + 1))\n          done < <(find . -type f \\( -name \".env.example\" -o -name \".env.template\" -o -name \"*.env.example\" -o -name \"*.env.template\" \\) -not -path \"./node_modules/*\" -print0)\n\n          cat > \"${artifact_root}/config-backups/environment-templates/.env.rollback.template\" <<EOF_ENV\n          NODE_ENV=production\n          PORT=3000\n          ROLLBACK_TARGET_COMMIT=${PREVIOUS_SHA}\n          ROLLBACK_SOURCE_COMMIT=${CURRENT_SHA}\n          PACKAGE_VERSION=${PACKAGE_VERSION}\n          EOF_ENV\n\n          cat > \"${artifact_root}/scripts/rollback.sh\" <<'ROLLBACK_SCRIPT'\n          #!/usr/bin/env bash\n          set -Eeuo pipefail\n          trap 'echo \"ERROR: Rollback failed on line ${LINENO}\" >&2' ERR\n\n          DEFAULT_PREVIOUS_COMMIT=\"__PREVIOUS_SHA__\"\n          DEPLOYED_COMMIT=\"__CURRENT_SHA__\"\n          PACKAGE_VERSION=\"__PACKAGE_VERSION__\"\n\n          usage() {\n            cat <<USAGE\n          Usage: $0 [--push] [target-commit]\n\n          Validates and prepares a rollback from ${DEPLOYED_COMMIT} to target-commit.\n          The default target is ${DEFAULT_PREVIOUS_COMMIT} for package version ${PACKAGE_VERSION}.\n\n          Options:\n            --push    Push the reset main branch to origin with --force-with-lease after validation.\n            -h,--help Show this help text.\n          USAGE\n          }\n\n          if [[ \"${1:-}\" == \"--help\" || \"${1:-}\" == \"-h\" ]]; then\n            usage\n            exit 0\n          fi\n\n          push_changes=false\n          if [[ \"${1:-}\" == \"--push\" ]]; then\n            push_changes=true\n            shift\n          fi\n\n          target_commit=\"${1:-${DEFAULT_PREVIOUS_COMMIT}}\"\n          if [[ -z \"${target_commit}\" || \"${target_commit}\" == \"unavailable\" ]]; then\n            echo \"ERROR: No valid rollback target commit was provided.\" >&2\n            usage\n            exit 1\n          fi\n\n          for command_name in git npm node; do\n            if ! command -v \"${command_name}\" >/dev/null 2>&1; then\n              echo \"ERROR: Required command not found: ${command_name}\" >&2\n              exit 1\n            fi\n          done\n\n          if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then\n            echo \"ERROR: Run this script from inside the repository working tree.\" >&2\n            exit 1\n          fi\n\n          if [[ -n \"$(git status --porcelain)\" ]]; then\n            echo \"ERROR: Working tree has uncommitted changes. Commit or stash them before rollback.\" >&2\n            exit 1\n          fi\n\n          echo \"Fetching origin/main and tags...\"\n          git fetch origin main --tags\n\n          if ! git rev-parse --verify \"${target_commit}^{commit}\" >/dev/null 2>&1; then\n            echo \"ERROR: Target commit does not exist locally or remotely: ${target_commit}\" >&2\n            exit 1\n          fi\n\n          echo \"Resetting local main from ${DEPLOYED_COMMIT} to ${target_commit}...\"\n          git checkout main\n          git reset --hard \"${target_commit}\"\n\n          if [[ -f package-lock.json ]]; then\n            npm ci\n          else\n            npm install\n          fi\n\n          npm test\n\n          if [[ \"${push_changes}\" == \"true\" ]]; then\n            git push --force-with-lease origin main\n            echo \"Rollback pushed to origin/main at ${target_commit}.\"\n          else\n            echo \"Rollback validation completed locally. Re-run with --push to update origin/main.\"\n          fi\n          ROLLBACK_SCRIPT\n\n          sed -i \\\n            -e \"s|__PREVIOUS_SHA__|${PREVIOUS_SHA}|g\" \\\n            -e \"s|__CURRENT_SHA__|${CURRENT_SHA}|g\" \\\n            -e \"s|__PACKAGE_VERSION__|${PACKAGE_VERSION}|g\" \\\n            \"${artifact_root}/scripts/rollback.sh\"\n\n          cat > \"${artifact_root}/scripts/verify-dependencies.sh\" <<'DEPENDENCY_SCRIPT'\n          #!/usr/bin/env bash\n          set -Eeuo pipefail\n          trap 'echo \"ERROR: Dependency verification failed on line ${LINENO}\" >&2' ERR\n\n          script_dir=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n          backup_dir=\"$(cd \"${script_dir}/../config-backups\" && pwd)\"\n\n          for command_name in node npm; do\n            if ! command -v \"${command_name}\" >/dev/null 2>&1; then\n              echo \"ERROR: Required command not found: ${command_name}\" >&2\n              exit 1\n            fi\n          done\n\n          node -e \"const fs = require('fs'); const pkg = JSON.parse(fs.readFileSync('${backup_dir}/package.json', 'utf8')); console.log('Package:', pkg.name + '@' + pkg.version); console.log('Required Node:', (pkg.engines && pkg.engines.node) || 'not specified'); console.log('Current Node:', process.version);\"\n\n          if [[ -f \"${backup_dir}/package-lock.json\" ]]; then\n            node -e \"const fs = require('fs'); const lock = JSON.parse(fs.readFileSync('${backup_dir}/package-lock.json', 'utf8')); if (!lock.lockfileVersion) { throw new Error('Missing lockfileVersion'); } console.log('Lockfile version:', lock.lockfileVersion);\"\n          else\n            echo \"ERROR: package-lock.json backup is missing.\" >&2\n            exit 1\n          fi\n\n          temp_dir=\"$(mktemp -d)\"\n          trap 'rm -rf \"${temp_dir}\"' EXIT\n          cp \"${backup_dir}/package.json\" \"${temp_dir}/package.json\"\n          cp \"${backup_dir}/package-lock.json\" \"${temp_dir}/package-lock.json\"\n\n          (cd \"${temp_dir}\" && npm ci --ignore-scripts --dry-run)\n          echo \"Dependency compatibility check completed.\"\n          DEPENDENCY_SCRIPT\n\n          chmod +x \"${artifact_root}/scripts/rollback.sh\" \"${artifact_root}/scripts/verify-dependencies.sh\"\n          bash -n \"${artifact_root}/scripts/rollback.sh\"\n          bash -n \"${artifact_root}/scripts/verify-dependencies.sh\"\n\n          cat > \"${artifact_root}/docs/ROLLBACK.md\" <<'ROLLBACK_DOC'\n          # Rollback Plan\n\n          This rollback package supports recovery from deployment commit `__CURRENT_SHA__` to the previous commit `__PREVIOUS_SHA__` for package version `__PACKAGE_VERSION__`.\n\n          ## Contents\n\n          - `scripts/rollback.sh` - executable rollback script with validation and optional push support.\n          - `scripts/verify-dependencies.sh` - dependency compatibility checker using the backed-up package files.\n          - `config-backups/package.json` - package manifest captured at deployment time.\n          - `config-backups/package-lock.json` - dependency lockfile captured at deployment time.\n          - `config-backups/environment-templates/` - discovered environment templates plus `.env.rollback.template`.\n          - `checksums/SHA256SUMS` - checksums for every file in the extracted rollback package.\n\n          ## Step-by-step rollback instructions\n\n          1. Download the GitHub Actions artifact named `__ARTIFACT_NAME__` from the deployment workflow run.\n          2. Verify the compressed archive checksum.\n          3. Extract the archive and verify the internal file checksums.\n          4. Run the dependency verification script.\n          5. Execute the rollback script locally first without `--push`.\n          6. Re-run the rollback script with `--push` only after local validation succeeds and the team approves the rollback.\n          7. Confirm the application health check after the rollback is pushed.\n\n          ## Quick rollback command\n\n          ```bash\n          sha256sum -c __ARTIFACT_NAME__.tar.gz.sha256\n          tar -xzf __ARTIFACT_NAME__.tar.gz\n          cd __ARTIFACT_NAME__\n          sha256sum -c checksums/SHA256SUMS\n          ./scripts/verify-dependencies.sh\n          ./scripts/rollback.sh --push __PREVIOUS_SHA__\n          ```\n\n          ## Safety notes\n\n          - The rollback script exits on errors, checks for required tools, and refuses to run with a dirty working tree.\n          - The script uses `git push --force-with-lease` only when `--push` is supplied.\n          - Keep this artifact for the full retention period so the exact deployment configuration can be restored.\n          ROLLBACK_DOC\n\n          sed -i \\\n            -e \"s|__PREVIOUS_SHA__|${PREVIOUS_SHA}|g\" \\\n            -e \"s|__CURRENT_SHA__|${CURRENT_SHA}|g\" \\\n            -e \"s|__PACKAGE_VERSION__|${PACKAGE_VERSION}|g\" \\\n            -e \"s|__ARTIFACT_NAME__|${artifact_name}|g\" \\\n            \"${artifact_root}/docs/ROLLBACK.md\"\n\n          cat > \"${artifact_root}/metadata.json\" <<EOF_METADATA\n          {\n            \"artifactName\": \"${artifact_name}\",\n            \"currentCommit\": \"${CURRENT_SHA}\",\n            \"previousCommit\": \"${PREVIOUS_SHA}\",\n            \"packageVersion\": \"${PACKAGE_VERSION}\",\n            \"environmentTemplatesDiscovered\": ${env_template_count},\n            \"createdAt\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"\n          }\n          EOF_METADATA\n\n          rollback_script_created=false\n          configuration_backup=false\n\n          if [[ -x \"${artifact_root}/scripts/rollback.sh\" ]] && bash -n \"${artifact_root}/scripts/rollback.sh\"; then\n            rollback_script_created=true\n          fi\n\n          if [[ -s \"${artifact_root}/config-backups/package.json\" && -s \"${artifact_root}/config-backups/package-lock.json\" && -s \"${artifact_root}/config-backups/environment-templates/.env.rollback.template\" ]]; then\n            configuration_backup=true\n          fi\n\n          if [[ \"${rollback_script_created}\" != \"true\" || \"${configuration_backup}\" != \"true\" ]]; then\n            echo \"::error::Rollback package verification failed.\"\n            exit 1\n          fi\n\n          (\n            cd \"${artifact_root}\"\n            find . -type f ! -path \"./checksums/SHA256SUMS\" -print0 | sort -z | xargs -0 sha256sum > checksums/SHA256SUMS\n            sha256sum -c checksums/SHA256SUMS\n          )\n\n          tar -czf \"${staging_dir}/${artifact_name}.tar.gz\" -C \"${RUNNER_TEMP}\" \"${artifact_name}\"\n          artifact_checksum=\"$(sha256sum \"${staging_dir}/${artifact_name}.tar.gz\" | awk '{print $1}')\"\n          echo \"${artifact_checksum}  ${artifact_name}.tar.gz\" > \"${staging_dir}/${artifact_name}.tar.gz.sha256\"\n          (cd \"${staging_dir}\" && sha256sum -c \"${artifact_name}.tar.gz.sha256\")\n\n          echo \"artifact_name=${artifact_name}\" >> \"${GITHUB_OUTPUT}\"\n          echo \"artifact_checksum=${artifact_checksum}\" >> \"${GITHUB_OUTPUT}\"\n          echo \"rollback_script_created=${rollback_script_created}\" >> \"${GITHUB_OUTPUT}\"\n          echo \"configuration_backup=${configuration_backup}\" >> \"${GITHUB_OUTPUT}\"\n\n      - name: Upload rollback artifact\n        uses: actions/upload-artifact@v4\n        with:\n          name: ${{ steps.rollback_artifact.outputs.artifact_name }}\n          path: rollback-artifacts/\n          retention-days: 30\n          if-no-files-found: error\n\n      - name: Comment with rollback plan\n        uses: actions/github-script@v7\n        env:\n          ISSUE_NUMBER: ${{ needs.pre-deployment.outputs.issue_number }}\n          CURRENT_SHA: ${{ needs.pre-deployment.outputs.current_sha }}\n          PREVIOUS_SHA: ${{ needs.pre-deployment.outputs.previous_sha }}\n          PACKAGE_VERSION: ${{ needs.pre-deployment.outputs.package_version }}\n          ARTIFACT_NAME: ${{ steps.rollback_artifact.outputs.artifact_name }}\n          ARTIFACT_CHECKSUM: ${{ steps.rollback_artifact.outputs.artifact_checksum }}\n          ROLLBACK_SCRIPT_CREATED: ${{ steps.rollback_artifact.outputs.rollback_script_created }}\n          CONFIGURATION_BACKUP: ${{ steps.rollback_artifact.outputs.configuration_backup }}\n        with:\n          script: |\n            const { owner, repo } = context.repo;\n            const issue_number = Number(process.env.ISSUE_NUMBER);\n\n            if (!Number.isInteger(issue_number)) {\n              throw new Error(`Invalid deployment issue number: ${process.env.ISSUE_NUMBER}`);\n            }\n\n            const body = `## 🔄 Rollback Plan Ready\n\nPrevious Commit: ${process.env.PREVIOUS_SHA}\nCurrent Commit: ${process.env.CURRENT_SHA}\nPackage Version: ${process.env.PACKAGE_VERSION}\nArtifact: ${process.env.ARTIFACT_NAME}\nSHA256: ${process.env.ARTIFACT_CHECKSUM}\n\n✅ Rollback script generated and syntax-checked\n✅ Package manifest backup captured\n✅ Package lockfile backup captured\n✅ Environment template backup prepared\n✅ Dependency verification script created\n✅ Rollback documentation generated\n✅ Compressed artifact uploaded with checksum\n\nRollback script created: ${process.env.ROLLBACK_SCRIPT_CREATED}\nConfiguration backup: ${process.env.CONFIGURATION_BACKUP}\n\n### Quick rollback command\n\n\\`\\`\\`bash\ngh run download ${context.runId} --name ${process.env.ARTIFACT_NAME}\nsha256sum -c ${process.env.ARTIFACT_NAME}.tar.gz.sha256\ntar -xzf ${process.env.ARTIFACT_NAME}.tar.gz\ncd ${process.env.ARTIFACT_NAME}\nsha256sum -c checksums/SHA256SUMS\n./scripts/verify-dependencies.sh\n./scripts/rollback.sh --push ${process.env.PREVIOUS_SHA}\n\\`\\`\\`\n`;\n\n            await github.rest.issues.createComment({ owner, repo, issue_number, body });\n\n  post-deployment:\n    name: post-deployment\n    runs-on: ubuntu-latest\n    needs:\n      - pre-deployment\n      - rollback-preparation\n    steps:\n      - name: Download rollback artifact\n        uses: actions/download-artifact@v4\n        with:\n          name: ${{ needs.rollback-preparation.outputs.artifact_name }}\n          path: downloaded-rollback-artifact\n\n      - name: Verify downloaded rollback artifact checksum\n        shell: bash\n        env:\n          ARTIFACT_NAME: ${{ needs.rollback-preparation.outputs.artifact_name }}\n          ARTIFACT_CHECKSUM: ${{ needs.rollback-preparation.outputs.artifact_checksum }}\n        run: |\n          set -euo pipefail\n          cd downloaded-rollback-artifact\n          test -f \"${ARTIFACT_NAME}.tar.gz\"\n          test -f \"${ARTIFACT_NAME}.tar.gz.sha256\"\n          echo \"${ARTIFACT_CHECKSUM}  ${ARTIFACT_NAME}.tar.gz\" | sha256sum -c -\n          sha256sum -c \"${ARTIFACT_NAME}.tar.gz.sha256\"\n\n      - name: Complete deployment issue\n        uses: actions/github-script@v7\n        env:\n          ISSUE_NUMBER: ${{ needs.pre-deployment.outputs.issue_number }}\n          CURRENT_SHA: ${{ needs.pre-deployment.outputs.current_sha }}\n          PREVIOUS_SHA: ${{ needs.pre-deployment.outputs.previous_sha }}\n          PACKAGE_VERSION: ${{ needs.pre-deployment.outputs.package_version }}\n          ARTIFACT_NAME: ${{ needs.rollback-preparation.outputs.artifact_name }}\n          ARTIFACT_CHECKSUM: ${{ needs.rollback-preparation.outputs.artifact_checksum }}\n        with:\n          script: |\n            const { owner, repo } = context.repo;\n            const issue_number = Number(process.env.ISSUE_NUMBER);\n\n            if (!Number.isInteger(issue_number)) {\n              throw new Error(`Invalid deployment issue number: ${process.env.ISSUE_NUMBER}`);\n            }\n\n            try {\n              await github.rest.issues.removeLabel({ owner, repo, issue_number, name: 'in-progress' });\n            } catch (error) {\n              if (error.status !== 404) {\n                throw error;\n              }\n            }\n\n            try {\n              await github.rest.issues.getLabel({ owner, repo, name: 'completed' });\n            } catch (error) {\n              if (error.status === 404) {\n                await github.rest.issues.createLabel({ owner, repo, name: 'completed', color: '0E8A16', description: 'Deployment completed successfully' });\n              } else {\n                throw error;\n              }\n            }\n\n            await github.rest.issues.addLabels({ owner, repo, issue_number, labels: ['completed'] });\n\n            const body = [\n              'Deployment Completed Successfully',\n              '',\n              `Current Commit: ${process.env.CURRENT_SHA}`,\n              `Previous Commit: ${process.env.PREVIOUS_SHA}`,\n              `Package Version: ${process.env.PACKAGE_VERSION}`,\n              `Rollback Artifact: ${process.env.ARTIFACT_NAME}`,\n              `SHA256: ${process.env.ARTIFACT_CHECKSUM}`,\n              '',\n              'The rollback artifact was downloaded and its checksum was verified before closing this deployment issue.'\n            ].join('\\n');\n\n            await github.rest.issues.createComment({ owner, repo, issue_number, body });\n            await github.rest.issues.update({ owner, repo, issue_number, state: 'closed' });\n",
