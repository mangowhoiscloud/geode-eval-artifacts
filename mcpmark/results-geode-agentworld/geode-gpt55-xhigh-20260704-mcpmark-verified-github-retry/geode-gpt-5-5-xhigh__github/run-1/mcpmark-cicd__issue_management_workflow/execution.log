        {
          "content": "name: Issue Management Automation\n\non:\n  issues:\n    types: [opened, labeled]\n\npermissions:\n  contents: read\n  issues: write\n\nconcurrency:\n  group: issue-automation-${{ github.event.issue.number }}\n  cancel-in-progress: false\n\njobs:\n  issue-triage:\n    name: Issue Triage\n    runs-on: ubuntu-latest\n    steps:\n      - name: Triage issue and manage labels\n        uses: actions/github-script@v7\n        with:\n          script: |\n            const issueApi = github.rest.issues;\n            const { owner, repo } = context.repo;\n            const issueNumber = context.payload.issue.number;\n\n            const labelDefinitions = [\n              { name: 'bug', color: 'd73a4a', description: \"Something isn't working\" },\n              { name: 'enhancement', color: 'a2eeef', description: 'New feature or request' },\n              { name: 'epic', color: '5319e7', description: 'Large feature requiring multiple sub-tasks' },\n              { name: 'maintenance', color: 'fef2c0', description: 'Maintenance and housekeeping tasks' },\n              { name: 'priority-critical', color: 'b60205', description: 'Critical priority issue' },\n              { name: 'priority-high', color: 'd93f0b', description: 'High priority issue' },\n              { name: 'priority-medium', color: 'fbca04', description: 'Medium priority issue' },\n              { name: 'priority-low', color: '0e8a16', description: 'Low priority issue' },\n              { name: 'needs-triage', color: 'cfd3d7', description: 'Needs to be reviewed by maintainers' },\n              { name: 'needs-review', color: '1d76db', description: 'Awaiting review from maintainers' },\n              { name: 'first-time-contributor', color: '7057ff', description: 'Issue created by first-time contributor' }\n            ];\n\n            async function ensureLabel(definition) {\n              try {\n                await issueApi.getLabel({ owner, repo, name: definition.name });\n                await issueApi.updateLabel({\n                  owner,\n                  repo,\n                  name: definition.name,\n                  new_name: definition.name,\n                  color: definition.color,\n                  description: definition.description\n                });\n                core.info(`Label ${definition.name} is available and up to date.`);\n              } catch (error) {\n                if (error.status === 404) {\n                  try {\n                    await issueApi.createLabel({ owner, repo, ...definition });\n                    core.info(`Created label ${definition.name}.`);\n                  } catch (createError) {\n                    if (createError.status === 422) {\n                      core.info(`Label ${definition.name} already exists after a concurrent run.`);\n                    } else {\n                      throw createError;\n                    }\n                  }\n                } else if (error.status === 422) {\n                  core.info(`Label ${definition.name} could not be updated because it already exists with the requested name.`);\n                } else {\n                  throw error;\n                }\n              }\n            }\n\n            for (const definition of labelDefinitions) {\n              await ensureLabel(definition);\n            }\n\n            const { data: latestIssue } = await issueApi.get({ owner, repo, issue_number: issueNumber });\n            const title = latestIssue.title || '';\n            const titleLower = title.toLowerCase();\n            const isAutomationSubtask = title.trim().toLowerCase().startsWith('[subtask]') && latestIssue.user?.login === 'github-actions[bot]';\n\n            if (isAutomationSubtask) {\n              core.info('Skipping triage for an automation-created sub-issue.');\n              return;\n            }\n\n            const body = latestIssue.body || '';\n            const searchableText = `${title}\\n${body}`.toLowerCase();\n            const currentLabels = new Set(latestIssue.labels.map((label) => label.name));\n            const labelsToAdd = [];\n\n            if (titleLower.includes('bug')) {\n              labelsToAdd.push('bug');\n            }\n            if (titleLower.includes('epic')) {\n              labelsToAdd.push('epic');\n            }\n            if (titleLower.includes('maintenance')) {\n              labelsToAdd.push('maintenance');\n            }\n\n            const criticalKeywords = ['critical', 'urgent', 'production', 'outage'];\n            const highKeywords = ['important', 'high', 'blocking'];\n            const mediumKeywords = ['medium', 'normal'];\n            const lowKeywords = ['low', 'nice-to-have', 'minor'];\n            const priorityLabels = ['priority-critical', 'priority-high', 'priority-medium', 'priority-low'];\n\n            let priorityLabel = 'priority-medium';\n            if (criticalKeywords.some((keyword) => searchableText.includes(keyword))) {\n              priorityLabel = 'priority-critical';\n            } else if (highKeywords.some((keyword) => searchableText.includes(keyword))) {\n              priorityLabel = 'priority-high';\n            } else if (mediumKeywords.some((keyword) => searchableText.includes(keyword))) {\n              priorityLabel = 'priority-medium';\n            } else if (lowKeywords.some((keyword) => searchableText.includes(keyword))) {\n              priorityLabel = 'priority-low';\n            }\n\n            for (const existingPriorityLabel of priorityLabels) {\n              if (existingPriorityLabel !== priorityLabel && currentLabels.has(existingPriorityLabel)) {\n                try {\n                  await issueApi.removeLabel({ owner, repo, issue_number: issueNumber, name: existingPriorityLabel });\n                  currentLabels.delete(existingPriorityLabel);\n                  core.info(`Removed lower-priority/conflicting label ${existingPriorityLabel}.`);\n                } catch (error) {\n                  if (error.status !== 404) {\n                    throw error;\n                  }\n                }\n              }\n            }\n\n            labelsToAdd.push(priorityLabel);\n\n            if (!currentLabels.has('needs-review')) {\n              labelsToAdd.push('needs-triage');\n            }\n\n            const missingLabels = [...new Set(labelsToAdd)].filter((labelName) => !currentLabels.has(labelName));\n            if (missingLabels.length > 0) {\n              await issueApi.addLabels({ owner, repo, issue_number: issueNumber, labels: missingLabels });\n              core.info(`Added labels: ${missingLabels.join(', ')}`);\n            } else {\n              core.info('No triage labels needed to be added.');\n            }\n\n  task-breakdown:\n    name: Task Breakdown\n    runs-on: ubuntu-latest\n    needs: issue-triage\n    steps:\n      - name: Create and link epic sub-issues\n        uses: actions/github-script@v7\n        with:\n          script: |\n            const issueApi = github.rest.issues;\n            const { owner, repo } = context.repo;\n            const issueNumber = context.payload.issue.number;\n\n            const { data: parentIssue } = await issueApi.get({ owner, repo, issue_number: issueNumber });\n            const title = parentIssue.title || '';\n            const titleLower = title.toLowerCase();\n            const isAutomationSubtask = title.trim().toLowerCase().startsWith('[subtask]') || parentIssue.user?.login === 'github-actions[bot]';\n\n            if (!titleLower.includes('epic') || isAutomationSubtask) {\n              core.info('Issue is not a human-authored epic; skipping task breakdown.');\n              return;\n            }\n\n            const tasks = [\n              { number: 1, name: 'Requirements Analysis' },\n              { number: 2, name: 'Design and Architecture' },\n              { number: 3, name: 'Implementation' },\n              { number: 4, name: 'Testing and Documentation' }\n            ];\n\n            async function listAllIssues() {\n              const allIssues = [];\n              for (let page = 1; ; page += 1) {\n                const { data } = await issueApi.listForRepo({ owner, repo, state: 'all', per_page: 100, page });\n                allIssues.push(...data);\n                if (data.length < 100) {\n                  break;\n                }\n              }\n              return allIssues;\n            }\n\n            const existingIssues = await listAllIssues();\n            const subIssues = [];\n\n            for (const task of tasks) {\n              const expectedTitle = `[SUBTASK] ${title} - Task ${task.number}: ${task.name}`;\n              let subIssue = existingIssues.find((candidate) => (\n                !candidate.pull_request &&\n                candidate.title === expectedTitle &&\n                (candidate.body || '').includes(`Related to #${parentIssue.number}`)\n              ));\n\n              if (!subIssue) {\n                const body = [\n                  `Related to #${parentIssue.number}`,\n                  '',\n                  `This sub-issue was created automatically for epic #${parentIssue.number}.`,\n                  `Task ${task.number}: ${task.name}`\n                ].join('\\n');\n\n                const { data: createdSubIssue } = await issueApi.create({\n                  owner,\n                  repo,\n                  title: expectedTitle,\n                  body,\n                  labels: ['enhancement', 'needs-review']\n                });\n                subIssue = createdSubIssue;\n                core.info(`Created sub-issue #${subIssue.number}: ${expectedTitle}`);\n              } else {\n                core.info(`Found existing sub-issue #${subIssue.number}: ${expectedTitle}`);\n              }\n\n              const subIssueLabels = new Set((subIssue.labels || []).map((label) => label.name));\n              const labelsToAdd = ['enhancement', 'needs-review'].filter((labelName) => !subIssueLabels.has(labelName));\n              if (labelsToAdd.length > 0) {\n                await issueApi.addLabels({ owner, repo, issue_number: subIssue.number, labels: labelsToAdd });\n                core.info(`Added labels to sub-issue #${subIssue.number}: ${labelsToAdd.join(', ')}`);\n              }\n\n              subIssues.push(subIssue);\n            }\n\n            const checklist = subIssues.map((subIssue, index) => {\n              const task = tasks[index];\n              return `- [ ] #${subIssue.number} - Task ${task.number}: ${task.name}`;\n            }).join('\\n');\n\n            const epicSection = `## Epic Tasks\\n\\n${checklist}`;\n            const originalBody = parentIssue.body || '';\n            const epicHeadingIndex = originalBody.indexOf('## Epic Tasks');\n            const baseBody = (epicHeadingIndex >= 0 ? originalBody.slice(0, epicHeadingIndex) : originalBody).trim();\n            const updatedBody = [baseBody, epicSection].filter(Boolean).join('\\n\\n');\n\n            if (updatedBody !== originalBody) {\n              await issueApi.update({ owner, repo, issue_number: parentIssue.number, body: updatedBody });\n              core.info(`Updated epic #${parentIssue.number} with the sub-issue checklist.`);\n            } else {\n              core.info('Epic checklist is already up to date.');\n            }\n\n  auto-response:\n    name: Auto Response\n    runs-on: ubuntu-latest\n    needs: [issue-triage, task-breakdown]\n    steps:\n      - name: Respond to issue and update status\n        uses: actions/github-script@v7\n        with:\n          script: |\n            const issueApi = github.rest.issues;\n            const { owner, repo } = context.repo;\n            const issueNumber = context.payload.issue.number;\n\n            const { data: latestIssue } = await issueApi.get({ owner, repo, issue_number: issueNumber });\n            const title = latestIssue.title || '';\n            const titleLower = title.toLowerCase();\n            const isAutomationSubtask = title.trim().toLowerCase().startsWith('[subtask]') && latestIssue.user?.login === 'github-actions[bot]';\n\n            if (isAutomationSubtask) {\n              core.info('Skipping automated response for an automation-created sub-issue.');\n              return;\n            }\n\n            const labels = new Set(latestIssue.labels.map((label) => label.name));\n\n            async function addLabelsSafely(labelNames) {\n              const missing = labelNames.filter((labelName) => !labels.has(labelName));\n              if (missing.length === 0) {\n                return;\n              }\n              await issueApi.addLabels({ owner, repo, issue_number: issueNumber, labels: missing });\n              for (const labelName of missing) {\n                labels.add(labelName);\n              }\n              core.info(`Added labels: ${missing.join(', ')}`);\n            }\n\n            async function removeLabelSafely(labelName) {\n              if (!labels.has(labelName)) {\n                return;\n              }\n              try {\n                await issueApi.removeLabel({ owner, repo, issue_number: issueNumber, name: labelName });\n                labels.delete(labelName);\n                core.info(`Removed label: ${labelName}`);\n              } catch (error) {\n                if (error.status !== 404) {\n                  throw error;\n                }\n              }\n            }\n\n            async function hasPriorHumanIssueByAuthor(authorLogin, currentCreatedAt) {\n              for (let page = 1; ; page += 1) {\n                const { data } = await issueApi.listForRepo({\n                  owner,\n                  repo,\n                  state: 'all',\n                  creator: authorLogin,\n                  per_page: 100,\n                  page\n                });\n\n                for (const candidate of data) {\n                  if (candidate.pull_request || candidate.number === issueNumber) {\n                    continue;\n                  }\n                  if (candidate.user?.login === 'github-actions[bot]') {\n                    continue;\n                  }\n                  if (candidate.user?.login !== authorLogin) {\n                    continue;\n                  }\n\n                  const candidateCreatedAt = new Date(candidate.created_at).getTime();\n                  if (candidateCreatedAt < currentCreatedAt || (candidateCreatedAt === currentCreatedAt && candidate.number < issueNumber)) {\n                    return true;\n                  }\n                }\n\n                if (data.length < 100) {\n                  break;\n                }\n              }\n              return false;\n            }\n\n            const authorLogin = latestIssue.user?.login || '';\n            let isFirstIssueInRepo = false;\n            if (authorLogin && authorLogin !== 'github-actions[bot]') {\n              const currentCreatedAt = new Date(latestIssue.created_at).getTime();\n              isFirstIssueInRepo = !(await hasPriorHumanIssueByAuthor(authorLogin, currentCreatedAt));\n              if (isFirstIssueInRepo) {\n                await addLabelsSafely(['first-time-contributor']);\n              }\n            }\n\n            async function findOrCreateMilestone(title) {\n              for (let page = 1; ; page += 1) {\n                const { data } = await issueApi.listMilestones({ owner, repo, state: 'all', per_page: 100, page });\n                const milestone = data.find((candidate) => candidate.title === title);\n                if (milestone) {\n                  return milestone;\n                }\n                if (data.length < 100) {\n                  break;\n                }\n              }\n\n              try {\n                const { data: createdMilestone } = await issueApi.createMilestone({\n                  owner,\n                  repo,\n                  title,\n                  description: 'Issues targeted for the v1.0.0 release.'\n                });\n                return createdMilestone;\n              } catch (error) {\n                if (error.status !== 422) {\n                  throw error;\n                }\n                for (let page = 1; ; page += 1) {\n                  const { data } = await issueApi.listMilestones({ owner, repo, state: 'all', per_page: 100, page });\n                  const milestone = data.find((candidate) => candidate.title === title);\n                  if (milestone) {\n                    return milestone;\n                  }\n                  if (data.length < 100) {\n                    break;\n                  }\n                }\n                throw error;\n              }\n            }\n\n            if (labels.has('priority-high') || labels.has('priority-critical')) {\n              const milestone = await findOrCreateMilestone('v1.0.0');\n              if (latestIssue.milestone?.number !== milestone.number) {\n                await issueApi.update({ owner, repo, issue_number: issueNumber, milestone: milestone.number });\n                core.info(`Assigned milestone ${milestone.title}.`);\n              }\n            }\n\n            const { data: comments } = await issueApi.listComments({ owner, repo, issue_number: issueNumber, per_page: 100 });\n            const hasAutomationResponse = comments.some((comment) => (\n              comment.user?.login === 'github-actions[bot]' &&\n              (comment.body || '').includes('<!-- issue-automation-response -->')\n            ));\n\n            if (!hasAutomationResponse) {\n              const sections = ['<!-- issue-automation-response -->'];\n\n              if (isFirstIssueInRepo) {\n                sections.push(`Welcome @${authorLogin}! Thanks for opening your first issue in this repository. A maintainer will review it soon.`);\n              }\n\n              if (labels.has('bug') || titleLower.includes('bug')) {\n                sections.push([\n                  '## Bug Report Guidelines',\n                  'Thanks for reporting a bug. Please make sure the issue includes clear reproduction steps, expected behavior, actual behavior, and any relevant logs or environment details.'\n                ].join('\\n\\n'));\n              } else if (labels.has('epic') || titleLower.includes('epic')) {\n                sections.push([\n                  '## Feature Request Process',\n                  'Thanks for proposing an epic. The automation has prepared the standard task breakdown so maintainers can review scope, design, implementation, and validation work.'\n                ].join('\\n\\n'));\n              } else if (labels.has('maintenance') || titleLower.includes('maintenance')) {\n                sections.push([\n                  '## Maintenance Guidelines',\n                  'Thanks for identifying maintenance work. Please keep the scope clear, note any affected modules, and include validation steps for reviewers.'\n                ].join('\\n\\n'));\n              } else {\n                sections.push('Thanks for opening this issue. A maintainer will review it soon.');\n              }\n\n              await issueApi.createComment({ owner, repo, issue_number: issueNumber, body: sections.join('\\n\\n') });\n              core.info('Posted the automated issue response.');\n            } else {\n              core.info('Automated issue response already exists; skipping duplicate comment.');\n            }\n\n            await removeLabelSafely('needs-triage');\n            await addLabelsSafely(['needs-review']);\n",
          "path": ".github/workflows/issue-automation.yml"
        }
      ],
      "message": "Add issue management automation workflow",
      "owner": "mangowhoiscloud",
      "repo": "mcpmark-cicd"
