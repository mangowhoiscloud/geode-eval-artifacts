      "result": "{\"meta\": null, \"content\": [{\"type\": \"text\", \"text\": \"[{\\\"sha\\\":\\\"8c72f78212db1019e8cdcfd77e6058f80a30cc9f\\\",\\\"filename\\\":\\\".github/workflows/pr-automation.yml\\\",\\\"additions\\\":795,\\\"deletions\\\":0,\\\"changes\\\":795,\\\"status\\\":\\\"added\\\",\\\"patch\\\":\\\"@@ -0,0 +1,795 @@\\\\n+name: Pull Request Automation\\\\n+\\\\n+on:\\\\n+  pull_request:\\\\n+    types: [opened, synchronize, reopened]\\\\n+\\\\n+permissions:\\\\n+  contents: read\\\\n+  issues: write\\\\n+  pull-requests: write\\\\n+\\\\n+concurrency:\\\\n+  group: pr-automation-${{ github.event.pull_request.number }}\\\\n+  cancel-in-progress: true\\\\n+\\\\n+env:\\\\n+  NODE_VERSION: '20'\\\\n+\\\\n+jobs:\\\\n+  code-quality:\\\\n+    name: code-quality\\\\n+    runs-on: ubuntu-latest\\\\n+    timeout-minutes: 15\\\\n+\\\\n+    steps:\\\\n+      - name: Checkout repository\\\\n+        uses: actions/checkout@v4\\\\n+\\\\n+      - name: Setup Node.js\\\\n+        uses: actions/setup-node@v4\\\\n+        with:\\\\n+          node-version: ${{ env.NODE_VERSION }}\\\\n+          cache: npm\\\\n+\\\\n+      - name: Install dependencies\\\\n+        run: npm ci\\\\n+\\\\n+      - name: Run ESLint\\\\n+        id: eslint\\\\n+        shell: bash\\\\n+        run: |\\\\n+          set +e\\\\n+          npm run lint \\\\u003e eslint-output.log 2\\\\u003e\\\\u00261\\\\n+          eslint_exit=$?\\\\n+\\\\n+          if [ \\\\\\\"$eslint_exit\\\\\\\" -eq 0 ]; then\\\\n+            echo \\\\\\\"status=passed\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+            echo \\\\\\\"ESLint completed successfully.\\\\\\\"\\\\n+          else\\\\n+            echo \\\\\\\"status=failed\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+            echo \\\\\\\"::error::ESLint reported issues. See eslint-output.log for details.\\\\\\\"\\\\n+          fi\\\\n+\\\\n+          echo \\\\\\\"exit_code=$eslint_exit\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+          exit 0\\\\n+\\\\n+      - name: Run Prettier formatting check\\\\n+        id: prettier\\\\n+        shell: bash\\\\n+        run: |\\\\n+          set +e\\\\n+          npx prettier --check \\\\\\\"src/**/*.js\\\\\\\" \\\\\\\"tests/**/*.js\\\\\\\" \\\\\\\"package.json\\\\\\\" \\\\\\\".github/workflows/*.yml\\\\\\\" \\\\u003e prettier-output.log 2\\\\u003e\\\\u00261\\\\n+          prettier_exit=$?\\\\n+\\\\n+          if [ \\\\\\\"$prettier_exit\\\\\\\" -eq 0 ]; then\\\\n+            echo \\\\\\\"status=passed\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+            echo \\\\\\\"Prettier formatting check completed successfully.\\\\\\\"\\\\n+          else\\\\n+            echo \\\\\\\"status=failed\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+            echo \\\\\\\"::error::Prettier found formatting issues. See prettier-output.log for details.\\\\\\\"\\\\n+          fi\\\\n+\\\\n+          echo \\\\\\\"exit_code=$prettier_exit\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+          exit 0\\\\n+\\\\n+      - name: Post Code Quality Report PR comment\\\\n+        if: ${{ always() \\\\u0026\\\\u0026 github.event_name == 'pull_request' }}\\\\n+        uses: actions/github-script@v7\\\\n+        continue-on-error: true\\\\n+        with:\\\\n+          script: |\\\\n+            const fs = require('fs');\\\\n+\\\\n+            const qualityMarker = '\\\\u003c!-- pr-automation:code-quality --\\\\u003e';\\\\n+            const qualityOwner = context.repo.owner;\\\\n+            const qualityRepo = context.repo.repo;\\\\n+            const qualityIssueNumber = context.issue.number;\\\\n+            const qualityRunUrl = `https://github.com/${qualityOwner}/${qualityRepo}/actions/runs/${context.runId}`;\\\\n+\\\\n+            const readQualityLog = logPath =\\\\u003e {\\\\n+              try {\\\\n+                const logContent = fs.readFileSync(logPath, 'utf8').trim();\\\\n+                return logContent ? logContent.slice(-4000) : 'No output.';\\\\n+              } catch (qualityReadError) {\\\\n+                return `Log unavailable: ${qualityReadError.message}`;\\\\n+              }\\\\n+            };\\\\n+\\\\n+            const eslintStatus = '${{ steps.eslint.outputs.status }}' || 'unknown';\\\\n+            const prettierStatus = '${{ steps.prettier.outputs.status }}' || 'unknown';\\\\n+            const eslintLog = readQualityLog('eslint-output.log');\\\\n+            const prettierLog = readQualityLog('prettier-output.log');\\\\n+\\\\n+            const qualityBody = [\\\\n+              qualityMarker,\\\\n+              '## Code Quality Report',\\\\n+              '',\\\\n+              `- ESLint: **${eslintStatus}**`,\\\\n+              `- Prettier: **${prettierStatus}**`,\\\\n+              `- Workflow run: ${qualityRunUrl}`,\\\\n+              '',\\\\n+              '\\\\u003cdetails\\\\u003e\\\\u003csummary\\\\u003eESLint output\\\\u003c/summary\\\\u003e',\\\\n+              '',\\\\n+              '```text',\\\\n+              eslintLog,\\\\n+              '```',\\\\n+              '\\\\u003c/details\\\\u003e',\\\\n+              '',\\\\n+              '\\\\u003cdetails\\\\u003e\\\\u003csummary\\\\u003ePrettier output\\\\u003c/summary\\\\u003e',\\\\n+              '',\\\\n+              '```text',\\\\n+              prettierLog,\\\\n+              '```',\\\\n+              '\\\\u003c/details\\\\u003e'\\\\n+            ].join('\\\\\\\\n');\\\\n+\\\\n+            const qualityComments = await github.rest.issues.listComments({\\\\n+              owner: qualityOwner,\\\\n+              repo: qualityRepo,\\\\n+              issue_number: qualityIssueNumber,\\\\n+              per_page: 100\\\\n+            });\\\\n+\\\\n+            const previousQualityComment = qualityComments.data.find(commentItem =\\\\u003e\\\\n+              commentItem.body \\\\u0026\\\\u0026 commentItem.body.includes(qualityMarker)\\\\n+            );\\\\n+\\\\n+            if (previousQualityComment) {\\\\n+              await github.rest.issues.updateComment({\\\\n+                owner: qualityOwner,\\\\n+                repo: qualityRepo,\\\\n+                comment_id: previousQualityComment.id,\\\\n+                body: qualityBody\\\\n+              });\\\\n+            } else {\\\\n+              await github.rest.issues.createComment({\\\\n+                owner: qualityOwner,\\\\n+                repo: qualityRepo,\\\\n+                issue_number: qualityIssueNumber,\\\\n+                body: qualityBody\\\\n+              });\\\\n+            }\\\\n+\\\\n+      - name: Enforce code quality gate\\\\n+        if: ${{ steps.eslint.outputs.exit_code != '0' || steps.prettier.outputs.exit_code != '0' }}\\\\n+        run: |\\\\n+          echo \\\\\\\"::error::Code quality checks failed. Review the Code Quality Report comment for details.\\\\\\\"\\\\n+          exit 1\\\\n+\\\\n+  testing-suite:\\\\n+    name: testing-suite\\\\n+    runs-on: ubuntu-latest\\\\n+    timeout-minutes: 20\\\\n+\\\\n+    steps:\\\\n+      - name: Checkout repository\\\\n+        uses: actions/checkout@v4\\\\n+\\\\n+      - name: Setup Node.js\\\\n+        uses: actions/setup-node@v4\\\\n+        with:\\\\n+          node-version: ${{ env.NODE_VERSION }}\\\\n+          cache: npm\\\\n+\\\\n+      - name: Install dependencies\\\\n+        run: npm ci\\\\n+\\\\n+      - name: Run full test suite and collect coverage\\\\n+        id: tests\\\\n+        shell: bash\\\\n+        run: |\\\\n+          set +e\\\\n+          npm test -- --coverage --coverageReporters=json-summary --coverageReporters=text --coverageReporters=lcov \\\\u003e test-output.log 2\\\\u003e\\\\u00261\\\\n+          test_exit=$?\\\\n+\\\\n+          if [ \\\\\\\"$test_exit\\\\\\\" -eq 0 ]; then\\\\n+            echo \\\\\\\"status=passed\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+            echo \\\\\\\"Test suite completed successfully.\\\\\\\"\\\\n+          else\\\\n+            echo \\\\\\\"status=failed\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+            echo \\\\\\\"::error::Test suite or coverage threshold failed. See test-output.log for details.\\\\\\\"\\\\n+          fi\\\\n+\\\\n+          echo \\\\\\\"exit_code=$test_exit\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+          exit 0\\\\n+\\\\n+      - name: Upload coverage artifacts\\\\n+        if: ${{ always() }}\\\\n+        uses: actions/upload-artifact@v4\\\\n+        with:\\\\n+          name: coverage-report-${{ github.event.pull_request.number }}\\\\n+          path: coverage/\\\\n+          if-no-files-found: warn\\\\n+          retention-days: 14\\\\n+\\\\n+      - name: Post Test Coverage Report PR comment\\\\n+        if: ${{ always() \\\\u0026\\\\u0026 github.event_name == 'pull_request' }}\\\\n+        uses: actions/github-script@v7\\\\n+        continue-on-error: true\\\\n+        with:\\\\n+          script: |\\\\n+            const fs = require('fs');\\\\n+\\\\n+            const coverageMarker = '\\\\u003c!-- pr-automation:testing-suite --\\\\u003e';\\\\n+            const coverageOwner = context.repo.owner;\\\\n+            const coverageRepo = context.repo.repo;\\\\n+            const coverageIssueNumber = context.issue.number;\\\\n+            const coverageRunUrl = `https://github.com/${coverageOwner}/${coverageRepo}/actions/runs/${context.runId}`;\\\\n+\\\\n+            const readCoverageLog = logPath =\\\\u003e {\\\\n+              try {\\\\n+                const logContent = fs.readFileSync(logPath, 'utf8').trim();\\\\n+                return logContent ? logContent.slice(-4000) : 'No output.';\\\\n+              } catch (coverageReadError) {\\\\n+                return `Log unavailable: ${coverageReadError.message}`;\\\\n+              }\\\\n+            };\\\\n+\\\\n+            const coverageSummaryPath = 'coverage/coverage-summary.json';\\\\n+            let coverageTable = 'Coverage summary was not generated.';\\\\n+\\\\n+            if (fs.existsSync(coverageSummaryPath)) {\\\\n+              try {\\\\n+                const coverageSummary = JSON.parse(fs.readFileSync(coverageSummaryPath, 'utf8'));\\\\n+                const totalCoverage = coverageSummary.total || {};\\\\n+                const coverageRows = ['lines', 'statements', 'functions', 'branches']\\\\n+                  .filter(metricName =\\\\u003e totalCoverage[metricName])\\\\n+                  .map(metricName =\\\\u003e {\\\\n+                    const metricData = totalCoverage[metricName];\\\\n+                    return `| ${metricName} | ${metricData.covered} | ${metricData.total} | ${metricData.pct}% |`;\\\\n+                  });\\\\n+\\\\n+                if (coverageRows.length \\\\u003e 0) {\\\\n+                  coverageTable = [\\\\n+                    '| Metric | Covered | Total | Percentage |',\\\\n+                    '| --- | ---: | ---: | ---: |',\\\\n+                    ...coverageRows\\\\n+                  ].join('\\\\\\\\n');\\\\n+                }\\\\n+              } catch (coverageParseError) {\\\\n+                coverageTable = `Coverage summary could not be parsed: ${coverageParseError.message}`;\\\\n+              }\\\\n+            }\\\\n+\\\\n+            const testStatus = '${{ steps.tests.outputs.status }}' || 'unknown';\\\\n+            const testLog = readCoverageLog('test-output.log');\\\\n+\\\\n+            const coverageBody = [\\\\n+              coverageMarker,\\\\n+              '## Test Coverage Report',\\\\n+              '',\\\\n+              `- npm test status: **${testStatus}**`,\\\\n+              `- Coverage artifact: coverage-report-${{ github.event.pull_request.number }}`,\\\\n+              `- Workflow run: ${coverageRunUrl}`,\\\\n+              '',\\\\n+              coverageTable,\\\\n+              '',\\\\n+              '\\\\u003cdetails\\\\u003e\\\\u003csummary\\\\u003eTest output\\\\u003c/summary\\\\u003e',\\\\n+              '',\\\\n+              '```text',\\\\n+              testLog,\\\\n+              '```',\\\\n+              '\\\\u003c/details\\\\u003e'\\\\n+            ].join('\\\\\\\\n');\\\\n+\\\\n+            const coverageComments = await github.rest.issues.listComments({\\\\n+              owner: coverageOwner,\\\\n+              repo: coverageRepo,\\\\n+              issue_number: coverageIssueNumber,\\\\n+              per_page: 100\\\\n+            });\\\\n+\\\\n+            const previousCoverageComment = coverageComments.data.find(commentItem =\\\\u003e\\\\n+              commentItem.body \\\\u0026\\\\u0026 commentItem.body.includes(coverageMarker)\\\\n+            );\\\\n+\\\\n+            if (previousCoverageComment) {\\\\n+              await github.rest.issues.updateComment({\\\\n+                owner: coverageOwner,\\\\n+                repo: coverageRepo,\\\\n+                comment_id: previousCoverageComment.id,\\\\n+                body: coverageBody\\\\n+              });\\\\n+            } else {\\\\n+              await github.rest.issues.createComment({\\\\n+                owner: coverageOwner,\\\\n+                repo: coverageRepo,\\\\n+                issue_number: coverageIssueNumber,\\\\n+                body: coverageBody\\\\n+              });\\\\n+            }\\\\n+\\\\n+      - name: Enforce testing gate\\\\n+        if: ${{ steps.tests.outputs.exit_code != '0' }}\\\\n+        run: |\\\\n+          echo \\\\\\\"::error::Tests or coverage checks failed. Review the Test Coverage Report comment for details.\\\\\\\"\\\\n+          exit 1\\\\n+\\\\n+  security-scan:\\\\n+    name: security-scan\\\\n+    runs-on: ubuntu-latest\\\\n+    timeout-minutes: 20\\\\n+\\\\n+    steps:\\\\n+      - name: Checkout repository\\\\n+        uses: actions/checkout@v4\\\\n+        with:\\\\n+          fetch-depth: 0\\\\n+\\\\n+      - name: Setup Node.js\\\\n+        uses: actions/setup-node@v4\\\\n+        with:\\\\n+          node-version: ${{ env.NODE_VERSION }}\\\\n+          cache: npm\\\\n+\\\\n+      - name: Install dependencies\\\\n+        run: npm ci\\\\n+\\\\n+      - name: Run dependency vulnerability audit\\\\n+        id: audit\\\\n+        shell: bash\\\\n+        run: |\\\\n+          set +e\\\\n+          npm audit --audit-level=moderate --json \\\\u003e npm-audit.json 2\\\\u003e npm-audit-error.log\\\\n+          audit_exit=$?\\\\n+\\\\n+          node \\\\u003c\\\\u003c'NODE' \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+          const fs = require('fs');\\\\n+\\\\n+          const severityNames = ['info', 'low', 'moderate', 'high', 'critical'];\\\\n+          const auditCounts = { info: 0, low: 0, moderate: 0, high: 0, critical: 0, total: 0 };\\\\n+          let auditStatus = 'completed';\\\\n+\\\\n+          try {\\\\n+            const auditRaw = fs.readFileSync('npm-audit.json', 'utf8').trim();\\\\n+            if (!auditRaw) {\\\\n+              throw new Error('No JSON output was produced by npm audit.');\\\\n+            }\\\\n+\\\\n+            const auditJson = JSON.parse(auditRaw);\\\\n+            const vulnerabilitySummary = (auditJson.metadata \\\\u0026\\\\u0026 auditJson.metadata.vulnerabilities) || {};\\\\n+\\\\n+            for (const severityName of severityNames) {\\\\n+              auditCounts[severityName] = Number(vulnerabilitySummary[severityName] || 0);\\\\n+            }\\\\n+\\\\n+            auditCounts.total = Number(vulnerabilitySummary.total || severityNames.reduce((count, severityName) =\\\\u003e count + auditCounts[severityName], 0));\\\\n+          } catch (auditError) {\\\\n+            auditStatus = 'unavailable';\\\\n+            fs.writeFileSync('audit-parse-error.log', `${auditError.message}\\\\\\\\n`);\\\\n+          }\\\\n+\\\\n+          const auditMarkdown = [\\\\n+            '| Severity | Vulnerabilities |',\\\\n+            '| --- | ---: |',\\\\n+            `| Critical | ${auditCounts.critical} |`,\\\\n+            `| High | ${auditCounts.high} |`,\\\\n+            `| Moderate | ${auditCounts.moderate} |`,\\\\n+            `| Low | ${auditCounts.low} |`,\\\\n+            `| Info | ${auditCounts.info} |`,\\\\n+            `| Total | ${auditCounts.total} |`\\\\n+          ].join('\\\\\\\\n');\\\\n+\\\\n+          fs.writeFileSync('audit-summary.md', `${auditMarkdown}\\\\\\\\n`);\\\\n+          console.log(`status=${auditStatus}`);\\\\n+          console.log(`critical_count=${auditCounts.critical}`);\\\\n+          console.log(`total_count=${auditCounts.total}`);\\\\n+          NODE\\\\n+\\\\n+          echo \\\\\\\"exit_code=$audit_exit\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+          exit 0\\\\n+\\\\n+      - name: Scan changed files for secrets\\\\n+        id: secret-scan\\\\n+        shell: bash\\\\n+        run: |\\\\n+          set +e\\\\n+          base_sha=\\\\\\\"${{ github.event.pull_request.base.sha }}\\\\\\\"\\\\n+          head_sha=\\\\\\\"${{ github.event.pull_request.head.sha }}\\\\\\\"\\\\n+\\\\n+          if ! git diff --name-only --diff-filter=ACMRT \\\\\\\"$base_sha\\\\\\\" \\\\\\\"$head_sha\\\\\\\" \\\\u003e changed-files.txt 2\\\\u003e changed-files-error.log; then\\\\n+            echo \\\\\\\"git diff failed; scanning all tracked files instead.\\\\\\\" \\\\u003e\\\\u003e changed-files-error.log\\\\n+            git ls-files \\\\u003e changed-files.txt\\\\n+          fi\\\\n+\\\\n+          node \\\\u003c\\\\u003c'NODE'\\\\n+          const fs = require('fs');\\\\n+          const path = require('path');\\\\n+\\\\n+          const changedFilesPath = 'changed-files.txt';\\\\n+          const changedFiles = fs.existsSync(changedFilesPath)\\\\n+            ? fs.readFileSync(changedFilesPath, 'utf8').split(/\\\\\\\\r?\\\\\\\\n/).filter(Boolean)\\\\n+            : [];\\\\n+\\\\n+          const secretPatterns = [\\\\n+            { name: 'AWS access key', regex: /\\\\\\\\bAKIA[0-9A-Z]{16}\\\\\\\\b/ },\\\\n+            { name: 'Private key material', regex: /-----BEGIN (?:RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----/ },\\\\n+            { name: 'Bearer token', regex: /\\\\\\\\bBearer\\\\\\\\s+[A-Za-z0-9._~+/=-]{20,}/i },\\\\n+            { name: 'Generic credential assignment', regex: /(?:api[_-]?key|secret|password|token)\\\\\\\\s*[:=]\\\\\\\\s*['\\\\\\\"]?[A-Za-z0-9_./+=-]{20,}['\\\\\\\"]?/i }\\\\n+          ];\\\\n+\\\\n+          const allowlistFragments = [\\\\n+            'secrets.',\\\\n+            'github.token',\\\\n+            'process.env.',\\\\n+            'example',\\\\n+            'placeholder',\\\\n+            'YOUR_',\\\\n+            'your-'\\\\n+          ];\\\\n+\\\\n+          const findings = [];\\\\n+\\\\n+          for (const changedFile of changedFiles) {\\\\n+            const normalizedPath = path.normalize(changedFile);\\\\n+\\\\n+            if (!fs.existsSync(normalizedPath) || fs.statSync(normalizedPath).isDirectory()) {\\\\n+              continue;\\\\n+            }\\\\n+\\\\n+            const fileStats = fs.statSync(normalizedPath);\\\\n+            if (fileStats.size \\\\u003e 1024 * 1024) {\\\\n+              continue;\\\\n+            }\\\\n+\\\\n+            const fileBuffer = fs.readFileSync(normalizedPath);\\\\n+            if (fileBuffer.includes(0)) {\\\\n+              continue;\\\\n+            }\\\\n+\\\\n+            const fileLines = fileBuffer.toString('utf8').split(/\\\\\\\\r?\\\\\\\\n/);\\\\n+            fileLines.forEach((lineContent, lineIndex) =\\\\u003e {\\\\n+              const shouldSkip = allowlistFragments.some(fragment =\\\\u003e lineContent.includes(fragment));\\\\n+              if (shouldSkip) {\\\\n+                return;\\\\n+              }\\\\n+\\\\n+              for (const secretPattern of secretPatterns) {\\\\n+                if (secretPattern.regex.test(lineContent)) {\\\\n+                  findings.push(`${changedFile}:${lineIndex + 1} ${secretPattern.name}`);\\\\n+                }\\\\n+              }\\\\n+            });\\\\n+          }\\\\n+\\\\n+          fs.writeFileSync('secret-scan-results.txt', findings.join('\\\\\\\\n') + (findings.length \\\\u003e 0 ? '\\\\\\\\n' : ''));\\\\n+          NODE\\\\n+\\\\n+          secret_count=$(wc -l \\\\u003c secret-scan-results.txt | tr -d ' ')\\\\n+          echo \\\\\\\"secret_count=$secret_count\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+\\\\n+          if [ \\\\\\\"$secret_count\\\\\\\" -gt 0 ]; then\\\\n+            echo \\\\\\\"status=failed\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+            echo \\\\\\\"::error::Potential secrets were detected in changed files.\\\\\\\"\\\\n+          else\\\\n+            echo \\\\\\\"status=passed\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+            echo \\\\\\\"No secrets detected in changed files.\\\\\\\"\\\\n+          fi\\\\n+\\\\n+          exit 0\\\\n+\\\\n+      - name: Post Security Scan Report PR comment\\\\n+        if: ${{ always() \\\\u0026\\\\u0026 github.event_name == 'pull_request' }}\\\\n+        uses: actions/github-script@v7\\\\n+        continue-on-error: true\\\\n+        with:\\\\n+          script: |\\\\n+            const fs = require('fs');\\\\n+\\\\n+            const securityMarker = '\\\\u003c!-- pr-automation:security-scan --\\\\u003e';\\\\n+            const securityOwner = context.repo.owner;\\\\n+            const securityRepo = context.repo.repo;\\\\n+            const securityIssueNumber = context.issue.number;\\\\n+            const securityRunUrl = `https://github.com/${securityOwner}/${securityRepo}/actions/runs/${context.runId}`;\\\\n+\\\\n+            const readSecurityFile = (filePath, fallbackText) =\\\\u003e {\\\\n+              try {\\\\n+                const fileContent = fs.readFileSync(filePath, 'utf8').trim();\\\\n+                return fileContent || fallbackText;\\\\n+              } catch (securityReadError) {\\\\n+                return fallbackText;\\\\n+              }\\\\n+            };\\\\n+\\\\n+            const auditStatus = '${{ steps.audit.outputs.status }}' || 'unknown';\\\\n+            const secretStatus = '${{ steps.secret-scan.outputs.status }}' || 'unknown';\\\\n+            const auditSummary = readSecurityFile('audit-summary.md', 'Dependency audit summary is unavailable.');\\\\n+            const secretFindings = readSecurityFile('secret-scan-results.txt', 'No potential secrets detected in changed files.');\\\\n+            const auditError = readSecurityFile('npm-audit-error.log', 'No npm audit stderr output.');\\\\n+\\\\n+            const securityBody = [\\\\n+              securityMarker,\\\\n+              '## Security Scan Report',\\\\n+              '',\\\\n+              `- Dependencies audit status: **${auditStatus}**`,\\\\n+              `- Secret scan status: **${secretStatus}**`,\\\\n+              `- Workflow run: ${securityRunUrl}`,\\\\n+              '',\\\\n+              '### Dependencies and Vulnerabilities',\\\\n+              '',\\\\n+              auditSummary,\\\\n+              '',\\\\n+              '### Changed-file secret scan',\\\\n+              '',\\\\n+              '```text',\\\\n+              secretFindings,\\\\n+              '```',\\\\n+              '',\\\\n+              '\\\\u003cdetails\\\\u003e\\\\u003csummary\\\\u003enpm audit stderr\\\\u003c/summary\\\\u003e',\\\\n+              '',\\\\n+              '```text',\\\\n+              auditError.slice(-4000),\\\\n+              '```',\\\\n+              '\\\\u003c/details\\\\u003e'\\\\n+            ].join('\\\\\\\\n');\\\\n+\\\\n+            const securityComments = await github.rest.issues.listComments({\\\\n+              owner: securityOwner,\\\\n+              repo: securityRepo,\\\\n+              issue_number: securityIssueNumber,\\\\n+              per_page: 100\\\\n+            });\\\\n+\\\\n+            const previousSecurityComment = securityComments.data.find(commentItem =\\\\u003e\\\\n+              commentItem.body \\\\u0026\\\\u0026 commentItem.body.includes(securityMarker)\\\\n+            );\\\\n+\\\\n+            if (previousSecurityComment) {\\\\n+              await github.rest.issues.updateComment({\\\\n+                owner: securityOwner,\\\\n+                repo: securityRepo,\\\\n+                comment_id: previousSecurityComment.id,\\\\n+                body: securityBody\\\\n+              });\\\\n+            } else {\\\\n+              await github.rest.issues.createComment({\\\\n+                owner: securityOwner,\\\\n+                repo: securityRepo,\\\\n+                issue_number: securityIssueNumber,\\\\n+                body: securityBody\\\\n+              });\\\\n+            }\\\\n+\\\\n+      - name: Enforce security gate\\\\n+        if: ${{ steps.secret-scan.outputs.secret_count != '0' || steps.audit.outputs.critical_count != '0' }}\\\\n+        run: |\\\\n+          echo \\\\\\\"::error::Security gate failed because critical vulnerabilities or potential secrets were found.\\\\\\\"\\\\n+          exit 1\\\\n+\\\\n+  build-validation:\\\\n+    name: build-validation\\\\n+    runs-on: ubuntu-latest\\\\n+    timeout-minutes: 20\\\\n+\\\\n+    steps:\\\\n+      - name: Checkout repository\\\\n+        uses: actions/checkout@v4\\\\n+\\\\n+      - name: Setup Node.js\\\\n+        uses: actions/setup-node@v4\\\\n+        with:\\\\n+          node-version: ${{ env.NODE_VERSION }}\\\\n+          cache: npm\\\\n+\\\\n+      - name: Install dependencies\\\\n+        run: npm ci\\\\n+\\\\n+      - name: Build application\\\\n+        id: build\\\\n+        shell: bash\\\\n+        run: |\\\\n+          set +e\\\\n+          npm run build \\\\u003e build-output.log 2\\\\u003e\\\\u00261\\\\n+          build_exit=$?\\\\n+\\\\n+          if [ \\\\\\\"$build_exit\\\\\\\" -eq 0 ]; then\\\\n+            echo \\\\\\\"status=passed\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+            echo \\\\\\\"Build completed successfully.\\\\\\\"\\\\n+          else\\\\n+            echo \\\\\\\"status=failed\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+            echo \\\\\\\"::error::Build failed. See build-output.log for details.\\\\\\\"\\\\n+          fi\\\\n+\\\\n+          echo \\\\\\\"exit_code=$build_exit\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+          exit 0\\\\n+\\\\n+      - name: Validate application endpoints\\\\n+        id: endpoints\\\\n+        shell: bash\\\\n+        run: |\\\\n+          set +e\\\\n+          mkdir -p build-validation\\\\n+          : \\\\u003e build-validation/endpoint-validation.log\\\\n+\\\\n+          PORT=3000 npm start \\\\u003e build-validation/server.log 2\\\\u003e\\\\u00261 \\\\u0026\\\\n+          server_pid=$!\\\\n+\\\\n+          cleanup() {\\\\n+            if ps -p \\\\\\\"$server_pid\\\\\\\" \\\\u003e /dev/null 2\\\\u003e\\\\u00261; then\\\\n+              kill \\\\\\\"$server_pid\\\\\\\" \\\\u003e /dev/null 2\\\\u003e\\\\u00261 || true\\\\n+              wait \\\\\\\"$server_pid\\\\\\\" 2\\\\u003e /dev/null || true\\\\n+            fi\\\\n+          }\\\\n+          trap cleanup EXIT\\\\n+\\\\n+          ready=false\\\\n+          for attempt in {1..30}; do\\\\n+            if curl -fsS --max-time 5 http://localhost:3000/health \\\\u003e build-validation/health.json 2\\\\u003e\\\\u003e build-validation/endpoint-validation.log; then\\\\n+              ready=true\\\\n+              break\\\\n+            fi\\\\n+            echo \\\\\\\"Waiting for application readiness... attempt $attempt\\\\\\\" \\\\u003e\\\\u003e build-validation/endpoint-validation.log\\\\n+            sleep 1\\\\n+          done\\\\n+\\\\n+          validation_exit=0\\\\n+\\\\n+          validate_endpoint() {\\\\n+            local label=\\\\\\\"$1\\\\\\\"\\\\n+            local method=\\\\\\\"$2\\\\\\\"\\\\n+            local url=\\\\\\\"$3\\\\\\\"\\\\n+            local data=\\\\\\\"${4:-}\\\\\\\"\\\\n+            local output_file=\\\\\\\"build-validation/${label}.json\\\\\\\"\\\\n+\\\\n+            echo \\\\\\\"Validating $method $url\\\\\\\" \\\\u003e\\\\u003e build-validation/endpoint-validation.log\\\\n+            if [ \\\\\\\"$method\\\\\\\" = \\\\\\\"POST\\\\\\\" ]; then\\\\n+              curl -fsS --max-time 5 -X POST -H \\\\\\\"Content-Type: application/json\\\\\\\" -d \\\\\\\"$data\\\\\\\" \\\\\\\"$url\\\\\\\" \\\\u003e \\\\\\\"$output_file\\\\\\\" 2\\\\u003e\\\\u003e build-validation/endpoint-validation.log\\\\n+            else\\\\n+              curl -fsS --max-time 5 \\\\\\\"$url\\\\\\\" \\\\u003e \\\\\\\"$output_file\\\\\\\" 2\\\\u003e\\\\u003e build-validation/endpoint-validation.log\\\\n+            fi\\\\n+          }\\\\n+\\\\n+          if [ \\\\\\\"$ready\\\\\\\" != \\\\\\\"true\\\\\\\" ]; then\\\\n+            echo \\\\\\\"Application did not become ready within the timeout.\\\\\\\" \\\\u003e\\\\u003e build-validation/endpoint-validation.log\\\\n+            validation_exit=1\\\\n+          else\\\\n+            validate_endpoint \\\\\\\"root\\\\\\\" \\\\\\\"GET\\\\\\\" \\\\\\\"http://localhost:3000/\\\\\\\" || validation_exit=1\\\\n+            validate_endpoint \\\\\\\"health\\\\\\\" \\\\\\\"GET\\\\\\\" \\\\\\\"http://localhost:3000/health\\\\\\\" || validation_exit=1\\\\n+            validate_endpoint \\\\\\\"users\\\\\\\" \\\\\\\"GET\\\\\\\" \\\\\\\"http://localhost:3000/users\\\\\\\" || validation_exit=1\\\\n+            validate_endpoint \\\\\\\"deployment-status\\\\\\\" \\\\\\\"GET\\\\\\\" \\\\\\\"http://localhost:3000/status/deployment\\\\\\\" || validation_exit=1\\\\n+            validate_endpoint \\\\\\\"calculate\\\\\\\" \\\\\\\"POST\\\\\\\" \\\\\\\"http://localhost:3000/calculate\\\\\\\" '{\\\\\\\"operation\\\\\\\":\\\\\\\"add\\\\\\\",\\\\\\\"a\\\\\\\":2,\\\\\\\"b\\\\\\\":3}' || validation_exit=1\\\\n+          fi\\\\n+\\\\n+          if [ \\\\\\\"$validation_exit\\\\\\\" -eq 0 ]; then\\\\n+            echo \\\\\\\"status=passed\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+            echo \\\\\\\"Endpoint validation completed successfully.\\\\\\\"\\\\n+          else\\\\n+            echo \\\\\\\"status=failed\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+            echo \\\\\\\"::error::Endpoint validation failed. See build-validation/endpoint-validation.log for details.\\\\\\\"\\\\n+          fi\\\\n+\\\\n+          echo \\\\\\\"exit_code=$validation_exit\\\\\\\" \\\\u003e\\\\u003e \\\\\\\"$GITHUB_OUTPUT\\\\\\\"\\\\n+          exit 0\\\\n+\\\\n+      - name: Create deployment preview artifacts\\\\n+        if: ${{ always() }}\\\\n+        shell: bash\\\\n+        env:\\\\n+          PR_NUMBER: ${{ github.event.pull_request.number }}\\\\n+        run: |\\\\n+          mkdir -p deployment-preview\\\\n+\\\\n+          cat \\\\u003e deployment-preview/README.md \\\\u003c\\\\u003c'EOF'\\\\n+          # Deployment Preview\\\\n+\\\\n+          This artifact contains build validation evidence for the pull request.\\\\n+          It includes endpoint responses, server logs, and a generated preview manifest.\\\\n+          EOF\\\\n+\\\\n+          node \\\\u003c\\\\u003c'NODE'\\\\n+          const fs = require('fs');\\\\n+\\\\n+          const previewManifest = {\\\\n+            repository: process.env.GITHUB_REPOSITORY,\\\\n+            pull_request: process.env.PR_NUMBER,\\\\n+            run_id: process.env.GITHUB_RUN_ID,\\\\n+            generated_at: new Date().toISOString(),\\\\n+            validated_endpoints: [\\\\n+              'GET /',\\\\n+              'GET /health',\\\\n+              'GET /users',\\\\n+              'GET /status/deployment',\\\\n+              'POST /calculate'\\\\n+            ]\\\\n+          };\\\\n+\\\\n+          fs.writeFileSync('deployment-preview/preview-manifest.json', `${JSON.stringify(previewManifest, null, 2)}\\\\\\\\n`);\\\\n+          NODE\\\\n+\\\\n+          cp build-output.log deployment-preview/build-output.log 2\\\\u003e /dev/null || true\\\\n+          cp -R build-validation deployment-preview/build-validation 2\\\\u003e /dev/null || true\\\\n+\\\\n+      - name: Upload deployment preview artifacts\\\\n+        if: ${{ always() }}\\\\n+        uses: actions/upload-artifact@v4\\\\n+        with:\\\\n+          name: deployment-preview-${{ github.event.pull_request.number }}\\\\n+          path: deployment-preview/\\\\n+          if-no-files-found: error\\\\n+          retention-days: 14\\\\n+\\\\n+      - name: Post Build Validation PR comment\\\\n+        if: ${{ always() \\\\u0026\\\\u0026 github.event_name == 'pull_request' }}\\\\n+        uses: actions/github-script@v7\\\\n+        continue-on-error: true\\\\n+        with:\\\\n+          script: |\\\\n+            const fs = require('fs');\\\\n+\\\\n+            const buildMarker = '\\\\u003c!-- pr-automation:build-validation --\\\\u003e';\\\\n+            const buildOwner = context.repo.owner;\\\\n+            const buildRepo = context.repo.repo;\\\\n+            const buildIssueNumber = context.issue.number;\\\\n+            const buildRunUrl = `https://github.com/${buildOwner}/${buildRepo}/actions/runs/${context.runId}`;\\\\n+\\\\n+            const readBuildLog = (filePath, fallbackText) =\\\\u003e {\\\\n+              try {\\\\n+                const fileContent = fs.readFileSync(filePath, 'utf8').trim();\\\\n+                return fileContent ? fileContent.slice(-4000) : fallbackText;\\\\n+              } catch (buildReadError) {\\\\n+                return fallbackText;\\\\n+              }\\\\n+            };\\\\n+\\\\n+            const buildStatus = '${{ steps.build.outputs.status }}' || 'unknown';\\\\n+            const endpointStatus = '${{ steps.endpoints.outputs.status }}' || 'unknown';\\\\n+            const buildLog = readBuildLog('build-output.log', 'Build output is unavailable.');\\\\n+            const endpointLog = readBuildLog('build-validation/endpoint-validation.log', 'Endpoint validation output is unavailable.');\\\\n+\\\\n+            const buildBody = [\\\\n+              buildMarker,\\\\n+              '## Build Validation',\\\\n+              '',\\\\n+              `- Build status: **${buildStatus}**`,\\\\n+              `- Endpoint validation status: **${endpointStatus}**`,\\\\n+              `- Deployment preview artifact: deployment-preview-${{ github.event.pull_request.number }}`,\\\\n+              `- Workflow run: ${buildRunUrl}`,\\\\n+              '',\\\\n+              '\\\\u003cdetails\\\\u003e\\\\u003csummary\\\\u003eBuild output\\\\u003c/summary\\\\u003e',\\\\n+              '',\\\\n+              '```text',\\\\n+              buildLog,\\\\n+              '```',\\\\n+              '\\\\u003c/details\\\\u003e',\\\\n+              '',\\\\n+              '\\\\u003cdetails\\\\u003e\\\\u003csummary\\\\u003eEndpoint validation output\\\\u003c/summary\\\\u003e',\\\\n+              '',\\\\n+              '```text',\\\\n+              endpointLog,\\\\n+              '```',\\\\n+              '\\\\u003c/details\\\\u003e'\\\\n+            ].join('\\\\\\\\n');\\\\n+\\\\n+            const buildComments = await github.rest.issues.listComments({\\\\n+              owner: buildOwner,\\\\n+              repo: buildRepo,\\\\n+              issue_number: buildIssueNumber,\\\\n+              per_page: 100\\\\n+            });\\\\n+\\\\n+            const previousBuildComment = buildComments.data.find(commentItem =\\\\u003e\\\\n+              commentItem.body \\\\u0026\\\\u0026 commentItem.body.includes(buildMarker)\\\\n+            );\\\\n+\\\\n+            if (previousBuildComment) {\\\\n+              await github.rest.issues.updateComment({\\\\n+                owner: buildOwner,\\\\n+                repo: buildRepo,\\\\n+                comment_id: previousBuildComment.id,\\\\n+                body: buildBody\\\\n+              });\\\\n+            } else {\\\\n+              await github.rest.issues.createComment({\\\\n+                owner: buildOwner,\\\\n+                repo: buildRepo,\\\\n+                issue_number: buildIssueNumber,\\\\n+                body: buildBody\\\\n+              });\\\\n+            }\\\\n+\\\\n+      - name: Enforce build validation gate\\\\n+        if: ${{ steps.build.outputs.exit_code != '0' || steps.endpoints.outputs.exit_code != '0' }}\\\\n+        run: |\\\\n+          echo \\\\\\\"::error::Build validation failed. Review the Build Validation comment for details.\\\\\\\"\\\\n+          exit 1\\\",\\\"blob_url\\\":\\\"https://github.com/mangowhoiscloud/mcpmark-cicd/blob/33e63ee1524df2c67b0306dd3b2ab20d0ed22f84/.github%2Fworkflows%2Fpr-automation.yml\\\",\\\"raw_url\\\":\\\"https://github.com/mangowhoiscloud/mcpmark-cicd/raw/33e63ee1524df2c67b0306dd3b2ab20d0ed22f84/.github%2Fworkflows%2Fpr-automation.yml\\\",\\\"contents_url\\\":\\\"https://api.github.com/repos/mangowhoiscloud/mcpmark-cicd/contents/.github%2Fworkflows%2Fpr-automation.yml?ref=33e63ee1524df2c67b0306dd3b2ab20d0ed22f84\\\"}]\", \"annotations\": null, \"meta\": null}], \"structuredContent\": null, \"isError\": false}"
