    "tool": "execute_sql",
    "input": {
      "sql": "BEGIN;\n\nCREATE TABLE employees.employee_projects (\n    project_id INTEGER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,\n    project_name VARCHAR(100) NOT NULL,\n    start_date DATE NOT NULL,\n    end_date DATE,\n    budget DECIMAL(10,2),\n    status VARCHAR(20) DEFAULT 'active'\n);\n\nCREATE TABLE employees.project_assignments (\n    assignment_id INTEGER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,\n    employee_id BIGINT NOT NULL,\n    project_id INTEGER NOT NULL,\n    role VARCHAR(50) NOT NULL,\n    allocation_percentage INTEGER CHECK (allocation_percentage BETWEEN 1 AND 100),\n    assigned_date DATE NOT NULL,\n    CONSTRAINT fk_project_assignments_employee\n        FOREIGN KEY (employee_id) REFERENCES employees.employee(id),\n    CONSTRAINT fk_project_assignments_project\n        FOREIGN KEY (project_id) REFERENCES employees.employee_projects(project_id)\n);\n\nCREATE TABLE employees.project_milestones (\n    milestone_id INTEGER GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,\n    project_id INTEGER NOT NULL,\n    milestone_name VARCHAR(100) NOT NULL,\n    due_date DATE NOT NULL,\n    completed BOOLEAN DEFAULT false,\n    CONSTRAINT fk_project_milestones_project\n        FOREIGN KEY (project_id) REFERENCES employees.employee_projects(project_id)\n);\n\nCREATE INDEX idx_projects_status\n    ON employees.employee_projects(status);\nCREATE INDEX idx_assignments_emp_proj\n    ON employees.project_assignments(employee_id, project_id);\nCREATE INDEX idx_milestones_due_date\n    ON employees.project_milestones(due_date);\n\nINSERT INTO employees.employee_projects\n    (project_id, project_name, start_date, end_date, budget, status)\nVALUES\n    (1, 'Database Modernization', '2024-01-15', '2024-06-30', 250000.00, 'active'),\n    (2, 'Employee Portal Upgrade', '2024-02-01', '2024-05-15', 180000.00, 'active'),\n    (3, 'HR Analytics Dashboard', '2023-11-01', '2024-01-31', 120000.00, 'active');\n\nSELECT setval(\n    pg_get_serial_sequence('employees.employee_projects', 'project_id'),\n    (SELECT MAX(project_id) FROM employees.employee_projects)\n);\n\nINSERT INTO employees.project_assignments\n    (employee_id, project_id, role, allocation_percentage, assigned_date)\nSELECT\n    de.employee_id,\n    CASE d.dept_name\n        WHEN 'Development' THEN 1\n        WHEN 'Human Resources' THEN 2\n        WHEN 'Marketing' THEN 3\n        WHEN 'Finance' THEN 1\n        WHEN 'Sales' THEN 2\n        WHEN 'Research' THEN 3\n        WHEN 'Production' THEN 1\n        WHEN 'Quality Management' THEN 2\n        WHEN 'Customer Service' THEN 3\n    END AS project_id,\n    CASE d.dept_name\n        WHEN 'Development' THEN 'Developer'\n        WHEN 'Human Resources' THEN 'Business Analyst'\n        WHEN 'Marketing' THEN 'Marketing Specialist'\n        WHEN 'Finance' THEN 'Financial Analyst'\n        WHEN 'Sales' THEN 'Sales Representative'\n        WHEN 'Research' THEN 'Research Analyst'\n        WHEN 'Production' THEN 'Production Coordinator'\n        WHEN 'Quality Management' THEN 'QA Specialist'\n        WHEN 'Customer Service' THEN 'Customer Success'\n    END AS role,\n    CASE d.dept_name\n        WHEN 'Development' THEN 80\n        WHEN 'Human Resources' THEN 60\n        WHEN 'Marketing' THEN 40\n        WHEN 'Finance' THEN 30\n        WHEN 'Sales' THEN 50\n        WHEN 'Research' THEN 70\n        WHEN 'Production' THEN 45\n        WHEN 'Quality Management' THEN 85\n        WHEN 'Customer Service' THEN 35\n    END AS allocation_percentage,\n    DATE '2024-01-01' AS assigned_date\nFROM employees.department_employee de\nJOIN employees.department d\n    ON d.id = de.department_id\nWHERE de.to_date = DATE '9999-01-01'\n  AND d.dept_name IN (\n      'Development', 'Human Resources', 'Marketing', 'Finance', 'Sales',\n      'Research', 'Production', 'Quality Management', 'Customer Service'\n  );\n\nINSERT INTO employees.project_milestones\n    (project_id, milestone_name, due_date)\nVALUES\n    (1, 'Design Phase Complete', '2024-03-01'),\n    (1, 'Implementation Complete', '2024-05-15'),\n    (2, 'UI/UX Approval', '2024-03-15'),\n    (2, 'Beta Testing', '2024-04-30'),\n    (3, 'Data Collection', '2023-12-15'),\n    (3, 'Dashboard Launch', '2024-01-25');\n\nUPDATE employees.employee_projects\nSET status = 'completed'\nWHERE project_name = 'HR Analytics Dashboard';\n\nUPDATE employees.employee_projects\nSET budget = budget * 1.15\nWHERE status = 'active';\n\nUPDATE employees.project_milestones\nSET completed = true\nWHERE milestone_name = 'Data Collection';\n\nALTER TABLE employees.employee_projects\n    ADD COLUMN priority VARCHAR(10),\n    ADD CONSTRAINT chk_employee_projects_priority\n        CHECK (priority IN ('low', 'medium', 'high'));\n\nUPDATE employees.employee_projects\nSET priority = CASE\n    WHEN project_name = 'Database Modernization' THEN 'high'\n    ELSE 'medium'\nEND;\n\nCOMMIT;\n\nSELECT\n    (SELECT COUNT(*) FROM employees.employee_projects) AS project_count,\n    (SELECT COUNT(*) FROM employees.project_assignments) AS assignment_count,\n    (SELECT COUNT(*) FROM employees.project_milestones) AS milestone_count,\n    (SELECT json_agg(projects ORDER BY project_id)\n     FROM (\n         SELECT project_id, project_name, status, budget, priority\n         FROM employees.employee_projects\n         ORDER BY project_id\n     ) projects) AS projects,\n    (SELECT json_agg(milestones ORDER BY milestone_id)\n     FROM (\n         SELECT milestone_id, project_id, milestone_name, due_date, completed\n         FROM employees.project_milestones\n         ORDER BY milestone_id\n     ) milestones) AS milestones;"
    },
