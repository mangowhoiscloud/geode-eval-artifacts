      "result": "{\"meta\": null, \"content\": [{\"type\": \"text\", \"text\": \"[{'project_count': 3, 'assignment_count': 240124, 'milestone_count': 6, 'projects': [{'project_id': 1, 'project_name': 'Database Modernization', 'status': 'active', 'budget': 287500.0, 'priority': 'high'}, {'project_id': 2, 'project_name': 'Employee Portal Upgrade', 'status': 'active', 'budget': 207000.0, 'priority': 'medium'}, {'project_id': 3, 'project_name': 'HR Analytics Dashboard', 'status': 'completed', 'budget': 120000.0, 'priority': 'medium'}], 'milestones': [{'milestone_id': 1, 'project_id': 1, 'milestone_name': 'Design Phase Complete', 'due_date': '2024-03-01', 'completed': False}, {'milestone_id': 2, 'project_id': 1, 'milestone_name': 'Implementation Complete', 'due_date': '2024-05-15', 'completed': False}, {'milestone_id': 3, 'project_id': 2, 'milestone_name': 'UI/UX Approval', 'due_date': '2024-03-15', 'completed': False}, {'milestone_id': 4, 'project_id': 2, 'milestone_name': 'Beta Testing', 'due_date': '2024-04-30', 'completed': False}, {'milestone_id': 5, 'project_id': 3, 'milestone_name': 'Data Collection', 'due_date': '2023-12-15', 'completed': True}, {'milestone_id': 6, 'project_id': 3, 'milestone_name': 'Dashboard Launch', 'due_date': '2024-01-25', 'completed': False}]}]\", \"annotations\": null, \"meta\": null}], \"structuredContent\": {\"result\": [{\"type\": \"text\", \"text\": \"[{'project_count': 3, 'assignment_count': 240124, 'milestone_count': 6, 'projects': [{'project_id': 1, 'project_name': 'Database Modernization', 'status': 'active', 'budget': 287500.0, 'priority': 'high'}, {'project_id': 2, 'project_name': 'Employee Portal Upgrade', 'status': 'active', 'budget': 207000.0, 'priority': 'medium'}, {'project_id': 3, 'project_name': 'HR Analytics Dashboard', 'status': 'completed', 'budget': 120000.0, 'priority': 'medium'}], 'milestones': [{'milestone_id': 1, 'project_id': 1, 'milestone_name': 'Design Phase Complete', 'due_date': '2024-03-01', 'completed': False}, {'milestone_id': 2, 'project_id': 1, 'milestone_name': 'Implementation Complete', 'due_date': '2024-05-15', 'completed': False}, {'milestone_id': 3, 'project_id': 2, 'milestone_name': 'UI/UX Approval', 'due_date': '2024-03-15', 'completed': False}, {'milestone_id': 4, 'project_id': 2, 'milestone_name': 'Beta Testing', 'due_date': '2024-04-30', 'completed': False}, {'milestone_id': 5, 'project_id': 3, 'milestone_name': 'Data Collection', 'due_date': '2023-12-15', 'completed': True}, {'milestone_id': 6, 'project_id': 3, 'milestone_name': 'Dashboard Launch', 'due_date': '2024-01-25', 'completed': False}]}]\", \"annotations\": null, \"_meta\": null}]}, \"isError\": false}"
