    "input": {
      "sql": "WITH vector_cols AS (\n    SELECT n.nspname AS schema_name, c.relname AS table_name, c.oid AS table_oid,\n           a.attname AS column_name, a.attnum, t.typname AS base_type,\n           format_type(a.atttypid, a.atttypmod) AS formatted_type,\n           CASE WHEN a.atttypmod > 0 THEN a.atttypmod ELSE NULL END AS dimensions\n    FROM pg_attribute a\n    JOIN pg_class c ON c.oid = a.attrelid\n    JOIN pg_namespace n ON n.oid = c.relnamespace\n    JOIN pg_type t ON t.oid = a.atttypid\n    WHERE a.attnum > 0 AND NOT a.attisdropped\n      AND c.relkind IN ('r','p')\n      AND n.nspname NOT IN ('pg_catalog','information_schema')\n      AND t.typname IN ('vector','halfvec','sparsevec')\n), vector_indexes AS (\n    SELECT tn.nspname AS schema_name, tbl.relname AS table_name, tbl.oid AS table_oid,\n           att.attname AS column_name, ind.relname AS index_name, ind.oid AS index_oid,\n           am.amname AS index_type, pg_relation_size(ind.oid) AS index_size_bytes,\n           pg_get_indexdef(ind.oid) AS indexdef,\n           ind.reloptions AS reloptions,\n           opc.opcname AS opclass,\n           COALESCE(s.idx_scan,0) AS idx_scan,\n           COALESCE(s.idx_tup_read,0) AS idx_tup_read,\n           COALESCE(s.idx_tup_fetch,0) AS idx_tup_fetch\n    FROM pg_index idx\n    JOIN pg_class ind ON ind.oid = idx.indexrelid\n    JOIN pg_class tbl ON tbl.oid = idx.indrelid\n    JOIN pg_namespace tn ON tn.oid = tbl.relnamespace\n    JOIN pg_am am ON am.oid = ind.relam\n    JOIN unnest(idx.indkey) WITH ORDINALITY AS k(attnum, ord) ON true\n    LEFT JOIN pg_attribute att ON att.attrelid = tbl.oid AND att.attnum = k.attnum\n    LEFT JOIN unnest(idx.indclass) WITH ORDINALITY AS ic(opc_oid, ord) ON ic.ord = k.ord\n    LEFT JOIN pg_opclass opc ON opc.oid = ic.opc_oid\n    LEFT JOIN pg_stat_user_indexes s ON s.indexrelid = ind.oid\n    WHERE tn.nspname NOT IN ('pg_catalog','information_schema')\n      AND am.amname IN ('hnsw','ivfflat')\n), table_rels AS (\n    SELECT tc.table_schema, tc.table_name, kcu.column_name,\n           ccu.table_schema AS foreign_table_schema,\n           ccu.table_name AS foreign_table_name,\n           ccu.column_name AS foreign_column_name,\n           tc.constraint_name\n    FROM information_schema.table_constraints tc\n    JOIN information_schema.key_column_usage kcu\n      ON tc.constraint_name = kcu.constraint_name\n     AND tc.table_schema = kcu.table_schema\n    LEFT JOIN information_schema.constraint_column_usage ccu\n      ON ccu.constraint_name = tc.constraint_name\n     AND ccu.table_schema = tc.table_schema\n    WHERE tc.constraint_type = 'FOREIGN KEY'\n      AND tc.table_schema NOT IN ('pg_catalog','information_schema')\n), table_stats AS (\n    SELECT schemaname AS schema_name, relname AS table_name,\n           n_live_tup, n_dead_tup, seq_scan, idx_scan,\n           n_tup_ins, n_tup_upd, n_tup_del, last_vacuum, last_autovacuum, last_analyze, last_autoanalyze\n    FROM pg_stat_user_tables\n), ext AS (\n    SELECT e.extname, e.extversion, n.nspname AS extension_schema, e.extrelocatable,\n           obj_description(e.oid, 'pg_extension') AS description\n    FROM pg_extension e JOIN pg_namespace n ON n.oid = e.extnamespace\n    WHERE e.extname = 'vector'\n)\nSELECT jsonb_pretty(jsonb_build_object(\n    'extension', (SELECT jsonb_agg(to_jsonb(ext)) FROM ext),\n    'analysis_columns', (SELECT jsonb_agg(to_jsonb(vac) ORDER BY schema, table_name, column_name) FROM vector_analysis_columns vac),\n    'storage_consumption', (SELECT jsonb_agg(to_jsonb(vs) ORDER BY total_size_bytes DESC) FROM vector_analysis_storage_consumption vs),\n    'vector_indexes', (SELECT jsonb_agg(to_jsonb(vi) ORDER BY schema_name, table_name, index_name) FROM vector_indexes vi),\n    'missing_vector_indexes', (\n        SELECT COALESCE(jsonb_agg(to_jsonb(vc) ORDER BY schema_name, table_name, column_name), '[]'::jsonb)\n        FROM vector_cols vc\n        WHERE NOT EXISTS (\n            SELECT 1 FROM vector_indexes vi\n            WHERE vi.table_oid = vc.table_oid AND vi.column_name = vc.column_name\n        )\n    ),\n    'relationships_foreign_keys', (SELECT COALESCE(jsonb_agg(to_jsonb(tr) ORDER BY table_schema, table_name, column_name), '[]'::jsonb) FROM table_rels tr),\n    'vector_table_activity', (\n        SELECT jsonb_agg(to_jsonb(ts) ORDER BY schema_name, table_name)\n        FROM table_stats ts\n        WHERE EXISTS (SELECT 1 FROM vector_cols vc WHERE vc.schema_name=ts.schema_name AND vc.table_name=ts.table_name)\n    )\n)) AS report;"
    },
