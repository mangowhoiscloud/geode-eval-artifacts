  {
    "tool": "execute_sql",
    "input": {
      "sql": "DROP TABLE IF EXISTS vector_analysis_quality;\nCREATE TEMP TABLE vector_analysis_quality (\n    schema_name text,\n    table_name text,\n    column_name text,\n    declared_dimensions integer,\n    row_count bigint,\n    null_vectors bigint,\n    non_null_vectors bigint,\n    distinct_observed_dimensions bigint,\n    min_observed_dimensions integer,\n    max_observed_dimensions integer,\n    dimension_mismatch_count bigint,\n    zero_norm_count bigint,\n    non_finite_norm_count bigint,\n    min_norm double precision,\n    max_norm double precision,\n    avg_norm double precision,\n    stddev_norm double precision,\n    norm_outlier_count bigint,\n    avg_vector_bytes numeric\n);\n\nDO $$\nDECLARE\n    r RECORD;\nBEGIN\n    FOR r IN\n        SELECT \n            n.nspname AS schema_name,\n            c.relname AS table_name,\n            a.attname AS column_name,\n            CASE WHEN a.atttypmod > 0 THEN a.atttypmod ELSE NULL END AS declared_dimensions,\n            t.typname AS base_type\n        FROM pg_attribute a\n        JOIN pg_class c ON c.oid = a.attrelid\n        JOIN pg_namespace n ON n.oid = c.relnamespace\n        JOIN pg_type t ON t.oid = a.atttypid\n        WHERE a.attnum > 0\n          AND NOT a.attisdropped\n          AND c.relkind IN ('r','p')\n          AND n.nspname NOT IN ('pg_catalog','information_schema')\n          AND t.typname = 'vector'\n        ORDER BY n.nspname, c.relname, a.attnum\n    LOOP\n        EXECUTE format($fmt$\n            WITH vals AS (\n                SELECT \n                    %1$I AS v,\n                    vector_dims(%1$I) AS dims,\n                    vector_norm(%1$I) AS norm,\n                    pg_column_size(%1$I) AS bytes\n                FROM %2$I.%3$I\n            ), stats AS (\n                SELECT avg(norm) AS avg_norm, stddev_samp(norm) AS stddev_norm\n                FROM vals\n                WHERE v IS NOT NULL\n            )\n            INSERT INTO vector_analysis_quality\n            SELECT\n                %4$L,\n                %5$L,\n                %6$L,\n                %7$s::integer,\n                count(*)::bigint AS row_count,\n                count(*) FILTER (WHERE v IS NULL)::bigint AS null_vectors,\n                count(*) FILTER (WHERE v IS NOT NULL)::bigint AS non_null_vectors,\n                count(DISTINCT dims) FILTER (WHERE v IS NOT NULL)::bigint AS distinct_observed_dimensions,\n                min(dims) FILTER (WHERE v IS NOT NULL)::integer AS min_observed_dimensions,\n                max(dims) FILTER (WHERE v IS NOT NULL)::integer AS max_observed_dimensions,\n                count(*) FILTER (WHERE v IS NOT NULL AND %7$s::integer IS NOT NULL AND dims <> %7$s::integer)::bigint AS dimension_mismatch_count,\n                count(*) FILTER (WHERE v IS NOT NULL AND norm = 0)::bigint AS zero_norm_count,\n                count(*) FILTER (WHERE v IS NOT NULL AND norm::text IN ('NaN','Infinity','-Infinity'))::bigint AS non_finite_norm_count,\n                min(norm) FILTER (WHERE v IS NOT NULL) AS min_norm,\n                max(norm) FILTER (WHERE v IS NOT NULL) AS max_norm,\n                avg(norm) FILTER (WHERE v IS NOT NULL) AS avg_norm,\n                stddev_samp(norm) FILTER (WHERE v IS NOT NULL) AS stddev_norm,\n                count(*) FILTER (\n                    WHERE v IS NOT NULL \n                      AND (SELECT stddev_norm FROM stats) IS NOT NULL\n                      AND (SELECT stddev_norm FROM stats) > 0\n                      AND abs(norm - (SELECT avg_norm FROM stats)) > 3 * (SELECT stddev_norm FROM stats)\n                )::bigint AS norm_outlier_count,\n                avg(bytes) FILTER (WHERE v IS NOT NULL)::numeric AS avg_vector_bytes\n            FROM vals\n        $fmt$,\n        r.column_name,\n        r.schema_name,\n        r.table_name,\n        r.schema_name,\n        r.table_name,\n        r.column_name,\n        COALESCE(r.declared_dimensions::text, 'NULL'));\n    END LOOP;\nEND $$;\n\nSELECT * FROM vector_analysis_quality ORDER BY schema_name, table_name, column_name;"
    },
