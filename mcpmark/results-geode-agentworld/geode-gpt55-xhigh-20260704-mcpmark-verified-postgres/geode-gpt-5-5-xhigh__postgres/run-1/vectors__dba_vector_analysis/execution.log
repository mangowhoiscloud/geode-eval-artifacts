  {
    "tool": "execute_sql",
    "input": {
      "sql": "TRUNCATE vector_analysis_columns, vector_analysis_storage_consumption, vector_analysis_indices;\n\nDO $$\nDECLARE\n    r RECORD;\n    v_rows BIGINT;\n    v_dims INTEGER;\nBEGIN\n    FOR r IN\n        SELECT \n            n.nspname AS schema_name,\n            c.relname AS table_name,\n            c.oid AS table_oid,\n            a.attname AS column_name,\n            a.attnum,\n            t.typname AS base_type,\n            format_type(a.atttypid, a.atttypmod) AS formatted_type,\n            a.atttypmod,\n            a.attnotnull,\n            EXISTS (\n                SELECT 1\n                FROM pg_constraint con\n                WHERE con.conrelid = c.oid\n                  AND con.contype IN ('c','f')\n                  AND a.attnum = ANY(con.conkey)\n            ) AS has_check_or_fk\n        FROM pg_attribute a\n        JOIN pg_class c ON c.oid = a.attrelid\n        JOIN pg_namespace n ON n.oid = c.relnamespace\n        JOIN pg_type t ON t.oid = a.atttypid\n        WHERE a.attnum > 0\n          AND NOT a.attisdropped\n          AND c.relkind IN ('r','p')\n          AND n.nspname NOT IN ('pg_catalog','information_schema')\n          AND t.typname IN ('vector','halfvec','sparsevec')\n        ORDER BY n.nspname, c.relname, a.attnum\n    LOOP\n        EXECUTE format('SELECT count(*) FROM %I.%I', r.schema_name, r.table_name) INTO v_rows;\n        v_dims := CASE WHEN r.atttypmod > 0 THEN r.atttypmod ELSE NULL END;\n\n        INSERT INTO vector_analysis_columns(schema, table_name, column_name, dimensions, data_type, has_constraints, rows)\n        VALUES (r.schema_name, r.table_name, r.column_name, v_dims, r.formatted_type, (r.attnotnull OR r.has_check_or_fk), v_rows);\n    END LOOP;\nEND $$;\n\nDO $$\nDECLARE\n    r RECORD;\n    v_expr TEXT;\n    v_rows BIGINT;\n    v_vector_bytes BIGINT;\n    v_total_size BIGINT;\nBEGIN\n    FOR r IN\n        SELECT \n            n.nspname AS schema_name,\n            c.relname AS table_name,\n            c.oid AS table_oid\n        FROM pg_attribute a\n        JOIN pg_class c ON c.oid = a.attrelid\n        JOIN pg_namespace n ON n.oid = c.relnamespace\n        JOIN pg_type t ON t.oid = a.atttypid\n        WHERE a.attnum > 0\n          AND NOT a.attisdropped\n          AND c.relkind IN ('r','p')\n          AND n.nspname NOT IN ('pg_catalog','information_schema')\n          AND t.typname IN ('vector','halfvec','sparsevec')\n        GROUP BY n.nspname, c.relname, c.oid\n        ORDER BY n.nspname, c.relname\n    LOOP\n        SELECT string_agg(format('COALESCE(pg_column_size(%I),0)', a.attname), ' + ' ORDER BY a.attnum)\n        INTO v_expr\n        FROM pg_attribute a\n        JOIN pg_type t ON t.oid = a.atttypid\n        WHERE a.attrelid = r.table_oid\n          AND a.attnum > 0\n          AND NOT a.attisdropped\n          AND t.typname IN ('vector','halfvec','sparsevec');\n\n        EXECUTE format('SELECT count(*)::bigint, COALESCE(sum(%s),0)::bigint FROM %I.%I', v_expr, r.schema_name, r.table_name)\n        INTO v_rows, v_vector_bytes;\n\n        SELECT pg_table_size(r.table_oid) INTO v_total_size;\n\n        INSERT INTO vector_analysis_storage_consumption(schema, table_name, total_size_bytes, vector_data_bytes, regular_data_bytes, vector_storage_pct, row_count)\n        VALUES (\n            r.schema_name,\n            r.table_name,\n            v_total_size,\n            v_vector_bytes,\n            GREATEST(v_total_size - v_vector_bytes, 0),\n            CASE WHEN v_total_size > 0 THEN ROUND((v_vector_bytes::numeric / v_total_size::numeric) * 100, 2) ELSE 0 END,\n            v_rows\n        );\n    END LOOP;\nEND $$;\n\nINSERT INTO vector_analysis_indices(schema, table_name, column_name, index_name, index_type, index_size_bytes)\nSELECT\n    tn.nspname AS schema,\n    tbl.relname AS table_name,\n    COALESCE(att.attname, pg_get_indexdef(idx.indexrelid, k.ord::int, true)) AS column_name,\n    ind.relname AS index_name,\n    am.amname AS index_type,\n    pg_relation_size(ind.oid) AS index_size_bytes\nFROM pg_index idx\nJOIN pg_class ind ON ind.oid = idx.indexrelid\nJOIN pg_class tbl ON tbl.oid = idx.indrelid\nJOIN pg_namespace tn ON tn.oid = tbl.relnamespace\nJOIN pg_am am ON am.oid = ind.relam\nCROSS JOIN LATERAL unnest(idx.indkey) WITH ORDINALITY AS k(attnum, ord)\nLEFT JOIN pg_attribute att ON att.attrelid = tbl.oid AND att.attnum = k.attnum\nWHERE tn.nspname NOT IN ('pg_catalog','information_schema')\n  AND am.amname IN ('hnsw','ivfflat')\nORDER BY tn.nspname, tbl.relname, ind.relname, k.ord;\n\nSELECT 'vector_analysis_columns' AS analysis_table, * FROM vector_analysis_columns ORDER BY schema, table_name, column_name;\nSELECT 'vector_analysis_storage_consumption' AS analysis_table, * FROM vector_analysis_storage_consumption ORDER BY total_size_bytes DESC;\nSELECT 'vector_analysis_indices' AS analysis_table, * FROM vector_analysis_indices ORDER BY schema, table_name, index_name;"
    },
    "result": {
      "result": "{\"meta\": null, \"content\": [{\"type\": \"text\", \"text\": \"[{'analysis_table': 'vector_analysis_indices', 'schema': 'public', 'table_name': 'document_chunks', 'column_name': 'embedding', 'index_name': 'chunks_embedding_idx', 'index_type': 'hnsw', 'index_size_bytes': 352256}, {'analysis_table': 'vector_analysis_indices', 'schema': 'public', 'table_name': 'documents', 'column_name': 'embedding', 'index_name': 'documents_embedding_idx', 'index_type': 'hnsw', 'index_size_bytes': 90112}, {'analysis_table': 'vector_analysis_indices', 'schema': 'public', 'table_name': 'user_queries', 'column_name': 'embedding', 'index_name': 'queries_embedding_idx', 'index_type': 'hnsw', 'index_size_bytes': 90112}]\", \"annotations\": null, \"meta\": null}], \"structuredContent\": {\"result\": [{\"type\": \"text\", \"text\": \"[{'analysis_table': 'vector_analysis_indices', 'schema': 'public', 'table_name': 'document_chunks', 'column_name': 'embedding', 'index_name': 'chunks_embedding_idx', 'index_type': 'hnsw', 'index_size_bytes': 352256}, {'analysis_table': 'vector_analysis_indices', 'schema': 'public', 'table_name': 'documents', 'column_name': 'embedding', 'index_name': 'documents_embedding_idx', 'index_type': 'hnsw', 'index_size_bytes': 90112}, {'analysis_table': 'vector_analysis_indices', 'schema': 'public', 'table_name': 'user_queries', 'column_name': 'embedding', 'index_name': 'queries_embedding_idx', 'index_type': 'hnsw', 'index_size_bytes': 90112}]\", \"annotations\": null, \"_meta\": null}]}, \"isError\": false}"
