    "input": {
      "sql": "DROP TABLE IF EXISTS vector_analysis_columns;\nCREATE TABLE vector_analysis_columns (\n    schema VARCHAR(50),\n    table_name VARCHAR(100),\n    column_name VARCHAR(100),\n    dimensions INTEGER,\n    data_type VARCHAR(50),\n    has_constraints BOOLEAN,\n    rows BIGINT\n);\n\nDROP TABLE IF EXISTS vector_analysis_storage_consumption;\nCREATE TABLE vector_analysis_storage_consumption (\n    schema VARCHAR(50),\n    table_name VARCHAR(100),\n    total_size_bytes BIGINT,\n    vector_data_bytes BIGINT,\n    regular_data_bytes BIGINT,\n    vector_storage_pct NUMERIC(5,2),\n    row_count BIGINT\n);\n\nDROP TABLE IF EXISTS vector_analysis_indices;\nCREATE TABLE vector_analysis_indices (\n    schema VARCHAR(50),\n    table_name VARCHAR(100),\n    column_name VARCHAR(100),\n    index_name VARCHAR(100),\n    index_type VARCHAR(50),\n    index_size_bytes BIGINT\n);"
    },
    "result": {
      "result": "{\"meta\": null, \"content\": [{\"type\": \"text\", \"text\": \"No results\", \"annotations\": null, \"meta\": null}], \"structuredContent\": {\"result\": [{\"type\": \"text\", \"text\": \"No results\", \"annotations\": null, \"_meta\": null}]}, \"isError\": false}"
