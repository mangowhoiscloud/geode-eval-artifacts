      "sql": "SELECT \n    t.oid::regtype::text AS type_name,\n    n.nspname AS type_schema\nFROM pg_type t\nJOIN pg_depend d ON d.classid = 'pg_type'::regclass AND d.objid = t.oid\nJOIN pg_extension e ON e.oid = d.refobjid AND e.extname = 'vector'\nJOIN pg_namespace n ON n.oid = t.typnamespace\nWHERE t.typtype IN ('b','d')\nORDER BY type_name;\n\nSELECT \n    p.proname,\n    pg_get_function_identity_arguments(p.oid) AS args,\n    pg_get_function_result(p.oid) AS result\nFROM pg_proc p\nJOIN pg_depend d ON d.classid = 'pg_proc'::regclass AND d.objid = p.oid\nJOIN pg_extension e ON e.oid = d.refobjid AND e.extname = 'vector'\nWHERE p.proname ILIKE '%dims%' OR p.proname ILIKE '%norm%'\nORDER BY p.proname, args;"
    },
