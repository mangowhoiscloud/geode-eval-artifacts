  {
    "tool": "execute_sql",
    "input": {
      "sql": "DROP TRIGGER IF EXISTS check_set_parts_consistency_lego_sets ON public.lego_sets;\nDROP TRIGGER IF EXISTS check_set_parts_consistency_lego_inventories ON public.lego_inventories;\nDROP TRIGGER IF EXISTS check_set_parts_consistency_lego_inventory_parts ON public.lego_inventory_parts;\n\nDROP TABLE IF EXISTS pg_temp.correct_counts;\nDROP TABLE IF EXISTS pg_temp.consistency_summary;\nDROP TABLE IF EXISTS pg_temp.update_summary;\n\nCREATE TEMP TABLE correct_counts (\n    set_num text,\n    actual_parts integer\n);\n\nINSERT INTO correct_counts (set_num, actual_parts)\nSELECT s.set_num,\n       COALESCE(latest_counts.actual_parts, 0)::integer AS actual_parts\nFROM public.lego_sets AS s\nLEFT JOIN (\n    SELECT latest_inventories.set_num,\n           COALESCE(SUM(lip.quantity), 0)::integer AS actual_parts\n    FROM (\n        SELECT li.set_num, li.id\n        FROM public.lego_inventories AS li\n        JOIN (\n            SELECT set_num, MAX(version) AS max_version\n            FROM public.lego_inventories\n            GROUP BY set_num\n        ) AS max_versions\n          ON max_versions.set_num = li.set_num\n         AND max_versions.max_version = li.version\n    ) AS latest_inventories\n    LEFT JOIN public.lego_inventory_parts AS lip\n      ON lip.inventory_id = latest_inventories.id\n     AND lip.is_spare = false\n    GROUP BY latest_inventories.set_num\n) AS latest_counts\n  ON latest_counts.set_num = s.set_num;\n\nCREATE TEMP TABLE consistency_summary AS\nSELECT COUNT(*)::integer AS sets_checked,\n       COUNT(*) FILTER (WHERE s.num_parts IS DISTINCT FROM cc.actual_parts)::integer AS pre_fix_inconsistencies\nFROM public.lego_sets AS s\nJOIN correct_counts AS cc\n  ON cc.set_num = s.set_num;\n\nCREATE TEMP TABLE update_summary AS\nWITH updated AS (\n    UPDATE public.lego_sets AS s\n       SET num_parts = cc.actual_parts\n      FROM correct_counts AS cc\n     WHERE s.set_num = cc.set_num\n       AND s.num_parts IS DISTINCT FROM cc.actual_parts\n    RETURNING s.set_num\n)\nSELECT COUNT(*)::integer AS rows_updated\nFROM updated;\n\nCREATE OR REPLACE FUNCTION public.check_set_parts_consistency()\nRETURNS trigger\nLANGUAGE plpgsql\nAS $$\nDECLARE\n    relevant_set_num public.lego_sets.set_num%TYPE;\n    old_relevant_set_num public.lego_sets.set_num%TYPE;\n    check_set_num public.lego_sets.set_num%TYPE;\n    stored_num_parts integer;\n    actual_parts integer;\nBEGIN\n    IF TG_TABLE_NAME = 'lego_sets' THEN\n        relevant_set_num := NEW.set_num;\n    ELSIF TG_TABLE_NAME = 'lego_inventories' THEN\n        relevant_set_num := NEW.set_num;\n\n        IF TG_OP = 'UPDATE' THEN\n            IF OLD.set_num IS DISTINCT FROM NEW.set_num THEN\n                old_relevant_set_num := OLD.set_num;\n            END IF;\n        END IF;\n    ELSIF TG_TABLE_NAME = 'lego_inventory_parts' THEN\n        SELECT li.set_num\n          INTO relevant_set_num\n          FROM public.lego_inventories AS li\n         WHERE li.id = NEW.inventory_id;\n\n        IF TG_OP = 'UPDATE' THEN\n            IF OLD.inventory_id IS DISTINCT FROM NEW.inventory_id THEN\n                SELECT li.set_num\n                  INTO old_relevant_set_num\n                  FROM public.lego_inventories AS li\n                 WHERE li.id = OLD.inventory_id;\n            END IF;\n        END IF;\n    ELSE\n        RETURN NEW;\n    END IF;\n\n    FOR check_set_num IN\n        SELECT DISTINCT x\n        FROM unnest(ARRAY[relevant_set_num, old_relevant_set_num]) AS u(x)\n        WHERE x IS NOT NULL\n    LOOP\n        SELECT s.num_parts\n          INTO stored_num_parts\n          FROM public.lego_sets AS s\n         WHERE s.set_num = check_set_num;\n\n        IF NOT FOUND THEN\n            CONTINUE;\n        END IF;\n\n        SELECT COALESCE(SUM(lip.quantity), 0)::integer\n          INTO actual_parts\n          FROM public.lego_inventory_parts AS lip\n         WHERE lip.is_spare = false\n           AND lip.inventory_id IN (\n               SELECT li.id\n                 FROM public.lego_inventories AS li\n                WHERE li.set_num = check_set_num\n                  AND li.version = (\n                      SELECT MAX(li2.version)\n                        FROM public.lego_inventories AS li2\n                       WHERE li2.set_num = check_set_num\n                  )\n           );\n\n        IF actual_parts IS DISTINCT FROM stored_num_parts THEN\n            RAISE EXCEPTION 'Inconsistent part count for set %: stored %, actual %',\n                check_set_num, stored_num_parts, actual_parts;\n        END IF;\n    END LOOP;\n\n    RETURN NEW;\nEND;\n$$;\n\nCREATE CONSTRAINT TRIGGER check_set_parts_consistency_lego_sets\nAFTER INSERT OR UPDATE ON public.lego_sets\nDEFERRABLE INITIALLY IMMEDIATE\nFOR EACH ROW\nEXECUTE FUNCTION public.check_set_parts_consistency();\n\nCREATE CONSTRAINT TRIGGER check_set_parts_consistency_lego_inventories\nAFTER INSERT OR UPDATE ON public.lego_inventories\nDEFERRABLE INITIALLY IMMEDIATE\nFOR EACH ROW\nEXECUTE FUNCTION public.check_set_parts_consistency();\n\nCREATE CONSTRAINT TRIGGER check_set_parts_consistency_lego_inventory_parts\nAFTER INSERT OR UPDATE ON public.lego_inventory_parts\nDEFERRABLE INITIALLY IMMEDIATE\nFOR EACH ROW\nEXECUTE FUNCTION public.check_set_parts_consistency();\n\nWITH latest_inventories AS (\n    SELECT li.set_num, li.id\n    FROM public.lego_inventories AS li\n    JOIN (\n        SELECT set_num, MAX(version) AS max_version\n        FROM public.lego_inventories\n        GROUP BY set_num\n    ) AS max_versions\n      ON max_versions.set_num = li.set_num\n     AND max_versions.max_version = li.version\n), actual_counts AS (\n    SELECT latest_inventories.set_num,\n           COALESCE(SUM(lip.quantity), 0)::integer AS actual_parts\n    FROM latest_inventories\n    LEFT JOIN public.lego_inventory_parts AS lip\n      ON lip.inventory_id = latest_inventories.id\n     AND lip.is_spare = false\n    GROUP BY latest_inventories.set_num\n), remaining AS (\n    SELECT COUNT(*)::integer AS remaining_inconsistencies\n    FROM public.lego_sets AS s\n    LEFT JOIN actual_counts AS ac\n      ON ac.set_num = s.set_num\n    WHERE s.num_parts IS DISTINCT FROM COALESCE(ac.actual_parts, 0)::integer\n), trigger_check AS (\n    SELECT COUNT(*)::integer AS valid_constraint_triggers\n    FROM pg_trigger AS t\n    WHERE t.tgname IN (\n        'check_set_parts_consistency_lego_sets',\n        'check_set_parts_consistency_lego_inventories',\n        'check_set_parts_consistency_lego_inventory_parts'\n    )\n      AND t.tgrelid IN (\n        'public.lego_sets'::regclass,\n        'public.lego_inventories'::regclass,\n        'public.lego_inventory_parts'::regclass\n    )\n      AND t.tgconstraint <> 0\n      AND t.tgdeferrable = true\n      AND t.tginitdeferred = false\n      AND t.tgisinternal = false\n), trigger_details AS (\n    SELECT COALESCE(\n        jsonb_agg(\n            jsonb_build_object(\n                'trigger_name', t.tgname,\n                'table_name', t.tgrelid::regclass::text,\n                'constraint_trigger', t.tgconstraint <> 0,\n                'deferrable', t.tgdeferrable,\n                'initially_deferred', t.tginitdeferred\n            )\n            ORDER BY t.tgrelid::regclass::text, t.tgname\n        ),\n        '[]'::jsonb\n    ) AS triggers\n    FROM pg_trigger AS t\n    WHERE t.tgname IN (\n        'check_set_parts_consistency_lego_sets',\n        'check_set_parts_consistency_lego_inventories',\n        'check_set_parts_consistency_lego_inventory_parts'\n    )\n      AND t.tgrelid IN (\n        'public.lego_sets'::regclass,\n        'public.lego_inventories'::regclass,\n        'public.lego_inventory_parts'::regclass\n    )\n      AND t.tgisinternal = false\n)\nSELECT cs.sets_checked,\n       cs.pre_fix_inconsistencies,\n       us.rows_updated,\n       r.remaining_inconsistencies,\n       tc.valid_constraint_triggers,\n       td.triggers\nFROM consistency_summary AS cs\nCROSS JOIN update_summary AS us\nCROSS JOIN remaining AS r\nCROSS JOIN trigger_check AS tc\nCROSS JOIN trigger_details AS td;"
    },
