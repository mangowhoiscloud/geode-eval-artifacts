k of 6814 6879 and 6898', 'stored_num_parts': 3, 'actual_parts': 0}, {'set_num': 'VP-10', 'name': 'Star Wars Value Pack with Free LEGO Backpack (K-Mart Australia Exclusive)', 'stored_num_parts': 4, 'actual_parts': 1}, {'set_num': 'VP-11', 'name': 'Star Wars Co-Pack of 7101 7111 and 7131', 'stored_num_parts': 3, 'actual_parts': 0}, {'set_num': 'VP-12', 'name': 'Star Wars Co-Pack of 7121 and 7151', 'stored_num_parts': 2, 'actual_parts': 0}, {'set_num': 'VP-13', 'name': 'Launch Command Value Pack - (6336 6516 6614)', 'stored_num_parts': 3, 'actual_parts': 0}, {'set_num': 'VP-14', 'name': 'Classic Town Value Pack Duopack (6581 6596)', 'stored_num_parts': 2, 'actual_parts': 0}, {'set_num': 'VP-15', 'name': 'Adventurers Super Value Pack', 'stored_num_parts': 3, 'actual_parts': 0}, {'set_num': 'VP-2', 'name': 'Star Wars Co-Pack of 7110 and 7144', 'stored_num_parts': 2, 'actual_parts': 0}, {'set_num': 'VP-3', 'name': 'Star Wars Co-Pack of 7131 and 7151', 'stored_num_parts': 2, 'actual_parts': 0}, {'set_num': 'VP-4', 'name': 'Star Wars Co-Pack of 7101 7111 and 7171', 'stored_num_parts': 3, 'actual_parts': 0}, {'set_num': 'VP-5', 'name': 'UFO Value Pack', 'stored_num_parts': 3, 'actual_parts': 0}, {'set_num': 'VP-6', 'name': 'Building Bonanza Value Pack 4886 with 7280 & 7281', 'stored_num_parts': 3, 'actual_parts': 0}, {'set_num': 'VP-7', 'name': 'Fire Value Pack (6554 6407 6564)', 'stored_num_parts': 3, 'actual_parts': 0}, {'set_num': 'VP-8', 'name': 'Star Wars Co-Pack of 7130 and 7150', 'stored_num_parts': 2, 'actual_parts': 0}, {'set_num': 'VPorient-1', 'name': 'Orient Expedition Value Pack with LEGO Backpack (K-Mart Australia Exclusive)', 'stored_num_parts': 4, 'actual_parts': 1}, {'set_num': 'wwgp1-1', 'name': 'Wild West Limited Edition Gift Pack', 'stored_num_parts': 3, 'actual_parts': 0}]\", \"annotations\": null, \"_meta\": null}]}, \"isError\": false}"
