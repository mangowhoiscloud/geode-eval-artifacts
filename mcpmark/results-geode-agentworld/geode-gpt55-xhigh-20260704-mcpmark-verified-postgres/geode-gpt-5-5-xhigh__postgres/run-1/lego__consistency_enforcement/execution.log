      "result": "{\"meta\": null, \"content\": [{\"type\": \"text\", \"text\": \"[{'sets_checked': 11673, 'pre_fix_inconsistencies': 540, 'rows_updated': 540, 'remaining_inconsistencies': 0, 'valid_constraint_triggers': 3, 'triggers': [{'deferrable': True, 'table_name': 'lego_inventories', 'trigger_name': 'check_set_parts_consistency_lego_inventories', 'constraint_trigger': True, 'initially_deferred': False}, {'deferrable': True, 'table_name': 'lego_inventory_parts', 'trigger_name': 'check_set_parts_consistency_lego_inventory_parts', 'constraint_trigger': True, 'initially_deferred': False}, {'deferrable': True, 'table_name': 'lego_sets', 'trigger_name': 'check_set_parts_consistency_lego_sets', 'constraint_trigger': True, 'initially_deferred': False}]}]\", \"annotations\": null, \"meta\": null}], \"structuredContent\": {\"result\": [{\"type\": \"text\", \"text\": \"[{'sets_checked': 11673, 'pre_fix_inconsistencies': 540, 'rows_updated': 540, 'remaining_inconsistencies': 0, 'valid_constraint_triggers': 3, 'triggers': [{'deferrable': True, 'table_name': 'lego_inventories', 'trigger_name': 'check_set_parts_consistency_lego_inventories', 'constraint_trigger': True, 'initially_deferred': False}, {'deferrable': True, 'table_name': 'lego_inventory_parts', 'trigger_name': 'check_set_parts_consistency_lego_inventory_parts', 'constraint_trigger': True, 'initially_deferred': False}, {'deferrable': True, 'table_name': 'lego_sets', 'trigger_name': 'check_set_parts_consistency_lego_sets', 'constraint_trigger': True, 'initially_deferred': False}]}]\", \"annotations\": null, \"_meta\": null}]}, \"isError\": false}"
