  {
    "tool": "execute_sql",
    "input": {
      "sql": "BEGIN;\n\nDROP TABLE IF EXISTS employees.manager_profile;\nDROP TABLE IF EXISTS employees.department_leadership;\nDROP TABLE IF EXISTS employees.management_transitions;\nDROP TABLE IF EXISTS employees.span_of_control;\n\nCREATE TABLE employees.manager_profile (\n    manager_id bigint,\n    manager_name varchar,\n    current_department varchar,\n    management_periods integer,\n    current_manager boolean\n);\n\nINSERT INTO employees.manager_profile (\n    manager_id,\n    manager_name,\n    current_department,\n    management_periods,\n    current_manager\n)\nSELECT\n    e.id::bigint AS manager_id,\n    CONCAT(e.first_name, ' ', e.last_name)::varchar AS manager_name,\n    STRING_AGG(DISTINCT d.dept_name, ', ' ORDER BY d.dept_name)\n        FILTER (WHERE dm.to_date = DATE '9999-01-01')::varchar AS current_department,\n    COUNT(*)::integer AS management_periods,\n    BOOL_OR(dm.to_date = DATE '9999-01-01') AS current_manager\nFROM employees.department_manager dm\nJOIN employees.employee e\n    ON e.id = dm.employee_id\nJOIN employees.department d\n    ON d.id = dm.department_id\nGROUP BY e.id, e.first_name, e.last_name;\n\nCREATE TABLE employees.department_leadership (\n    department_name varchar,\n    current_manager_name varchar,\n    manager_start_date date,\n    total_historical_managers integer\n);\n\nINSERT INTO employees.department_leadership (\n    department_name,\n    current_manager_name,\n    manager_start_date,\n    total_historical_managers\n)\nWITH historical_counts AS (\n    SELECT\n        department_id,\n        COUNT(DISTINCT employee_id)::integer AS total_historical_managers\n    FROM employees.department_manager\n    GROUP BY department_id\n), current_managers AS (\n    SELECT\n        dm.department_id,\n        CONCAT(e.first_name, ' ', e.last_name)::varchar AS current_manager_name,\n        dm.from_date AS manager_start_date,\n        ROW_NUMBER() OVER (\n            PARTITION BY dm.department_id\n            ORDER BY dm.from_date DESC, dm.employee_id\n        ) AS rn\n    FROM employees.department_manager dm\n    JOIN employees.employee e\n        ON e.id = dm.employee_id\n    WHERE dm.to_date = DATE '9999-01-01'\n)\nSELECT\n    d.dept_name::varchar AS department_name,\n    cm.current_manager_name,\n    cm.manager_start_date,\n    COALESCE(hc.total_historical_managers, 0)::integer AS total_historical_managers\nFROM employees.department d\nLEFT JOIN current_managers cm\n    ON cm.department_id = d.id\n   AND cm.rn = 1\nLEFT JOIN historical_counts hc\n    ON hc.department_id = d.id;\n\nCREATE TABLE employees.management_transitions (\n    department_name varchar,\n    transition_year integer,\n    outgoing_manager varchar,\n    incoming_manager varchar,\n    transition_gap_days integer\n);\n\nINSERT INTO employees.management_transitions (\n    department_name,\n    transition_year,\n    outgoing_manager,\n    incoming_manager,\n    transition_gap_days\n)\nWITH ordered_management AS (\n    SELECT\n        d.dept_name::varchar AS department_name,\n        CONCAT(e.first_name, ' ', e.last_name)::varchar AS manager_name,\n        dm.from_date,\n        dm.to_date,\n        LEAD(CONCAT(e.first_name, ' ', e.last_name)::varchar) OVER (\n            PARTITION BY dm.department_id\n            ORDER BY dm.from_date, dm.to_date, dm.employee_id\n        ) AS next_manager_name,\n        LEAD(dm.from_date) OVER (\n            PARTITION BY dm.department_id\n            ORDER BY dm.from_date, dm.to_date, dm.employee_id\n        ) AS next_from_date\n    FROM employees.department_manager dm\n    JOIN employees.department d\n        ON d.id = dm.department_id\n    JOIN employees.employee e\n        ON e.id = dm.employee_id\n)\nSELECT\n    department_name,\n    EXTRACT(YEAR FROM COALESCE(next_from_date, to_date))::integer AS transition_year,\n    manager_name::varchar AS outgoing_manager,\n    COALESCE(next_manager_name, 'No Successor')::varchar AS incoming_manager,\n    CASE\n        WHEN next_from_date IS NULL THEN 0\n        ELSE GREATEST((next_from_date - to_date), 0)::integer\n    END AS transition_gap_days\nFROM ordered_management\nWHERE to_date <> DATE '9999-01-01';\n\nCREATE TABLE employees.span_of_control (\n    manager_id bigint,\n    manager_name varchar,\n    department_name varchar,\n    total_employees integer,\n    current_employees integer,\n    management_load varchar\n);\n\nINSERT INTO employees.span_of_control (\n    manager_id,\n    manager_name,\n    department_name,\n    total_employees,\n    current_employees,\n    management_load\n)\nWITH department_counts AS (\n    SELECT\n        department_id,\n        COUNT(DISTINCT employee_id)::integer AS total_employees,\n        COUNT(DISTINCT employee_id) FILTER (WHERE to_date = DATE '9999-01-01')::integer AS current_employees\n    FROM employees.department_employee\n    GROUP BY department_id\n)\nSELECT\n    dm.employee_id::bigint AS manager_id,\n    CONCAT(e.first_name, ' ', e.last_name)::varchar AS manager_name,\n    d.dept_name::varchar AS department_name,\n    COALESCE(dc.total_employees, 0)::integer AS total_employees,\n    COALESCE(dc.current_employees, 0)::integer AS current_employees,\n    CASE\n        WHEN COALESCE(dc.current_employees, 0) < 5000 THEN 'light'\n        WHEN COALESCE(dc.current_employees, 0) BETWEEN 5000 AND 15000 THEN 'moderate'\n        ELSE 'heavy'\n    END::varchar AS management_load\nFROM employees.department_manager dm\nJOIN employees.employee e\n    ON e.id = dm.employee_id\nJOIN employees.department d\n    ON d.id = dm.department_id\nLEFT JOIN department_counts dc\n    ON dc.department_id = dm.department_id\nWHERE dm.to_date = DATE '9999-01-01';\n\nCOMMIT;\n\nSELECT\n    (SELECT COUNT(*) FROM employees.manager_profile) AS manager_profile_rows,\n    (SELECT COUNT(*) FROM employees.department_leadership) AS department_leadership_rows,\n    (SELECT COUNT(*) FROM employees.management_transitions) AS management_transitions_rows,\n    (SELECT COUNT(*) FROM employees.span_of_control) AS span_of_control_rows;"
    },
    "result": {
      "result": "{\"meta\": null, \"content\": [{\"type\": \"text\", \"text\": \"[{'manager_profile_rows': 24, 'department_leadership_rows': 9, 'management_transitions_rows': 15, 'span_of_control_rows': 9}]\", \"annotations\": null, \"meta\": null}], \"structuredContent\": {\"result\": [{\"type\": \"text\", \"text\": \"[{'manager_profile_rows': 24, 'department_leadership_rows': 9, 'management_transitions_rows': 15, 'span_of_control_rows': 9}]\", \"annotations\": null, \"_meta\": null}]}, \"isError\": false}"
    },
