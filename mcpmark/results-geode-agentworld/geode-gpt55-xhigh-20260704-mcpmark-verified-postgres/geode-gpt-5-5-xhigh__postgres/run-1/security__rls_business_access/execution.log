  {
    "tool": "execute_sql",
    "input": {
      "sql": "SELECT n.nspname AS schema, p.proname AS function_name, pg_get_function_identity_arguments(p.oid) AS args, pg_get_function_result(p.oid) AS result_type, pg_get_functiondef(p.oid) AS definition\nFROM pg_proc p\nJOIN pg_namespace n ON n.oid = p.pronamespace\nWHERE n.nspname = 'public'\n  AND p.proname IN ('app_current_user_id', 'is_channel_owner', 'is_channel_moderator', 'can_moderate_channel')\nORDER BY p.proname;"
    },
    "result": {
      "result": "{\"meta\": null, \"content\": [{\"type\": \"text\", \"text\": \"[{'schema': 'public', 'function_name': 'app_current_user_id', 'args': '', 'result_type': 'uuid', 'definition': \\\"CREATE OR REPLACE FUNCTION public.app_current_user_id()\\\\n RETURNS uuid\\\\n LANGUAGE plpgsql\\\\n STABLE PARALLEL SAFE SECURITY DEFINER\\\\nAS $function$\\\\n            BEGIN\\\\n                RETURN NULLIF(current_setting('app.current_user_id', true), '')::UUID;\\\\n            END;\\\\n            $function$\\\\n\\\"}, {'schema': 'public', 'function_name': 'can_moderate_channel', 'args': 'p_channel_id uuid, p_user_id uuid', 'result_type': 'boolean', 'definition': 'CREATE OR REPLACE FUNCTION public.can_moderate_channel(p_channel_id uuid, p_user_id uuid)\\\\n RETURNS boolean\\\\n LANGUAGE plpgsql\\\\n STABLE PARALLEL SAFE SECURITY DEFINER\\\\nAS $function$\\\\n            BEGIN\\\\n                RETURN is_channel_owner(p_channel_id, p_user_id)\\\\n                       OR is_channel_moderator(p_channel_id, p_user_id);\\\\n            END;\\\\n            $function$\\\\n'}, {'schema': 'public', 'function_name': 'is_channel_moderator', 'args': 'p_channel_id uuid, p_user_id uuid', 'result_type': 'boolean', 'definition': 'CREATE OR REPLACE FUNCTION public.is_channel_moderator(p_channel_id uuid, p_user_id uuid)\\\\n RETURNS boolean\\\\n LANGUAGE plpgsql\\\\n STABLE PARALLEL SAFE SECURITY DEFINER\\\\nAS $function$\\\\n            BEGIN\\\\n                RETURN EXISTS (\\\\n                    SELECT 1 FROM channel_moderators\\\\n                    WHERE channel_id = p_channel_id AND user_id = p_user_id\\\\n                );\\\\n            END;\\\\n            $function$\\\\n'}, {'schema': 'public', 'function_name': 'is_channel_owner', 'args': 'p_channel_id uuid, p_user_id uuid', 'result_type': 'boolean', 'definition': 'CREATE OR REPLACE FUNCTION public.is_channel_owner(p_channel_id uuid, p_user_id uuid)\\\\n RETURNS boolean\\\\n LANGUAGE plpgsql\\\\n STABLE PARALLEL SAFE SECURITY DEFINER\\\\nAS $function$\\\\n            BEGIN\\\\n                RETURN EXISTS (\\\\n                    SELECT 1 FROM channels\\\\n                    WHERE id = p_channel_id AND owner_id = p_user_id\\\\n                );\\\\n            END;\\\\n            $function$\\\\n'}]\", \"annotations\": null, \"meta\": null}], \"structuredContent\": {\"result\": [{\"type\": \"text\", \"text\": \"[{'schema': 'public', 'function_name': 'app_current_user_id', 'args': '', 'result_type': 'uuid', 'definition': \\\"CREATE OR REPLACE FUNCTION public.app_current_user_id()\\\\n RETURNS uuid\\\\n LANGUAGE plpgsql\\\\n STABLE PARALLEL SAFE SECURITY DEFINER\\\\nAS $function$\\\\n            BEGIN\\\\n                RETURN NULLIF(current_setting('app.current_user_id', true), '')::UUID;\\\\n            END;\\\\n            $function$\\\\n\\\"}, {'schema': 'public', 'function_name': 'can_moderate_channel', 'args': 'p_channel_id uuid, p_user_id uuid', 'result_type': 'boolean', 'definition': 'CREATE OR REPLACE FUNCTION public.can_moderate_channel(p_channel_id uuid, p_user_id uuid)\\\\n RETURNS boolean\\\\n LANGUAGE plpgsql\\\\n STABLE PARALLEL SAFE SECURITY DEFINER\\\\nAS $function$\\\\n            BEGIN\\\\n                RETURN is_channel_owner(p_channel_id, p_user_id)\\\\n                       OR is_channel_moderator(p_channel_id, p_user_id);\\\\n            END;\\\\n            $function$\\\\n'}, {'schema': 'public', 'function_name': 'is_channel_moderator', 'args': 'p_channel_id uuid, p_user_id uuid', 'result_type': 'boolean', 'definition': 'CREATE OR REPLACE FUNCTION public.is_channel_moderator(p_channel_id uuid, p_user_id uuid)\\\\n RETURNS boolean\\\\n LANGUAGE plpgsql\\\\n STABLE PARALLEL SAFE SECURITY DEFINER\\\\nAS $function$\\\\n            BEGIN\\\\n                RETURN EXISTS (\\\\n                    SELECT 1 FROM channel_moderators\\\\n                    WHERE channel_id = p_channel_id AND user_id = p_user_id\\\\n                );\\\\n            END;\\\\n            $function$\\\\n'}, {'schema': 'public', 'function_name': 'is_channel_owner', 'args': 'p_channel_id uuid, p_user_id uuid', 'result_type': 'boolean', 'definition': 'CREATE OR REPLACE FUNCTION public.is_channel_owner(p_channel_id uuid, p_user_id uuid)\\\\n RETURNS boolean\\\\n LANGUAGE plpgsql\\\\n STABLE PARALLEL SAFE SECURITY DEFINER\\\\nAS $function$\\\\n            BEGIN\\\\n                RETURN EXISTS (\\\\n                    SELECT 1 FROM channels\\\\n                    WHERE id = p_channel_id AND owner_id = p_user_id\\\\n                );\\\\n            END;\\\\n            $function$\\\\n'}]\", \"annotations\": null, \"_meta\": null}]}, \"isError\": false}"
