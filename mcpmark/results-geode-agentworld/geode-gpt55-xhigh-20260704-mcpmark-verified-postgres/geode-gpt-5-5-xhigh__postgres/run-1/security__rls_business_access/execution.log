  {
    "tool": "execute_sql",
    "input": {
      "sql": "BEGIN;\n\n-- Helper functions used by cross-table policies. They live in public and use the\n-- pre-created ownership/moderation helpers while bypassing policy recursion.\nCREATE OR REPLACE FUNCTION public.can_access_channel(p_channel_id uuid, p_user_id uuid)\nRETURNS boolean\nLANGUAGE sql\nSTABLE\nPARALLEL SAFE\nSECURITY DEFINER\nSET search_path = public, pg_temp\nAS $$\n    SELECT EXISTS (\n        SELECT 1\n        FROM public.channels c\n        WHERE c.id = p_channel_id\n          AND (\n              COALESCE(c.is_public, false)\n              OR public.can_moderate_channel(c.id, p_user_id)\n          )\n    );\n$$;\n\nCREATE OR REPLACE FUNCTION public.can_access_post(p_post_id uuid, p_user_id uuid)\nRETURNS boolean\nLANGUAGE sql\nSTABLE\nPARALLEL SAFE\nSECURITY DEFINER\nSET search_path = public, pg_temp\nAS $$\n    SELECT EXISTS (\n        SELECT 1\n        FROM public.posts p\n        WHERE p.id = p_post_id\n          AND public.can_access_channel(p.channel_id, p_user_id)\n    );\n$$;\n\nCREATE OR REPLACE FUNCTION public.can_manage_post(p_post_id uuid, p_user_id uuid)\nRETURNS boolean\nLANGUAGE sql\nSTABLE\nPARALLEL SAFE\nSECURITY DEFINER\nSET search_path = public, pg_temp\nAS $$\n    SELECT p_user_id IS NOT NULL\n       AND EXISTS (\n           SELECT 1\n           FROM public.posts p\n           WHERE p.id = p_post_id\n             AND (\n                 p.author_id = p_user_id\n                 OR public.can_moderate_channel(p.channel_id, p_user_id)\n             )\n       );\n$$;\n\nGRANT EXECUTE ON FUNCTION public.can_access_channel(uuid, uuid) TO PUBLIC;\nGRANT EXECUTE ON FUNCTION public.can_access_post(uuid, uuid) TO PUBLIC;\nGRANT EXECUTE ON FUNCTION public.can_manage_post(uuid, uuid) TO PUBLIC;\n\nALTER TABLE public.users ENABLE ROW LEVEL SECURITY;\nALTER TABLE public.channels ENABLE ROW LEVEL SECURITY;\nALTER TABLE public.channel_moderators ENABLE ROW LEVEL SECURITY;\nALTER TABLE public.posts ENABLE ROW LEVEL SECURITY;\nALTER TABLE public.comments ENABLE ROW LEVEL SECURITY;\n\nALTER TABLE public.users FORCE ROW LEVEL SECURITY;\nALTER TABLE public.channels FORCE ROW LEVEL SECURITY;\nALTER TABLE public.channel_moderators FORCE ROW LEVEL SECURITY;\nALTER TABLE public.posts FORCE ROW LEVEL SECURITY;\nALTER TABLE public.comments FORCE ROW LEVEL SECURITY;\n\nDROP POLICY IF EXISTS users_select_public_profiles ON public.users;\nDROP POLICY IF EXISTS users_insert_self ON public.users;\nDROP POLICY IF EXISTS users_update_self ON public.users;\nDROP POLICY IF EXISTS users_delete_self ON public.users;\n\nDROP POLICY IF EXISTS channels_select_accessible ON public.channels;\nDROP POLICY IF EXISTS channels_insert_owner ON public.channels;\nDROP POLICY IF EXISTS channels_update_owner ON public.channels;\nDROP POLICY IF EXISTS channels_delete_owner ON public.channels;\n\nDROP POLICY IF EXISTS channel_moderators_select_accessible_channel ON public.channel_moderators;\nDROP POLICY IF EXISTS channel_moderators_insert_channel_owner ON public.channel_moderators;\nDROP POLICY IF EXISTS channel_moderators_update_none ON public.channel_moderators;\nDROP POLICY IF EXISTS channel_moderators_delete_owner_or_self ON public.channel_moderators;\n\nDROP POLICY IF EXISTS posts_select_accessible_channels ON public.posts;\nDROP POLICY IF EXISTS posts_insert_authenticated_author ON public.posts;\nDROP POLICY IF EXISTS posts_update_author_or_moderator ON public.posts;\nDROP POLICY IF EXISTS posts_delete_author_or_moderator ON public.posts;\n\nDROP POLICY IF EXISTS comments_select_accessible_posts ON public.comments;\nDROP POLICY IF EXISTS comments_insert_authenticated_visible_post ON public.comments;\nDROP POLICY IF EXISTS comments_update_author_post_author_or_moderator ON public.comments;\nDROP POLICY IF EXISTS comments_delete_author_post_author_or_moderator ON public.comments;\n\n-- Users: public profiles are readable; users manage only their own row.\nCREATE POLICY users_select_public_profiles\nON public.users\nFOR SELECT\nTO PUBLIC\nUSING (\n    COALESCE(is_public, false)\n    OR id = public.app_current_user_id()\n);\n\nCREATE POLICY users_insert_self\nON public.users\nFOR INSERT\nTO PUBLIC\nWITH CHECK (\n    public.app_current_user_id() IS NOT NULL\n    AND id = public.app_current_user_id()\n);\n\nCREATE POLICY users_update_self\nON public.users\nFOR UPDATE\nTO PUBLIC\nUSING (id = public.app_current_user_id())\nWITH CHECK (id = public.app_current_user_id());\n\nCREATE POLICY users_delete_self\nON public.users\nFOR DELETE\nTO PUBLIC\nUSING (id = public.app_current_user_id());\n\n-- Channels: public channels are visible to everyone; private channel access is\n-- available to owners/moderators. Only owners create/update/delete their channel.\nCREATE POLICY channels_select_accessible\nON public.channels\nFOR SELECT\nTO PUBLIC\nUSING (public.can_access_channel(id, public.app_current_user_id()));\n\nCREATE POLICY channels_insert_owner\nON public.channels\nFOR INSERT\nTO PUBLIC\nWITH CHECK (\n    public.app_current_user_id() IS NOT NULL\n    AND owner_id = public.app_current_user_id()\n);\n\nCREATE POLICY channels_update_owner\nON public.channels\nFOR UPDATE\nTO PUBLIC\nUSING (public.is_channel_owner(id, public.app_current_user_id()))\nWITH CHECK (owner_id = public.app_current_user_id());\n\nCREATE POLICY channels_delete_owner\nON public.channels\nFOR DELETE\nTO PUBLIC\nUSING (public.is_channel_owner(id, public.app_current_user_id()));\n\n-- Channel moderators: moderator lists are visible for accessible channels;\n-- only owners add moderators; owners remove anyone and moderators remove self.\nCREATE POLICY channel_moderators_select_accessible_channel\nON public.channel_moderators\nFOR SELECT\nTO PUBLIC\nUSING (public.can_access_channel(channel_id, public.app_current_user_id()));\n\nCREATE POLICY channel_moderators_insert_channel_owner\nON public.channel_moderators\nFOR INSERT\nTO PUBLIC\nWITH CHECK (public.is_channel_owner(channel_id, public.app_current_user_id()));\n\nCREATE POLICY channel_moderators_update_none\nON public.channel_moderators\nFOR UPDATE\nTO PUBLIC\nUSING (false)\nWITH CHECK (false);\n\nCREATE POLICY channel_moderators_delete_owner_or_self\nON public.channel_moderators\nFOR DELETE\nTO PUBLIC\nUSING (\n    public.is_channel_owner(channel_id, public.app_current_user_id())\n    OR user_id = public.app_current_user_id()\n);\n\n-- Posts: visibility follows channel access only. Authors and channel moderation\n-- hierarchy can edit/delete; authenticated users create posts as themselves.\nCREATE POLICY posts_select_accessible_channels\nON public.posts\nFOR SELECT\nTO PUBLIC\nUSING (public.can_access_channel(channel_id, public.app_current_user_id()));\n\nCREATE POLICY posts_insert_authenticated_author\nON public.posts\nFOR INSERT\nTO PUBLIC\nWITH CHECK (\n    public.app_current_user_id() IS NOT NULL\n    AND author_id = public.app_current_user_id()\n    AND channel_id IS NOT NULL\n);\n\nCREATE POLICY posts_update_author_or_moderator\nON public.posts\nFOR UPDATE\nTO PUBLIC\nUSING (\n    author_id = public.app_current_user_id()\n    OR public.can_moderate_channel(channel_id, public.app_current_user_id())\n)\nWITH CHECK (\n    author_id = public.app_current_user_id()\n    OR public.can_moderate_channel(channel_id, public.app_current_user_id())\n);\n\nCREATE POLICY posts_delete_author_or_moderator\nON public.posts\nFOR DELETE\nTO PUBLIC\nUSING (\n    author_id = public.app_current_user_id()\n    OR public.can_moderate_channel(channel_id, public.app_current_user_id())\n);\n\n-- Comments: visibility follows the post's channel access only. Comment authors,\n-- post authors, and the channel moderation hierarchy can edit/delete.\nCREATE POLICY comments_select_accessible_posts\nON public.comments\nFOR SELECT\nTO PUBLIC\nUSING (public.can_access_post(post_id, public.app_current_user_id()));\n\nCREATE POLICY comments_insert_authenticated_visible_post\nON public.comments\nFOR INSERT\nTO PUBLIC\nWITH CHECK (\n    public.app_current_user_id() IS NOT NULL\n    AND author_id = public.app_current_user_id()\n    AND public.can_access_post(post_id, public.app_current_user_id())\n);\n\nCREATE POLICY comments_update_author_post_author_or_moderator\nON public.comments\nFOR UPDATE\nTO PUBLIC\nUSING (\n    author_id = public.app_current_user_id()\n    OR public.can_manage_post(post_id, public.app_current_user_id())\n)\nWITH CHECK (\n    author_id = public.app_current_user_id()\n    OR public.can_manage_post(post_id, public.app_current_user_id())\n);\n\nCREATE POLICY comments_delete_author_post_author_or_moderator\nON public.comments\nFOR DELETE\nTO PUBLIC\nUSING (\n    author_id = public.app_current_user_id()\n    OR public.can_manage_post(post_id, public.app_current_user_id())\n);\n\n-- Privileges for application roles. RLS still enforces row-level access; user\n-- profile SELECT is column-limited to public profile fields plus id.\nGRANT USAGE ON SCHEMA public TO PUBLIC;\n\nREVOKE ALL ON public.users FROM PUBLIC;\nGRANT SELECT (id, username, created_at) ON public.users TO PUBLIC;\nGRANT INSERT (id, username, email, is_public) ON public.users TO PUBLIC;\nGRANT UPDATE (username, email, is_public) ON public.users TO PUBLIC;\nGRANT DELETE ON public.users TO PUBLIC;\n\nGRANT SELECT, INSERT, DELETE ON public.channels TO PUBLIC;\nGRANT UPDATE (name, description, is_public) ON public.channels TO PUBLIC;\n\nGRANT SELECT, INSERT, DELETE ON public.channel_moderators TO PUBLIC;\n\nGRANT SELECT, INSERT, DELETE ON public.posts TO PUBLIC;\nGRANT UPDATE (title, content, updated_at) ON public.posts TO PUBLIC;\n\nGRANT SELECT, INSERT, DELETE ON public.comments TO PUBLIC;\nGRANT UPDATE (content, updated_at) ON public.comments TO PUBLIC;\n\nCOMMIT;"
