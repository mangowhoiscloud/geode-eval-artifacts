  {
    "tool": "execute_sql",
    "input": {
      "sql": "DROP TABLE IF EXISTS public.baseball_player_analysis;\n\nCREATE TABLE public.baseball_player_analysis (\n    player_id INTEGER NOT NULL,\n    player_name VARCHAR(255) NOT NULL,\n    team_name VARCHAR(255),\n    games_played INTEGER,\n    at_bats INTEGER,\n    hits INTEGER,\n    runs_scored INTEGER,\n    rbi INTEGER,\n    home_runs INTEGER,\n    batting_average DECIMAL,\n    defensive_games INTEGER,\n    putouts INTEGER,\n    assists INTEGER,\n    errors INTEGER,\n    fielding_percentage DECIMAL\n);\n\nWITH offense_by_season AS (\n    SELECT\n        s.stat_holder_id AS player_id,\n        s.stat_coverage_id AS sub_season_id,\n        SUM(COALESCE(bos.at_bats, 0))::INTEGER AS at_bats,\n        SUM(COALESCE(bos.hits, 0))::INTEGER AS hits,\n        SUM(COALESCE(bos.runs_scored, 0))::INTEGER AS runs_scored,\n        SUM(COALESCE(bos.rbi, 0))::INTEGER AS rbi,\n        SUM(COALESCE(bos.home_runs, 0))::INTEGER AS home_runs\n    FROM public.stats s\n    JOIN public.baseball_offensive_stats bos\n      ON bos.id = s.stat_repository_id\n    JOIN public.sub_seasons ss\n      ON ss.id = s.stat_coverage_id\n    WHERE s.stat_repository_type = 'baseball_offensive_stats'\n      AND s.stat_holder_type = 'persons'\n      AND s.stat_coverage_type = 'sub_seasons'\n      AND s.context = 'season-regular'\n      AND ss.sub_season_type = 'season-regular'\n    GROUP BY s.stat_holder_id, s.stat_coverage_id\n),\ncore_by_season AS (\n    SELECT\n        s.stat_holder_id AS player_id,\n        s.stat_coverage_id AS sub_season_id,\n        SUM(COALESCE(cps.events_played, 0))::INTEGER AS games_played\n    FROM public.stats s\n    JOIN public.core_person_stats cps\n      ON cps.id = s.stat_repository_id\n    JOIN public.sub_seasons ss\n      ON ss.id = s.stat_coverage_id\n    WHERE s.stat_repository_type = 'core_person_stats'\n      AND s.stat_holder_type = 'persons'\n      AND s.stat_coverage_type = 'sub_seasons'\n      AND s.context = 'season-regular'\n      AND ss.sub_season_type = 'season-regular'\n    GROUP BY s.stat_holder_id, s.stat_coverage_id\n),\ndefense_by_season AS (\n    SELECT\n        s.stat_holder_id AS player_id,\n        s.stat_coverage_id AS sub_season_id,\n        SUM(COALESCE(bds.putouts, 0))::INTEGER AS putouts,\n        SUM(COALESCE(bds.assists, 0))::INTEGER AS assists,\n        SUM(COALESCE(bds.errors, 0))::INTEGER AS errors\n    FROM public.stats s\n    JOIN public.baseball_defensive_stats bds\n      ON bds.id = s.stat_repository_id\n    JOIN public.sub_seasons ss\n      ON ss.id = s.stat_coverage_id\n    WHERE s.stat_repository_type = 'baseball_defensive_stats'\n      AND s.stat_holder_type = 'persons'\n      AND s.stat_coverage_type = 'sub_seasons'\n      AND s.context = 'season-regular'\n      AND ss.sub_season_type = 'season-regular'\n    GROUP BY s.stat_holder_id, s.stat_coverage_id\n),\nplayer_rollup AS (\n    SELECT\n        o.player_id,\n        SUM(COALESCE(c.games_played, 0))::INTEGER AS games_played,\n        SUM(COALESCE(o.at_bats, 0))::INTEGER AS at_bats,\n        SUM(COALESCE(o.hits, 0))::INTEGER AS hits,\n        SUM(COALESCE(o.runs_scored, 0))::INTEGER AS runs_scored,\n        SUM(COALESCE(o.rbi, 0))::INTEGER AS rbi,\n        SUM(COALESCE(o.home_runs, 0))::INTEGER AS home_runs,\n        SUM(COALESCE(d.putouts, 0))::INTEGER AS putouts,\n        SUM(COALESCE(d.assists, 0))::INTEGER AS assists,\n        SUM(COALESCE(d.errors, 0))::INTEGER AS errors\n    FROM offense_by_season o\n    LEFT JOIN core_by_season c\n      ON c.player_id = o.player_id\n     AND c.sub_season_id = o.sub_season_id\n    LEFT JOIN defense_by_season d\n      ON d.player_id = o.player_id\n     AND d.sub_season_id = o.sub_season_id\n    GROUP BY o.player_id\n)\nINSERT INTO public.baseball_player_analysis (\n    player_id,\n    player_name,\n    team_name,\n    games_played,\n    at_bats,\n    hits,\n    runs_scored,\n    rbi,\n    home_runs,\n    batting_average,\n    defensive_games,\n    putouts,\n    assists,\n    errors,\n    fielding_percentage\n)\nSELECT\n    pr.player_id,\n    dn.full_name::VARCHAR(255) AS player_name,\n    'Unknown'::VARCHAR(255) AS team_name,\n    pr.games_played,\n    pr.at_bats,\n    pr.hits,\n    pr.runs_scored,\n    pr.rbi,\n    pr.home_runs,\n    CASE\n        WHEN pr.at_bats = 0 THEN 0::DECIMAL\n        ELSE pr.hits::DECIMAL / pr.at_bats\n    END AS batting_average,\n    pr.games_played AS defensive_games,\n    pr.putouts,\n    pr.assists,\n    pr.errors,\n    CASE\n        WHEN (pr.putouts + pr.assists + pr.errors) = 0 THEN 0::DECIMAL\n        ELSE (pr.putouts + pr.assists)::DECIMAL / (pr.putouts + pr.assists + pr.errors)\n    END AS fielding_percentage\nFROM player_rollup pr\nJOIN public.persons p\n  ON p.id = pr.player_id\nJOIN public.display_names dn\n  ON dn.entity_type = 'persons'\n AND dn.entity_id = pr.player_id\n AND dn.language = 'en-US'\nWHERE pr.games_played >= 10\n  AND pr.at_bats >= 50\n  AND NULLIF(BTRIM(dn.full_name), '') IS NOT NULL\nORDER BY batting_average DESC, games_played DESC;\n\nSELECT\n    COUNT(*) AS row_count,\n    COUNT(*) FILTER (WHERE player_id IS NULL) AS null_player_id_count,\n    COUNT(*) FILTER (WHERE player_name IS NULL OR BTRIM(player_name) = '') AS invalid_player_name_count,\n    COUNT(*) FILTER (WHERE team_name <> 'Unknown') AS non_unknown_team_count,\n    COUNT(*) FILTER (WHERE games_played < 10) AS games_under_10_count,\n    COUNT(*) FILTER (WHERE at_bats < 50) AS at_bats_under_50_count,\n    COUNT(*) FILTER (WHERE defensive_games IS DISTINCT FROM games_played) AS defensive_games_mismatch_count,\n    MIN(games_played) AS min_games_played,\n    MIN(at_bats) AS min_at_bats,\n    MAX(batting_average) AS max_batting_average\nFROM public.baseball_player_analysis;"
    },
