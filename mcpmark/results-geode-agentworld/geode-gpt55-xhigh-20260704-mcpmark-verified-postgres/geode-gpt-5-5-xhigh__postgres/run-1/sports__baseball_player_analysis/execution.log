      "sql": "SELECT 'offensive' AS stat_type, COUNT(*) AS rows, COUNT(DISTINCT (s.stat_holder_id, s.stat_coverage_id)) AS distinct_player_seasons\nFROM public.stats s\nJOIN public.baseball_offensive_stats bos ON bos.id = s.stat_repository_id\nJOIN public.sub_seasons ss ON ss.id = s.stat_coverage_id\nWHERE s.stat_repository_type = 'baseball_offensive_stats'\n  AND s.stat_holder_type = 'persons'\n  AND s.stat_coverage_type = 'sub_seasons'\n  AND s.context = 'season-regular'\n  AND ss.sub_season_type = 'season-regular'\nUNION ALL\nSELECT 'defensive' AS stat_type, COUNT(*) AS rows, COUNT(DISTINCT (s.stat_holder_id, s.stat_coverage_id)) AS distinct_player_seasons\nFROM public.stats s\nJOIN public.baseball_defensive_stats bds ON bds.id = s.stat_repository_id\nJOIN public.sub_seasons ss ON ss.id = s.stat_coverage_id\nWHERE s.stat_repository_type = 'baseball_defensive_stats'\n  AND s.stat_holder_type = 'persons'\n  AND s.stat_coverage_type = 'sub_seasons'\n  AND s.context = 'season-regular'\n  AND ss.sub_season_type = 'season-regular';"
