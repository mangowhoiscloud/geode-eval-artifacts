  {
    "tool": "execute_sql",
    "input": {
      "sql": "DROP TABLE IF EXISTS public.customer_analysis_fixed;\n\nCREATE TABLE public.customer_analysis_fixed AS\nWITH valid_customers AS (\n    SELECT c.*\n    FROM public.customer c\n    WHERE c.email IS NOT NULL\n      AND c.email ~* '^[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}$'\n),\nrental_payments AS (\n    SELECT\n        p.rental_id,\n        SUM(p.amount) AS rental_amount\n    FROM public.payment p\n    GROUP BY p.rental_id\n),\npaid_rentals AS (\n    SELECT\n        r.rental_id,\n        r.rental_date,\n        r.inventory_id,\n        r.customer_id,\n        r.return_date,\n        rp.rental_amount\n    FROM public.rental r\n    JOIN rental_payments rp ON rp.rental_id = r.rental_id\n),\ncustomer_basic_stats AS (\n    SELECT\n        c.customer_id,\n        c.first_name || ' ' || c.last_name AS customer_name,\n        ci.city AS customer_city,\n        co.country AS customer_country,\n        COUNT(pr.rental_id) AS total_rentals,\n        COUNT(DISTINCT i.film_id) AS unique_films,\n        SUM(pr.rental_amount) AS total_spent,\n        AVG(EXTRACT(epoch FROM (pr.return_date - pr.rental_date)) / 86400.0) AS avg_rental_duration\n    FROM valid_customers c\n    JOIN public.address a ON c.address_id = a.address_id\n    JOIN public.city ci ON a.city_id = ci.city_id\n    JOIN public.country co ON ci.country_id = co.country_id\n    JOIN paid_rentals pr ON c.customer_id = pr.customer_id\n    JOIN public.inventory i ON pr.inventory_id = i.inventory_id\n    GROUP BY c.customer_id, c.first_name, c.last_name, ci.city, co.country\n    HAVING COUNT(pr.rental_id) >= 15\n),\ncustomer_categories AS (\n    SELECT\n        pr.customer_id,\n        cat.name AS category_name,\n        COUNT(*) AS category_count,\n        ROW_NUMBER() OVER (PARTITION BY pr.customer_id ORDER BY COUNT(*) DESC, cat.name ASC) AS rn\n    FROM paid_rentals pr\n    JOIN valid_customers c ON pr.customer_id = c.customer_id\n    JOIN public.inventory i ON pr.inventory_id = i.inventory_id\n    JOIN public.film f ON i.film_id = f.film_id\n    JOIN public.film_category fc ON f.film_id = fc.film_id\n    JOIN public.category cat ON fc.category_id = cat.category_id\n    GROUP BY pr.customer_id, cat.name\n),\ncustomer_actors AS (\n    SELECT\n        pr.customer_id,\n        a.first_name || ' ' || a.last_name AS actor_name,\n        COUNT(*) AS actor_count,\n        ROW_NUMBER() OVER (PARTITION BY pr.customer_id ORDER BY COUNT(*) DESC, (a.first_name || ' ' || a.last_name) ASC) AS rn\n    FROM paid_rentals pr\n    JOIN valid_customers c ON pr.customer_id = c.customer_id\n    JOIN public.inventory i ON pr.inventory_id = i.inventory_id\n    JOIN public.film f ON i.film_id = f.film_id\n    JOIN public.film_actor fa ON f.film_id = fa.film_id\n    JOIN public.actor a ON fa.actor_id = a.actor_id\n    GROUP BY pr.customer_id, a.first_name, a.last_name\n),\nregional_popular_films AS (\n    SELECT\n        co.country,\n        f.title,\n        COUNT(*) AS rental_count,\n        ROW_NUMBER() OVER (PARTITION BY co.country ORDER BY COUNT(*) DESC, f.title ASC) AS rn\n    FROM paid_rentals pr\n    JOIN public.inventory i ON pr.inventory_id = i.inventory_id\n    JOIN public.film f ON i.film_id = f.film_id\n    JOIN valid_customers c ON pr.customer_id = c.customer_id\n    JOIN public.address a ON c.address_id = a.address_id\n    JOIN public.city ci ON a.city_id = ci.city_id\n    JOIN public.country co ON ci.country_id = co.country_id\n    GROUP BY co.country, f.title\n)\nSELECT\n    cbs.customer_id,\n    cbs.customer_name,\n    cbs.customer_city,\n    cbs.customer_country,\n    cbs.total_rentals,\n    cbs.unique_films,\n    cbs.total_spent,\n    cc.category_name AS favorite_category,\n    ca.actor_name AS favorite_actor,\n    cbs.avg_rental_duration,\n    CASE\n        WHEN cbs.total_spent >= 150 THEN 'Premium'\n        WHEN cbs.total_spent >= 75 THEN 'Standard'\n        ELSE 'Basic'\n    END AS customer_tier,\n    rpf.title AS most_popular_film_in_region,\n    rpf.rental_count AS regional_film_rental_count\nFROM customer_basic_stats cbs\nLEFT JOIN customer_categories cc ON cbs.customer_id = cc.customer_id AND cc.rn = 1\nLEFT JOIN customer_actors ca ON cbs.customer_id = ca.customer_id AND ca.rn = 1\nLEFT JOIN regional_popular_films rpf ON cbs.customer_country = rpf.country AND rpf.rn = 1\nORDER BY cbs.total_spent DESC, cbs.total_rentals DESC, cbs.customer_name ASC;"
    },
