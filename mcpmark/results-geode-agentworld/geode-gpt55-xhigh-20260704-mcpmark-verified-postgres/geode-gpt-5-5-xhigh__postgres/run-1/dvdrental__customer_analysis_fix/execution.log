    "input": {
      "sql": "SELECT COUNT(*) AS payment_rows, COUNT(DISTINCT rental_id) AS paid_rentals, COUNT(*) - COUNT(DISTINCT rental_id) AS extra_payment_rows FROM public.payment;\nSELECT rental_id, COUNT(*) AS payment_count, SUM(amount) AS total_amount FROM public.payment GROUP BY rental_id HAVING COUNT(*) > 1 ORDER BY payment_count DESC, rental_id LIMIT 10;\nSELECT COUNT(*) AS customers_total,\n       COUNT(*) FILTER (WHERE email IS NULL) AS email_null,\n       COUNT(*) FILTER (WHERE email IS NOT NULL AND email !~* '^[A-Z0-9._%+\\-]+@[A-Z0-9.\\-]+\\.[A-Z]{2,}$') AS email_invalid_regex\nFROM public.customer;\nSELECT customer_id, email FROM public.customer WHERE email IS NULL OR email !~* '^[A-Z0-9._%+\\-]+@[A-Z0-9.\\-]+\\.[A-Z]{2,}$' ORDER BY customer_id LIMIT 20;"
