      "sql": "SELECT json_build_object(\n  'payment_rows', COUNT(*),\n  'paid_rentals', COUNT(DISTINCT rental_id),\n  'extra_payment_rows', COUNT(*) - COUNT(DISTINCT rental_id),\n  'rentals_with_multiple_payments', COUNT(*) FILTER (WHERE cnt > 1)\n) AS payment_summary\nFROM (\n  SELECT rental_id, COUNT(*) AS cnt\n  FROM public.payment\n  GROUP BY rental_id\n) x\nJOIN public.payment p USING (rental_id);\n"
