: 'gender', 'data_type': 'USER-DEFINED', 'is_nullable': 'NO', 'default': None}, {'column': 'hire_date', 'data_type': 'date', 'is_nullable': 'NO', 'default': None}], 'constraints': [{'name': 'idx_16988_primary', 'type': 'PRIMARY KEY', 'columns': ['id']}, {'name': '16385_16400_1_not_null', 'type': 'CHECK', 'columns': []}, {'name': '16385_16400_2_not_null', 'type': 'CHECK', 'columns': []}, {'name': '16385_16400_3_not_null', 'type': 'CHECK', 'columns': []}, {'name': '16385_16400_4_not_null', 'type': 'CHECK', 'columns': []}, {'name': '16385_16400_5_not_null', 'type': 'CHECK', 'columns': []}, {'name': '16385_16400_6_not_null', 'type': 'CHECK', 'columns': []}], 'indexes': [{'name': 'idx_16988_primary', 'definition': 'CREATE UNIQUE INDEX idx_16988_primary ON employees.employee USING btree (id)'}]}\", \"annotations\": null, \"_meta\": null}]}, \"isError\": false}"
