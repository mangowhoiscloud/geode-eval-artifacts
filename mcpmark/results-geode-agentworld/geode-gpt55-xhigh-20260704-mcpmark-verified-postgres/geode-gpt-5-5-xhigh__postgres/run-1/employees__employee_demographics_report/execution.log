  {
    "tool": "execute_sql",
    "input": {
      "sql": "BEGIN;\n\nDROP TABLE IF EXISTS employees.gender_statistics;\nDROP TABLE IF EXISTS employees.age_group_analysis;\nDROP TABLE IF EXISTS employees.birth_month_distribution;\nDROP TABLE IF EXISTS employees.hiring_year_summary;\n\nCREATE TABLE employees.gender_statistics (\n    gender varchar,\n    total_employees integer,\n    current_employees integer,\n    percentage_of_workforce decimal\n);\n\nCREATE TABLE employees.age_group_analysis (\n    age_group varchar,\n    employee_count integer,\n    avg_salary decimal,\n    avg_tenure_days decimal\n);\n\nCREATE TABLE employees.birth_month_distribution (\n    birth_month integer,\n    month_name varchar,\n    employee_count integer,\n    current_employee_count integer\n);\n\nCREATE TABLE employees.hiring_year_summary (\n    hire_year integer,\n    employees_hired integer,\n    still_employed integer,\n    retention_rate decimal\n);\n\nWITH current_employees AS (\n    SELECT DISTINCT employee_id\n    FROM employees.salary\n    WHERE to_date = DATE '9999-01-01'\n),\ncurrent_workforce AS (\n    SELECT COUNT(*)::decimal AS total_current\n    FROM current_employees\n),\ngender_counts AS (\n    SELECT\n        e.gender::varchar AS gender,\n        COUNT(*)::integer AS total_employees,\n        COUNT(ce.employee_id)::integer AS current_employees\n    FROM employees.employee e\n    LEFT JOIN current_employees ce ON ce.employee_id = e.id\n    GROUP BY e.gender::varchar\n)\nINSERT INTO employees.gender_statistics (\n    gender,\n    total_employees,\n    current_employees,\n    percentage_of_workforce\n)\nSELECT\n    gc.gender,\n    gc.total_employees,\n    gc.current_employees,\n    CASE\n        WHEN cw.total_current = 0 THEN 0::decimal\n        ELSE (gc.current_employees::decimal / cw.total_current) * 100\n    END AS percentage_of_workforce\nFROM gender_counts gc\nCROSS JOIN current_workforce cw\nORDER BY gc.gender;\n\nWITH current_salary AS (\n    SELECT employee_id, amount\n    FROM employees.salary\n    WHERE to_date = DATE '9999-01-01'\n),\ncurrent_employee_ages AS (\n    SELECT\n        e.id,\n        cs.amount,\n        (DATE '2002-08-01' - e.hire_date)::integer AS tenure_days,\n        EXTRACT(YEAR FROM age(DATE '2002-08-01', e.birth_date))::integer AS age_years\n    FROM employees.employee e\n    INNER JOIN current_salary cs ON cs.employee_id = e.id\n),\nclassified AS (\n    SELECT\n        CASE\n            WHEN age_years BETWEEN 20 AND 29 THEN '20-29'\n            WHEN age_years BETWEEN 30 AND 39 THEN '30-39'\n            WHEN age_years BETWEEN 40 AND 49 THEN '40-49'\n            WHEN age_years BETWEEN 50 AND 59 THEN '50-59'\n            WHEN age_years >= 60 THEN '60+'\n        END AS age_group,\n        amount,\n        tenure_days\n    FROM current_employee_ages\n)\nINSERT INTO employees.age_group_analysis (\n    age_group,\n    employee_count,\n    avg_salary,\n    avg_tenure_days\n)\nSELECT\n    age_group,\n    COUNT(*)::integer AS employee_count,\n    AVG(amount)::decimal AS avg_salary,\n    AVG(tenure_days)::decimal AS avg_tenure_days\nFROM classified\nWHERE age_group IS NOT NULL\nGROUP BY age_group\nORDER BY CASE age_group\n    WHEN '20-29' THEN 1\n    WHEN '30-39' THEN 2\n    WHEN '40-49' THEN 3\n    WHEN '50-59' THEN 4\n    WHEN '60+' THEN 5\nEND;\n\nWITH months AS (\n    SELECT generate_series(1, 12)::integer AS birth_month\n),\ncurrent_employees AS (\n    SELECT DISTINCT employee_id\n    FROM employees.salary\n    WHERE to_date = DATE '9999-01-01'\n),\nmonth_counts AS (\n    SELECT\n        EXTRACT(MONTH FROM e.birth_date)::integer AS birth_month,\n        COUNT(*)::integer AS employee_count,\n        COUNT(ce.employee_id)::integer AS current_employee_count\n    FROM employees.employee e\n    LEFT JOIN current_employees ce ON ce.employee_id = e.id\n    GROUP BY EXTRACT(MONTH FROM e.birth_date)::integer\n)\nINSERT INTO employees.birth_month_distribution (\n    birth_month,\n    month_name,\n    employee_count,\n    current_employee_count\n)\nSELECT\n    m.birth_month,\n    to_char(to_date(m.birth_month::text, 'MM'), 'FMMonth')::varchar AS month_name,\n    COALESCE(mc.employee_count, 0)::integer AS employee_count,\n    COALESCE(mc.current_employee_count, 0)::integer AS current_employee_count\nFROM months m\nLEFT JOIN month_counts mc ON mc.birth_month = m.birth_month\nORDER BY m.birth_month;\n\nWITH current_employees AS (\n    SELECT DISTINCT employee_id\n    FROM employees.salary\n    WHERE to_date = DATE '9999-01-01'\n),\nhiring_counts AS (\n    SELECT\n        EXTRACT(YEAR FROM e.hire_date)::integer AS hire_year,\n        COUNT(*)::integer AS employees_hired,\n        COUNT(ce.employee_id)::integer AS still_employed\n    FROM employees.employee e\n    LEFT JOIN current_employees ce ON ce.employee_id = e.id\n    GROUP BY EXTRACT(YEAR FROM e.hire_date)::integer\n)\nINSERT INTO employees.hiring_year_summary (\n    hire_year,\n    employees_hired,\n    still_employed,\n    retention_rate\n)\nSELECT\n    hire_year,\n    employees_hired,\n    still_employed,\n    CASE\n        WHEN employees_hired = 0 THEN 0::decimal\n        ELSE (still_employed::decimal / employees_hired::decimal) * 100\n    END AS retention_rate\nFROM hiring_counts\nORDER BY hire_year;\n\nCOMMIT;\n\nSELECT 'gender_statistics' AS table_name, COUNT(*)::integer AS rows_created FROM employees.gender_statistics\nUNION ALL\nSELECT 'age_group_analysis', COUNT(*)::integer FROM employees.age_group_analysis\nUNION ALL\nSELECT 'birth_month_distribution', COUNT(*)::integer FROM employees.birth_month_distribution\nUNION ALL\nSELECT 'hiring_year_summary', COUNT(*)::integer FROM employees.hiring_year_summary\nORDER BY table_name;"
    },
