  {
    "tool": "execute_sql",
    "input": {
      "sql": "BEGIN;\n\nCREATE TABLE public.monthly_sales_summary (\n    year_month varchar,\n    total_invoices integer,\n    total_revenue decimal,\n    total_tracks_sold integer,\n    average_invoice_value decimal,\n    unique_customers integer\n);\n\nCREATE TABLE public.top_music_charts (\n    chart_type varchar,\n    rank_position integer,\n    item_id integer,\n    item_name varchar,\n    total_revenue decimal\n);\n\nWITH invoice_monthly AS (\n    SELECT\n        to_char(\"InvoiceDate\", 'YYYY-MM') AS year_month,\n        COUNT(*)::integer AS total_invoices,\n        SUM(\"Total\") AS total_revenue,\n        AVG(\"Total\") AS average_invoice_value,\n        COUNT(DISTINCT \"CustomerId\")::integer AS unique_customers\n    FROM public.\"Invoice\"\n    GROUP BY to_char(\"InvoiceDate\", 'YYYY-MM')\n), tracks_monthly AS (\n    SELECT\n        to_char(i.\"InvoiceDate\", 'YYYY-MM') AS year_month,\n        SUM(il.\"Quantity\")::integer AS total_tracks_sold\n    FROM public.\"Invoice\" i\n    JOIN public.\"InvoiceLine\" il ON il.\"InvoiceId\" = i.\"InvoiceId\"\n    GROUP BY to_char(i.\"InvoiceDate\", 'YYYY-MM')\n)\nINSERT INTO public.monthly_sales_summary (\n    year_month,\n    total_invoices,\n    total_revenue,\n    total_tracks_sold,\n    average_invoice_value,\n    unique_customers\n)\nSELECT\n    im.year_month,\n    im.total_invoices,\n    im.total_revenue,\n    COALESCE(tm.total_tracks_sold, 0)::integer AS total_tracks_sold,\n    im.average_invoice_value,\n    im.unique_customers\nFROM invoice_monthly im\nLEFT JOIN tracks_monthly tm ON tm.year_month = im.year_month\nORDER BY im.year_month;\n\nWITH track_sales AS (\n    SELECT\n        t.\"TrackId\" AS item_id,\n        t.\"Name\" AS item_name,\n        SUM(il.\"Quantity\") AS total_quantity,\n        SUM(il.\"UnitPrice\" * il.\"Quantity\") AS total_revenue\n    FROM public.\"InvoiceLine\" il\n    JOIN public.\"Track\" t ON t.\"TrackId\" = il.\"TrackId\"\n    GROUP BY t.\"TrackId\", t.\"Name\"\n    HAVING SUM(il.\"Quantity\") > 0\n), ranked_tracks AS (\n    SELECT\n        'top_tracks'::varchar AS chart_type,\n        ROW_NUMBER() OVER (ORDER BY total_quantity DESC, item_name ASC) AS rank_position,\n        item_id,\n        item_name,\n        total_revenue\n    FROM track_sales\n), album_sales AS (\n    SELECT\n        a.\"AlbumId\" AS item_id,\n        a.\"Title\" AS item_name,\n        SUM(il.\"UnitPrice\" * il.\"Quantity\") AS total_revenue\n    FROM public.\"InvoiceLine\" il\n    JOIN public.\"Track\" t ON t.\"TrackId\" = il.\"TrackId\"\n    JOIN public.\"Album\" a ON a.\"AlbumId\" = t.\"AlbumId\"\n    GROUP BY a.\"AlbumId\", a.\"Title\"\n    HAVING SUM(il.\"UnitPrice\" * il.\"Quantity\") > 0\n), ranked_albums AS (\n    SELECT\n        'top_albums'::varchar AS chart_type,\n        ROW_NUMBER() OVER (ORDER BY total_revenue DESC, item_name ASC) AS rank_position,\n        item_id,\n        item_name,\n        total_revenue\n    FROM album_sales\n), artist_sales AS (\n    SELECT\n        ar.\"ArtistId\" AS item_id,\n        ar.\"Name\" AS item_name,\n        SUM(il.\"UnitPrice\" * il.\"Quantity\") AS total_revenue\n    FROM public.\"InvoiceLine\" il\n    JOIN public.\"Track\" t ON t.\"TrackId\" = il.\"TrackId\"\n    JOIN public.\"Album\" a ON a.\"AlbumId\" = t.\"AlbumId\"\n    JOIN public.\"Artist\" ar ON ar.\"ArtistId\" = a.\"ArtistId\"\n    GROUP BY ar.\"ArtistId\", ar.\"Name\"\n    HAVING SUM(il.\"UnitPrice\" * il.\"Quantity\") > 0\n), ranked_artists AS (\n    SELECT\n        'top_artists'::varchar AS chart_type,\n        ROW_NUMBER() OVER (ORDER BY total_revenue DESC, item_name ASC NULLS LAST) AS rank_position,\n        item_id,\n        item_name,\n        total_revenue\n    FROM artist_sales\n)\nINSERT INTO public.top_music_charts (\n    chart_type,\n    rank_position,\n    item_id,\n    item_name,\n    total_revenue\n)\nSELECT chart_type, rank_position::integer, item_id, item_name, total_revenue\nFROM ranked_tracks\nWHERE rank_position <= 10\nUNION ALL\nSELECT chart_type, rank_position::integer, item_id, item_name, total_revenue\nFROM ranked_albums\nWHERE rank_position <= 10\nUNION ALL\nSELECT chart_type, rank_position::integer, item_id, item_name, total_revenue\nFROM ranked_artists\nWHERE rank_position <= 10\nORDER BY chart_type, rank_position;\n\nCOMMIT;\n\nSELECT\n    (SELECT COUNT(*) FROM public.monthly_sales_summary) AS monthly_rows,\n    (SELECT COUNT(*) FROM public.top_music_charts WHERE chart_type = 'top_tracks') AS top_track_rows,\n    (SELECT COUNT(*) FROM public.top_music_charts WHERE chart_type = 'top_albums') AS top_album_rows,\n    (SELECT COUNT(*) FROM public.top_music_charts WHERE chart_type = 'top_artists') AS top_artist_rows;"
