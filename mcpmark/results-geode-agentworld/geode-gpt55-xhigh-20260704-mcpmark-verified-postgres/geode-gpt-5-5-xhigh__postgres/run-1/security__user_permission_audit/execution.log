  {
    "tool": "execute_sql",
    "input": {
      "sql": "DROP TABLE IF EXISTS security_audit_details;\nDROP TABLE IF EXISTS security_audit_results;\n\nCREATE TABLE security_audit_results (\n    audit_id SERIAL PRIMARY KEY,\n    audit_type VARCHAR(50) NOT NULL,\n    total_issues INTEGER NOT NULL,\n    users_affected INTEGER NOT NULL,\n    tables_affected INTEGER NOT NULL\n);\n\nCREATE TABLE security_audit_details (\n    detail_id SERIAL PRIMARY KEY,\n    username VARCHAR(50) NOT NULL,\n    issue_type VARCHAR(50) NOT NULL,\n    table_name VARCHAR(50),\n    permission_type VARCHAR(20),\n    expected_access BOOLEAN NOT NULL\n);\n\nWITH\nexpected_users(username, business_role) AS (\n    VALUES\n    ('analytics_user', 'Analytics Team'),\n    ('marketing_user', 'Marketing Department'),\n    ('customer_service', 'Customer Service'),\n    ('finance_user', 'Finance Team'),\n    ('product_manager', 'Product Management'),\n    ('security_auditor', 'Security Team'),\n    ('developer_user', 'Development Team'),\n    ('backup_user', 'Backup Service')\n),\nrole_expected_permissions(business_role, table_name, privilege_type) AS (\n    VALUES\n    ('Analytics Team', 'user_profiles', 'SELECT'),\n    ('Analytics Team', 'user_stat_analysis', 'SELECT'),\n    ('Analytics Team', 'product_catalog', 'SELECT'),\n    ('Analytics Team', 'order_management', 'SELECT'),\n\n    ('Marketing Department', 'user_profiles', 'SELECT'),\n    ('Marketing Department', 'user_stat_analysis', 'SELECT'),\n    ('Marketing Department', 'product_catalog', 'SELECT'),\n\n    ('Customer Service', 'user_profiles', 'SELECT'),\n    ('Customer Service', 'user_profiles', 'UPDATE'),\n    ('Customer Service', 'order_management', 'SELECT'),\n    ('Customer Service', 'order_management', 'INSERT'),\n    ('Customer Service', 'order_management', 'UPDATE'),\n    ('Customer Service', 'product_catalog', 'SELECT'),\n\n    ('Finance Team', 'financial_transactions', 'SELECT'),\n    ('Finance Team', 'order_management', 'SELECT'),\n    ('Finance Team', 'user_profiles', 'SELECT'),\n\n    ('Product Management', 'product_catalog', 'SELECT'),\n    ('Product Management', 'product_catalog', 'INSERT'),\n    ('Product Management', 'product_catalog', 'UPDATE'),\n    ('Product Management', 'product_catalog', 'DELETE'),\n    ('Product Management', 'order_management', 'SELECT'),\n    ('Product Management', 'user_stat_analysis', 'SELECT'),\n\n    ('Security Team', 'audit_logs', 'SELECT'),\n    ('Security Team', 'user_credentials', 'SELECT'),\n    ('Security Team', 'user_profiles', 'SELECT'),\n\n    ('Development Team', 'user_profiles', 'SELECT'),\n    ('Development Team', 'product_catalog', 'SELECT'),\n\n    ('Backup Service', 'user_profiles', 'SELECT'),\n    ('Backup Service', 'product_catalog', 'SELECT'),\n    ('Backup Service', 'order_management', 'SELECT'),\n    ('Backup Service', 'financial_transactions', 'SELECT'),\n    ('Backup Service', 'user_stat_analysis', 'SELECT'),\n    ('Backup Service', 'audit_logs', 'SELECT'),\n    ('Backup Service', 'user_credentials', 'SELECT')\n),\nexpected_permissions AS (\n    SELECT eu.username::varchar(50), rep.table_name::varchar(50), rep.privilege_type::varchar(20)\n    FROM expected_users eu\n    JOIN role_expected_permissions rep ON rep.business_role = eu.business_role\n),\nbusiness_tables AS (\n    SELECT DISTINCT table_name FROM role_expected_permissions\n),\ncurrent_privileges AS (\n    SELECT DISTINCT\n           tp.grantee::varchar(50) AS username,\n           tp.table_name::varchar(50) AS table_name,\n           tp.privilege_type::varchar(20) AS privilege_type\n    FROM information_schema.table_privileges tp\n    JOIN business_tables bt ON bt.table_name = tp.table_name\n    JOIN pg_catalog.pg_roles r ON r.rolname = tp.grantee\n    WHERE tp.table_schema = 'public'\n      AND tp.privilege_type IN ('SELECT', 'INSERT', 'UPDATE', 'DELETE')\n      AND tp.grantee <> 'postgres'\n      AND tp.grantee !~ '^pg_'\n),\ndangling_users AS (\n    SELECT DISTINCT cp.username\n    FROM current_privileges cp\n    LEFT JOIN expected_users eu ON eu.username = cp.username\n    WHERE eu.username IS NULL\n),\nfindings AS (\n    SELECT du.username::varchar(50) AS username,\n           'DANGLING_USER'::varchar(50) AS issue_type,\n           NULL::varchar(50) AS table_name,\n           NULL::varchar(20) AS permission_type,\n           FALSE AS expected_access\n    FROM dangling_users du\n\n    UNION ALL\n\n    SELECT ep.username,\n           'MISSING_PERMISSION'::varchar(50) AS issue_type,\n           ep.table_name,\n           ep.privilege_type,\n           TRUE AS expected_access\n    FROM expected_permissions ep\n    LEFT JOIN current_privileges cp\n      ON cp.username = ep.username\n     AND cp.table_name = ep.table_name\n     AND cp.privilege_type = ep.privilege_type\n    WHERE cp.username IS NULL\n\n    UNION ALL\n\n    SELECT cp.username,\n           'EXCESSIVE_PERMISSION'::varchar(50) AS issue_type,\n           cp.table_name,\n           cp.privilege_type,\n           FALSE AS expected_access\n    FROM current_privileges cp\n    LEFT JOIN expected_permissions ep\n      ON ep.username = cp.username\n     AND ep.table_name = cp.table_name\n     AND ep.privilege_type = cp.privilege_type\n    WHERE ep.username IS NULL\n)\nINSERT INTO security_audit_details (username, issue_type, table_name, permission_type, expected_access)\nSELECT username, issue_type, table_name, permission_type, expected_access\nFROM findings\nORDER BY\n  CASE issue_type\n    WHEN 'DANGLING_USER' THEN 1\n    WHEN 'MISSING_PERMISSION' THEN 2\n    WHEN 'EXCESSIVE_PERMISSION' THEN 3\n    ELSE 4\n  END,\n  username,\n  table_name NULLS FIRST,\n  permission_type NULLS FIRST;\n\nWITH audit_types(audit_type, issue_type, sort_order) AS (\n    VALUES\n    ('DANGLING_USERS', 'DANGLING_USER', 1),\n    ('MISSING_PERMISSIONS', 'MISSING_PERMISSION', 2),\n    ('EXCESSIVE_PERMISSIONS', 'EXCESSIVE_PERMISSION', 3)\n),\nsummary AS (\n    SELECT at.audit_type,\n           at.sort_order,\n           COUNT(d.detail_id)::integer AS total_issues,\n           COUNT(DISTINCT d.username)::integer AS users_affected,\n           COUNT(DISTINCT d.table_name)::integer AS tables_affected\n    FROM audit_types at\n    LEFT JOIN security_audit_details d ON d.issue_type = at.issue_type\n    GROUP BY at.audit_type, at.sort_order\n)\nINSERT INTO security_audit_results (audit_type, total_issues, users_affected, tables_affected)\nSELECT audit_type, total_issues, users_affected, tables_affected\nFROM summary\nORDER BY sort_order;\n\nSELECT\n  (SELECT json_agg(row_to_json(r) ORDER BY r.audit_id) FROM security_audit_results r) AS summary,\n  (SELECT COUNT(*) FROM security_audit_details) AS detail_count,\n  (SELECT json_agg(row_to_json(d) ORDER BY\n      CASE d.issue_type\n        WHEN 'DANGLING_USER' THEN 1\n        WHEN 'MISSING_PERMISSION' THEN 2\n        WHEN 'EXCESSIVE_PERMISSION' THEN 3\n        ELSE 4\n      END,\n      d.username,\n      d.table_name NULLS FIRST,\n      d.permission_type NULLS FIRST)\n   FROM security_audit_details d) AS details;"
