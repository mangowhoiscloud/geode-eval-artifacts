200_16623_11_not_null', 'type': 'CHECK', 'columns': []}, {'name': '2200_16623_13_not_null', 'type': 'CHECK', 'columns': []}], 'indexes': [{'name': 'film_pkey', 'definition': 'CREATE UNIQUE INDEX film_pkey ON public.film USING btree (film_id)'}, {'name': 'film_fulltext_idx', 'definition': 'CREATE INDEX film_fulltext_idx ON public.film USING gist (fulltext)'}, {'name': 'idx_fk_language_id', 'definition': 'CREATE INDEX idx_fk_language_id ON public.film USING btree (language_id)'}, {'name': 'idx_title', 'definition': 'CREATE INDEX idx_title ON public.film USING btree (title)'}]}\", \"annotations\": null, \"meta\": null}], \"structuredContent\": {\"result\": [{\"type\": \"text\", \"text\": \"{'basic': {'schema': 'public', 'name': 'film', 'type': 'table'}, 'columns': [{'column': 'film_id', 'data_type': 'integer', 'is_nullable': 'NO', 'default': \\\"nextval('film_film_id_seq'::regclass)\\\"}, {'column': 'title', 'data_type': 'character varying', 'is_nullable': 'NO', 'default': None}, {'column': 'description', 'data_type': 'text', 'is_nullable': 'YES', 'default': None}, {'column': 'release_year', 'data_type': 'integer', 'is_nullable': 'YES', 'default': None}, {'column': 'language_id', 'data_type': 'smallint', 'is_nullable': 'NO', 'default': None}, {'column': 'rental_duration', 'data_type': 'smallint', 'is_nullable': 'NO', 'default': '3'}, {'column': 'rental_rate', 'data_type': 'numeric', 'is_nullable': 'NO', 'default': '4.99'}, {'column': 'length', 'data_type': 'smallint', 'is_nullable': 'YES', 'default': None}, {'column': 'replacement_cost', 'data_type': 'numeric', 'is_nullable': 'NO', 'default': '19.99'}, {'column': 'rating', 'data_type': 'USER-DEFINED', 'is_nullable': 'YES', 'default': \\\"'G'::mpaa_rating\\\"}, {'column': 'last_update', 'data_type': 'timestamp without time zone', 'is_nullable': 'NO', 'default': 'now()'}, {'column': 'special_features', 'data_type': 'ARRAY', 'is_nullable': 'YES', 'default': None}, {'column': 'fulltext', 'data_type': 'tsvector', 'is_nullab