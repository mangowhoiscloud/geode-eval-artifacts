  {
    "tool": "execute_sql",
    "input": {
      "sql": "DROP TABLE IF EXISTS employees.employee_performance_analysis;\n\nCREATE TABLE employees.employee_performance_analysis (\n    employee_id bigint,\n    performance_category varchar,\n    salary_growth_rate decimal,\n    days_of_service integer,\n    promotion_count integer\n);\n\nWITH first_salaries AS (\n    SELECT DISTINCT ON (employee_id)\n        employee_id,\n        amount AS first_salary\n    FROM employees.salary\n    ORDER BY employee_id, from_date ASC\n),\ncurrent_salaries AS (\n    SELECT\n        employee_id,\n        amount AS current_salary\n    FROM employees.salary\n    WHERE to_date = DATE '9999-01-01'\n),\ntitle_counts AS (\n    SELECT\n        employee_id,\n        COUNT(DISTINCT title)::integer AS promotion_count\n    FROM employees.title\n    GROUP BY employee_id\n),\nemployee_metrics AS (\n    SELECT\n        e.id AS employee_id,\n        ((cs.current_salary::decimal - fs.first_salary::decimal) * 100 / NULLIF(fs.first_salary::decimal, 0))::decimal AS salary_growth_rate,\n        (DATE '2026-07-04' - e.hire_date)::integer AS days_of_service,\n        COALESCE(tc.promotion_count, 0)::integer AS promotion_count\n    FROM current_salaries cs\n    JOIN employees.employee e\n        ON e.id = cs.employee_id\n    JOIN first_salaries fs\n        ON fs.employee_id = cs.employee_id\n    LEFT JOIN title_counts tc\n        ON tc.employee_id = cs.employee_id\n)\nINSERT INTO employees.employee_performance_analysis (\n    employee_id,\n    performance_category,\n    salary_growth_rate,\n    days_of_service,\n    promotion_count\n)\nSELECT\n    employee_id,\n    CASE\n        WHEN salary_growth_rate > 40 AND promotion_count > 1 THEN 'high_achiever'\n        WHEN salary_growth_rate < 15 AND days_of_service > 3650 THEN 'needs_attention'\n        ELSE 'steady_performer'\n    END AS performance_category,\n    salary_growth_rate,\n    days_of_service,\n    promotion_count\nFROM employee_metrics;\n\nDROP TABLE IF EXISTS employees.department_salary_analysis;\n\nCREATE TABLE employees.department_salary_analysis (\n    department_name varchar,\n    avg_current_salary decimal,\n    employee_count integer,\n    salary_range_spread integer\n);\n\nWITH current_salaries AS (\n    SELECT\n        employee_id,\n        amount AS current_salary\n    FROM employees.salary\n    WHERE to_date = DATE '9999-01-01'\n),\ncurrent_department_employees AS (\n    SELECT DISTINCT\n        employee_id,\n        department_id\n    FROM employees.department_employee\n    WHERE to_date = DATE '9999-01-01'\n)\nINSERT INTO employees.department_salary_analysis (\n    department_name,\n    avg_current_salary,\n    employee_count,\n    salary_range_spread\n)\nSELECT\n    d.dept_name AS department_name,\n    AVG(cs.current_salary::decimal) AS avg_current_salary,\n    COUNT(DISTINCT cde.employee_id)::integer AS employee_count,\n    (MAX(cs.current_salary) - MIN(cs.current_salary))::integer AS salary_range_spread\nFROM current_department_employees cde\nJOIN current_salaries cs\n    ON cs.employee_id = cde.employee_id\nJOIN employees.department d\n    ON d.id = cde.department_id\nGROUP BY d.dept_name;\n\nSELECT\n    (SELECT COUNT(*) FROM employees.employee_performance_analysis) AS employee_performance_rows,\n    (SELECT COUNT(*) FROM employees.department_salary_analysis) AS department_salary_rows;"
    },
    "result": {
