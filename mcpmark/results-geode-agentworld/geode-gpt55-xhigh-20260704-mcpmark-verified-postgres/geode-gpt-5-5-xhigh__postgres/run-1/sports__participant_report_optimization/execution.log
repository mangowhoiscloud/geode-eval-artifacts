  {
    "tool": "execute_sql",
    "input": {
      "sql": "WITH inserted AS (\n    INSERT INTO public.participant_performance_report (\n        participant_id,\n        event_count,\n        stat_count,\n        stat_type_count,\n        last_event_date\n    )\n    SELECT \n        pe.participant_id,\n        COUNT(pe.event_id)::integer AS event_count,\n        COALESCE((SELECT COUNT(*) FROM public.stats s WHERE s.stat_holder_id = pe.participant_id AND s.stat_holder_type = 'persons'), 0)::integer AS stat_count,\n        COALESCE((SELECT COUNT(DISTINCT s.stat_repository_type) FROM public.stats s WHERE s.stat_holder_id = pe.participant_id AND s.stat_holder_type = 'persons'), 0)::integer AS stat_type_count,\n        (SELECT MAX(e.start_date_time)\n         FROM public.events e\n         JOIN public.participants_events pe2 ON e.id = pe2.event_id\n         WHERE pe2.participant_id = pe.participant_id) AS last_event_date\n    FROM public.participants_events pe \n    WHERE pe.participant_id <= 50\n    GROUP BY pe.participant_id\n    ORDER BY pe.participant_id\n    RETURNING report_id\n)\nSELECT COUNT(*) AS inserted_rows,\n       (SELECT COUNT(*) FROM public.participant_performance_report) AS total_report_rows\nFROM inserted;"
