      "sql": "DROP TABLE IF EXISTS public.participant_performance_report;\n\nCREATE TABLE public.participant_performance_report (\n    report_id serial PRIMARY KEY,\n    participant_id integer NOT NULL,\n    event_count integer,\n    stat_count integer,\n    stat_type_count integer,\n    last_event_date timestamp,\n    created_at timestamp DEFAULT current_timestamp,\n    CONSTRAINT chk_participant_performance_report_participant_id_positive CHECK (participant_id > 0)\n);\n\nCREATE INDEX IF NOT EXISTS idx_pe_participant_event\n    ON public.participants_events (participant_id, event_id);\n\nCREATE INDEX IF NOT EXISTS idx_stats_persons_holder_repo\n    ON public.stats (stat_holder_id, stat_repository_type)\n    WHERE stat_holder_type = 'persons';\n\nCREATE INDEX IF NOT EXISTS idx_events_id_start_dt\n    ON public.events (id, start_date_time);\n\nANALYZE public.participants_events;\nANALYZE public.stats;\nANALYZE public.events;"
