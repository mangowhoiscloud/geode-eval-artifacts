    "input": {
      "sql": "WITH original_query AS (\n    SELECT \n        c.customer_id,\n        c.first_name,\n        c.last_name,\n        c.email,\n        COUNT(DISTINCT p.payment_id) as total_payments,\n        SUM(p.amount) as total_spent,\n        AVG(p.amount) as avg_payment,\n        COUNT(DISTINCT EXTRACT(month FROM p.payment_date)) as active_months,\n        MAX(p.payment_date) as last_payment,\n        MIN(p.payment_date) as first_payment,\n        (SELECT COUNT(*) FROM payment p2 WHERE p2.customer_id = c.customer_id AND p2.amount > 5.0) as high_value_payments,\n        (SELECT SUM(amount) FROM payment p3 WHERE p3.customer_id = c.customer_id AND p3.payment_date >= '2007-03-01') as recent_spending\n    FROM customer c\n    JOIN payment p ON c.customer_id = p.customer_id\n    WHERE c.active = 1\n    GROUP BY c.customer_id, c.first_name, c.last_name, c.email\n    HAVING COUNT(p.payment_id) >= 10\n), optimized_query AS (\n    WITH customer_payment_stats AS (\n        SELECT\n            p.customer_id,\n            COUNT(DISTINCT p.payment_id) AS total_payments,\n            SUM(p.amount) AS total_spent,\n            AVG(p.amount) AS avg_payment,\n            COUNT(DISTINCT EXTRACT(month FROM p.payment_date)) AS active_months,\n            MAX(p.payment_date) AS last_payment,\n            MIN(p.payment_date) AS first_payment,\n            COUNT(*) FILTER (WHERE p.amount > 5.0) AS high_value_payments,\n            SUM(p.amount) FILTER (WHERE p.payment_date >= '2007-03-01') AS recent_spending\n        FROM payment p\n        GROUP BY p.customer_id\n        HAVING COUNT(p.payment_id) >= 10\n    )\n    SELECT\n        c.customer_id,\n        c.first_name,\n        c.last_name,\n        c.email,\n        s.total_payments,\n        s.total_spent,\n        s.avg_payment,\n        s.active_months,\n        s.last_payment,\n        s.first_payment,\n        s.high_value_payments,\n        s.recent_spending\n    FROM customer c\n    JOIN customer_payment_stats s ON c.customer_id = s.customer_id\n    WHERE c.active = 1\n)\nSELECT\n    (SELECT COUNT(*) FROM original_query) AS original_rows,\n    (SELECT COUNT(*) FROM optimized_query) AS optimized_rows,\n    (SELECT COUNT(*) FROM (SELECT * FROM original_query EXCEPT SELECT * FROM optimized_query) d) AS original_minus_optimized,\n    (SELECT COUNT(*) FROM (SELECT * FROM optimized_query EXCEPT SELECT * FROM original_query) d) AS optimized_minus_original;"
