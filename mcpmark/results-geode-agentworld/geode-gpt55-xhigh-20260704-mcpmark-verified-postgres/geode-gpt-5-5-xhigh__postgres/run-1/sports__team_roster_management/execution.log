  {
    "tool": "execute_sql",
    "input": {
      "sql": "BEGIN;\n\n-- Ensure persons(id) can be referenced by foreign keys in the new roster tables.\nCREATE UNIQUE INDEX IF NOT EXISTS persons_id_unique_for_roster_idx ON public.persons (id);\n\n-- 1. Set Up Player Performance Tracking\nCREATE TABLE public.player_evaluation (\n    performance_id SERIAL PRIMARY KEY,\n    person_id INTEGER NOT NULL REFERENCES public.persons(id),\n    batting_avg DECIMAL CHECK (batting_avg BETWEEN 0 AND 1),\n    home_runs INTEGER,\n    rbis INTEGER,\n    games_played INTEGER,\n    performance_score DECIMAL,\n    evaluation_date DATE\n);\n\n-- 2. Load Historical Player Statistics\nWITH offensive_totals AS (\n    SELECT\n        s.stat_holder_id AS person_id,\n        COALESCE(SUM(COALESCE(bos.hits, 0)), 0) AS total_hits,\n        COALESCE(SUM(COALESCE(bos.at_bats, 0)), 0) AS total_at_bats,\n        COALESCE(SUM(COALESCE(bos.home_runs, 0)), 0) AS total_home_runs,\n        COALESCE(SUM(COALESCE(bos.rbi, 0)), 0) AS total_rbis\n    FROM public.stats s\n    JOIN public.baseball_offensive_stats bos\n        ON bos.id = s.stat_repository_id\n    JOIN public.persons p\n        ON p.id = s.stat_holder_id\n    WHERE s.stat_repository_type = 'baseball_offensive_stats'\n      AND s.stat_holder_type = 'persons'\n    GROUP BY s.stat_holder_id\n),\ngames AS (\n    SELECT\n        person_id,\n        COUNT(*)::integer AS games_played\n    FROM public.person_event_metadata\n    GROUP BY person_id\n),\ncalculated AS (\n    SELECT\n        ot.person_id,\n        CASE\n            WHEN COALESCE(ot.total_at_bats, 0) = 0 THEN 0::numeric\n            ELSE COALESCE(ot.total_hits, 0)::numeric / COALESCE(ot.total_at_bats, 0)::numeric\n        END AS batting_avg,\n        COALESCE(ot.total_home_runs, 0)::integer AS home_runs,\n        COALESCE(ot.total_rbis, 0)::integer AS rbis,\n        COALESCE(g.games_played, 0)::integer AS games_played\n    FROM offensive_totals ot\n    LEFT JOIN games g\n        ON g.person_id = ot.person_id\n)\nINSERT INTO public.player_evaluation (\n    person_id,\n    batting_avg,\n    home_runs,\n    rbis,\n    games_played,\n    performance_score,\n    evaluation_date\n)\nSELECT\n    person_id,\n    batting_avg,\n    home_runs,\n    rbis,\n    games_played,\n    (COALESCE(batting_avg, 0) * 1000) + (COALESCE(home_runs, 0) * 5) + (COALESCE(rbis, 0) * 2),\n    DATE '2024-01-01'\nFROM calculated\nWHERE games_played >= 10;\n\n-- 3. Track Player Health Status\nCREATE TABLE public.player_injury_status (\n    status_id SERIAL PRIMARY KEY,\n    person_id INTEGER UNIQUE NOT NULL REFERENCES public.persons(id),\n    injury_count INTEGER DEFAULT 0,\n    last_injury_date DATE,\n    current_status VARCHAR CHECK (current_status IN ('healthy', 'injured', 'recovering'))\n);\n\nINSERT INTO public.player_injury_status (\n    person_id,\n    injury_count,\n    last_injury_date,\n    current_status\n)\nSELECT\n    pe.person_id,\n    COALESCE(COUNT(ip.id), 0)::integer AS injury_count,\n    MAX(ip.start_date_time)::date AS last_injury_date,\n    CASE\n        WHEN COUNT(ip.id) FILTER (WHERE ip.end_date_time IS NULL) > 0 THEN 'injured'\n        ELSE 'healthy'\n    END AS current_status\nFROM public.player_evaluation pe\nLEFT JOIN public.injury_phases ip\n    ON ip.person_id = pe.person_id\nGROUP BY pe.person_id;\n\n-- 4. Adjust Scores Based on Health\nUPDATE public.player_evaluation pe\nSET performance_score = GREATEST(\n    0::numeric,\n    COALESCE(pe.performance_score, 0) *\n    CASE WHEN pis.current_status = 'injured' THEN 0.8::numeric ELSE 1::numeric END *\n    CASE WHEN COALESCE(pis.injury_count, 0) > 2 THEN 0.9::numeric ELSE 1::numeric END\n)\nFROM public.player_injury_status pis\nWHERE pis.person_id = pe.person_id;\n\n-- 5. Generate Performance Summary Report\nCREATE TABLE public.team_performance_summary (\n    summary_id SERIAL PRIMARY KEY,\n    metric_name VARCHAR UNIQUE,\n    metric_value DECIMAL\n);\n\nINSERT INTO public.team_performance_summary (metric_name, metric_value)\nSELECT 'total_players', COUNT(*)::numeric FROM public.player_evaluation\nUNION ALL\nSELECT 'avg_batting_average', AVG(COALESCE(batting_avg, 0)) FROM public.player_evaluation\nUNION ALL\nSELECT 'total_home_runs', SUM(COALESCE(home_runs, 0))::numeric FROM public.player_evaluation\nUNION ALL\nSELECT 'avg_performance_score', AVG(COALESCE(performance_score, 0)) FROM public.player_evaluation\nUNION ALL\nSELECT 'injured_player_count', COUNT(*)::numeric FROM public.player_injury_status WHERE current_status = 'injured'\nUNION ALL\nSELECT 'healthy_player_count', COUNT(*)::numeric FROM public.player_injury_status WHERE current_status = 'healthy';\n\nCOMMIT;\n\nSELECT metric_name, metric_value\nFROM public.team_performance_summary\nORDER BY summary_id;"
    },
