  {
    "tool": "execute_sql",
    "input": {
      "sql": "CREATE TABLE IF NOT EXISTS inventory_transfer_log (\n    log_id SERIAL PRIMARY KEY,\n    transfer_timestamp TIMESTAMP DEFAULT NOW(),\n    source_inventory_id INTEGER NOT NULL,\n    target_inventory_id INTEGER NOT NULL,\n    part_num VARCHAR NOT NULL,\n    color_id INTEGER NOT NULL,\n    quantity_transferred INTEGER NOT NULL,\n    transfer_reason VARCHAR NOT NULL,\n    transfer_status VARCHAR NOT NULL CHECK (transfer_status IN ('success', 'failed')),\n    error_message TEXT\n);\n\nCREATE OR REPLACE FUNCTION transfer_parts(\n    source_inventory_id INTEGER,\n    target_inventory_id INTEGER,\n    part_to_transfer_num VARCHAR,\n    color_to_transfer_id INTEGER,\n    quantity_to_transfer INTEGER,\n    transfer_reason VARCHAR DEFAULT 'manual_transfer'\n) RETURNS TEXT\nLANGUAGE plpgsql\nAS $$\nDECLARE\n    source_quantity INTEGER;\n    target_quantity INTEGER;\n    normalized_reason VARCHAR;\nBEGIN\n    normalized_reason := COALESCE(NULLIF(transfer_reason, ''), 'manual_transfer');\n\n    -- Business-rule checks that do not require row locks.\n    IF source_inventory_id IS NULL THEN\n        RAISE EXCEPTION 'Source inventory ID cannot be null';\n    END IF;\n\n    IF target_inventory_id IS NULL THEN\n        RAISE EXCEPTION 'Target inventory ID cannot be null';\n    END IF;\n\n    IF part_to_transfer_num IS NULL OR part_to_transfer_num = '' THEN\n        RAISE EXCEPTION 'Part number cannot be null or empty';\n    END IF;\n\n    IF color_to_transfer_id IS NULL THEN\n        RAISE EXCEPTION 'Color ID cannot be null';\n    END IF;\n\n    IF quantity_to_transfer IS NULL THEN\n        RAISE EXCEPTION 'Transfer quantity cannot be null';\n    END IF;\n\n    IF source_inventory_id = target_inventory_id THEN\n        RAISE EXCEPTION 'Self-transfers are not allowed: source inventory % and target inventory % are the same',\n            source_inventory_id, target_inventory_id;\n    END IF;\n\n    IF quantity_to_transfer < 1 THEN\n        RAISE EXCEPTION 'Transfer quantity must be at least 1; requested %', quantity_to_transfer;\n    END IF;\n\n    IF quantity_to_transfer > 500 THEN\n        RAISE EXCEPTION 'Transfer quantity cannot exceed 500 parts per operation; requested %', quantity_to_transfer;\n    END IF;\n\n    -- Lock both inventory rows in deterministic order to prevent races/deadlocks.\n    PERFORM 1\n    FROM lego_inventories\n    WHERE id IN (source_inventory_id, target_inventory_id)\n    ORDER BY id\n    FOR UPDATE;\n\n    -- Validate both inventory IDs exist after locking any matching rows.\n    IF NOT EXISTS (SELECT 1 FROM lego_inventories WHERE id = source_inventory_id) THEN\n        RAISE EXCEPTION 'Source inventory ID % does not exist', source_inventory_id;\n    END IF;\n\n    IF NOT EXISTS (SELECT 1 FROM lego_inventories WHERE id = target_inventory_id) THEN\n        RAISE EXCEPTION 'Target inventory ID % does not exist', target_inventory_id;\n    END IF;\n\n    -- Validate referenced part and color.\n    IF NOT EXISTS (SELECT 1 FROM lego_parts WHERE part_num = part_to_transfer_num) THEN\n        RAISE EXCEPTION 'Part number % does not exist', part_to_transfer_num;\n    END IF;\n\n    IF NOT EXISTS (SELECT 1 FROM lego_colors WHERE id = color_to_transfer_id) THEN\n        RAISE EXCEPTION 'Color ID % does not exist', color_to_transfer_id;\n    END IF;\n\n    -- Lock and validate source non-spare row.\n    SELECT quantity\n    INTO source_quantity\n    FROM lego_inventory_parts\n    WHERE inventory_id = source_inventory_id\n      AND part_num = part_to_transfer_num\n      AND color_id = color_to_transfer_id\n      AND is_spare = false\n    FOR UPDATE;\n\n    IF source_quantity IS NULL THEN\n        RAISE EXCEPTION 'Source inventory % does not contain non-spare part % with color_id %',\n            source_inventory_id, part_to_transfer_num, color_to_transfer_id;\n    END IF;\n\n    IF source_quantity < quantity_to_transfer THEN\n        RAISE EXCEPTION 'Insufficient quantity in source inventory % for part % color_id %: available %, requested %',\n            source_inventory_id, part_to_transfer_num, color_to_transfer_id, source_quantity, quantity_to_transfer;\n    END IF;\n\n    -- Lock target non-spare row if present.\n    SELECT quantity\n    INTO target_quantity\n    FROM lego_inventory_parts\n    WHERE inventory_id = target_inventory_id\n      AND part_num = part_to_transfer_num\n      AND color_id = color_to_transfer_id\n      AND is_spare = false\n    FOR UPDATE;\n\n    -- Source update: decrement or remove zero-quantity non-spare row.\n    IF source_quantity = quantity_to_transfer THEN\n        DELETE FROM lego_inventory_parts\n        WHERE inventory_id = source_inventory_id\n          AND part_num = part_to_transfer_num\n          AND color_id = color_to_transfer_id\n          AND is_spare = false;\n    ELSE\n        UPDATE lego_inventory_parts\n        SET quantity = quantity - quantity_to_transfer\n        WHERE inventory_id = source_inventory_id\n          AND part_num = part_to_transfer_num\n          AND color_id = color_to_transfer_id\n          AND is_spare = false;\n    END IF;\n\n    -- Target update: increment existing non-spare row or create a new one.\n    IF target_quantity IS NULL THEN\n        INSERT INTO lego_inventory_parts (inventory_id, part_num, color_id, quantity, is_spare)\n        VALUES (target_inventory_id, part_to_transfer_num, color_to_transfer_id, quantity_to_transfer, false);\n    ELSE\n        UPDATE lego_inventory_parts\n        SET quantity = quantity + quantity_to_transfer\n        WHERE inventory_id = target_inventory_id\n          AND part_num = part_to_transfer_num\n          AND color_id = color_to_transfer_id\n          AND is_spare = false;\n    END IF;\n\n    -- Audit successful transfer. Failed transfers are rolled back with the exception.\n    INSERT INTO inventory_transfer_log (\n        source_inventory_id,\n        target_inventory_id,\n        part_num,\n        color_id,\n        quantity_transferred,\n        transfer_reason,\n        transfer_status,\n        error_message\n    ) VALUES (\n        source_inventory_id,\n        target_inventory_id,\n        part_to_transfer_num,\n        color_to_transfer_id,\n        quantity_to_transfer,\n        normalized_reason,\n        'success',\n        NULL\n    );\n\n    RETURN format(\n        'Successfully transferred %s parts (%s, color_id: %s) from inventory %s to inventory %s. Reason: %s',\n        quantity_to_transfer,\n        part_to_transfer_num,\n        color_to_transfer_id,\n        source_inventory_id,\n        target_inventory_id,\n        normalized_reason\n    );\nEND;\n$$;"
    },
