  {
    "tool": "execute_sql",
    "input": {
      "sql": "-- Supporting tables for reporting and alerting\nCREATE TABLE IF NOT EXISTS employees.monthly_reports (\n    report_id SERIAL PRIMARY KEY,\n    report_date DATE NOT NULL,\n    department_count INTEGER NOT NULL,\n    total_employees INTEGER NOT NULL,\n    avg_salary NUMERIC(12,2),\n    generated_at TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP\n);\n\nCREATE TABLE IF NOT EXISTS employees.salary_alerts (\n    alert_id SERIAL PRIMARY KEY,\n    employee_id BIGINT NOT NULL,\n    salary_amount BIGINT NOT NULL,\n    alert_date TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,\n    status VARCHAR(20) NOT NULL DEFAULT 'new'\n);\n\n-- Trigger function and trigger for high salary alerts\nCREATE OR REPLACE FUNCTION employees.high_salary_alert_fn()\nRETURNS trigger\nLANGUAGE plpgsql\nAS $$\nBEGIN\n    INSERT INTO employees.salary_alerts (employee_id, salary_amount, alert_date, status)\n    VALUES (NEW.employee_id, NEW.amount, CURRENT_TIMESTAMP, 'new');\n    RETURN NEW;\nEND;\n$$;\n\nDROP TRIGGER IF EXISTS high_salary_alert ON employees.salary;\nCREATE TRIGGER high_salary_alert\nAFTER INSERT ON employees.salary\nFOR EACH ROW\nWHEN (NEW.amount > 120000)\nEXECUTE FUNCTION employees.high_salary_alert_fn();\n\n-- Recreate executive materialized views\nDROP MATERIALIZED VIEW IF EXISTS employees.exec_salary_distribution;\nDROP MATERIALIZED VIEW IF EXISTS employees.exec_hiring_trends;\nDROP MATERIALIZED VIEW IF EXISTS employees.exec_department_summary;\n\nCREATE MATERIALIZED VIEW employees.exec_department_summary AS\nWITH current_dept AS (\n    SELECT employee_id, department_id\n    FROM employees.department_employee\n    WHERE to_date = DATE '9999-01-01'\n),\ncurrent_salary AS (\n    SELECT DISTINCT ON (employee_id) employee_id, amount\n    FROM employees.salary\n    WHERE to_date = DATE '9999-01-01'\n    ORDER BY employee_id, from_date DESC\n),\ncurrent_manager AS (\n    SELECT DISTINCT ON (dm.department_id)\n           dm.department_id,\n           (e.first_name || ' ' || e.last_name)::VARCHAR AS manager_name\n    FROM employees.department_manager dm\n    JOIN employees.employee e ON e.id = dm.employee_id\n    WHERE dm.to_date = DATE '9999-01-01'\n    ORDER BY dm.department_id, dm.from_date DESC, dm.employee_id\n)\nSELECT d.dept_name::VARCHAR AS department_name,\n       COUNT(cd.employee_id)::INTEGER AS total_employees,\n       ROUND(AVG(cs.amount)::NUMERIC, 2) AS avg_salary,\n       COALESCE(SUM(cs.amount), 0)::BIGINT AS total_payroll,\n       cm.manager_name::VARCHAR AS manager_name\nFROM employees.department d\nLEFT JOIN current_dept cd ON cd.department_id = d.id\nLEFT JOIN current_salary cs ON cs.employee_id = cd.employee_id\nLEFT JOIN current_manager cm ON cm.department_id = d.id\nGROUP BY d.id, d.dept_name, cm.manager_name\nORDER BY d.dept_name;\n\nCREATE MATERIALIZED VIEW employees.exec_hiring_trends AS\nWITH first_salary AS (\n    SELECT DISTINCT ON (employee_id)\n           employee_id,\n           amount AS starting_salary\n    FROM employees.salary\n    ORDER BY employee_id, from_date\n),\nfirst_department AS (\n    SELECT DISTINCT ON (employee_id)\n           employee_id,\n           department_id\n    FROM employees.department_employee\n    ORDER BY employee_id, from_date, department_id\n),\ncurrent_employee AS (\n    SELECT DISTINCT employee_id\n    FROM employees.department_employee\n    WHERE to_date = DATE '9999-01-01'\n),\nhire_rows AS (\n    SELECT e.id AS employee_id,\n           EXTRACT(YEAR FROM e.hire_date)::INTEGER AS hire_year,\n           fs.starting_salary,\n           (ce.employee_id IS NOT NULL) AS still_employed,\n           d.dept_name AS department_name\n    FROM employees.employee e\n    LEFT JOIN first_salary fs ON fs.employee_id = e.id\n    LEFT JOIN current_employee ce ON ce.employee_id = e.id\n    LEFT JOIN first_department fd ON fd.employee_id = e.id\n    LEFT JOIN employees.department d ON d.id = fd.department_id\n),\nyearly_stats AS (\n    SELECT hire_year,\n           COUNT(*)::INTEGER AS employees_hired,\n           ROUND(AVG(starting_salary)::NUMERIC, 2) AS avg_starting_salary,\n           ROUND((COUNT(*) FILTER (WHERE still_employed))::NUMERIC * 100 / NULLIF(COUNT(*)::NUMERIC, 0), 2) AS retention_rate\n    FROM hire_rows\n    GROUP BY hire_year\n),\ndept_counts AS (\n    SELECT hire_year,\n           department_name,\n           COUNT(*) AS hires,\n           ROW_NUMBER() OVER (PARTITION BY hire_year ORDER BY COUNT(*) DESC, department_name ASC NULLS LAST) AS rn\n    FROM hire_rows\n    GROUP BY hire_year, department_name\n)\nSELECT ys.hire_year,\n       ys.employees_hired,\n       ys.avg_starting_salary,\n       ys.retention_rate,\n       dc.department_name::VARCHAR AS top_hiring_department\nFROM yearly_stats ys\nLEFT JOIN dept_counts dc ON dc.hire_year = ys.hire_year AND dc.rn = 1\nORDER BY ys.hire_year;\n\nCREATE MATERIALIZED VIEW employees.exec_salary_distribution AS\nWITH bands(salary_band, sort_order, min_salary, max_salary) AS (\n    VALUES\n        ('30K-50K'::VARCHAR, 1, 30000::BIGINT, 50000::BIGINT),\n        ('50K-70K'::VARCHAR, 2, 50000::BIGINT, 70000::BIGINT),\n        ('70K-90K'::VARCHAR, 3, 70000::BIGINT, 90000::BIGINT),\n        ('90K-110K'::VARCHAR, 4, 90000::BIGINT, 110000::BIGINT),\n        ('110K+'::VARCHAR, 5, 110000::BIGINT, NULL::BIGINT)\n),\ncurrent_employee AS (\n    SELECT DISTINCT employee_id\n    FROM employees.department_employee\n    WHERE to_date = DATE '9999-01-01'\n),\ncurrent_salary AS (\n    SELECT DISTINCT ON (employee_id) employee_id, amount\n    FROM employees.salary\n    WHERE to_date = DATE '9999-01-01'\n    ORDER BY employee_id, from_date DESC\n),\nactive_salary AS (\n    SELECT ce.employee_id,\n           cs.amount,\n           ct.title\n    FROM current_employee ce\n    JOIN current_salary cs ON cs.employee_id = ce.employee_id\n    LEFT JOIN LATERAL (\n        SELECT t.title\n        FROM employees.title t\n        WHERE t.employee_id = ce.employee_id\n          AND (t.to_date = DATE '9999-01-01' OR t.to_date IS NULL)\n        ORDER BY t.from_date DESC, t.title\n        LIMIT 1\n    ) ct ON TRUE\n),\nsalary_banded AS (\n    SELECT b.salary_band,\n           b.sort_order,\n           a.employee_id,\n           a.title\n    FROM bands b\n    JOIN active_salary a\n      ON a.amount >= b.min_salary\n     AND (b.max_salary IS NULL OR a.amount < b.max_salary)\n),\ntotal_workforce AS (\n    SELECT COUNT(*)::NUMERIC AS total_employees\n    FROM active_salary\n),\nband_counts AS (\n    SELECT salary_band,\n           COUNT(*)::INTEGER AS employee_count\n    FROM salary_banded\n    GROUP BY salary_band\n),\ntitle_counts AS (\n    SELECT salary_band,\n           title,\n           COUNT(*) AS title_count,\n           ROW_NUMBER() OVER (PARTITION BY salary_band ORDER BY COUNT(*) DESC, title ASC) AS rn\n    FROM salary_banded\n    WHERE title IS NOT NULL\n    GROUP BY salary_band, title\n)\nSELECT b.salary_band::VARCHAR AS salary_band,\n       COALESCE(bc.employee_count, 0)::INTEGER AS employee_count,\n       ROUND(COALESCE(bc.employee_count, 0)::NUMERIC * 100 / NULLIF(tw.total_employees, 0), 2) AS percentage_of_workforce,\n       tc.title::VARCHAR AS most_common_title\nFROM bands b\nCROSS JOIN total_workforce tw\nLEFT JOIN band_counts bc ON bc.salary_band = b.salary_band\nLEFT JOIN title_counts tc ON tc.salary_band = b.salary_band AND tc.rn = 1\nORDER BY b.sort_order;\n\n-- Stored reporting routine; implemented as a PostgreSQL function to return report_id\nCREATE OR REPLACE FUNCTION employees.generate_monthly_report(p_report_date DATE)\nRETURNS INTEGER\nLANGUAGE plpgsql\nAS $$\nDECLARE\n    v_report_id INTEGER;\nBEGIN\n    CREATE TABLE IF NOT EXISTS employees.monthly_reports (\n        report_id SERIAL PRIMARY KEY,\n        report_date DATE NOT NULL,\n        department_count INTEGER NOT NULL,\n        total_employees INTEGER NOT NULL,\n        avg_salary NUMERIC(12,2),\n        generated_at TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP\n    );\n\n    INSERT INTO employees.monthly_reports (\n        report_date,\n        department_count,\n        total_employees,\n        avg_salary,\n        generated_at\n    )\n    SELECT p_report_date,\n           (SELECT COUNT(*)::INTEGER FROM employees.department),\n           COUNT(DISTINCT de.employee_id)::INTEGER,\n           ROUND(AVG(s.amount)::NUMERIC, 2),\n           CURRENT_TIMESTAMP\n    FROM employees.department_employee de\n    JOIN employees.salary s\n      ON s.employee_id = de.employee_id\n     AND s.to_date = DATE '9999-01-01'\n    WHERE de.to_date = DATE '9999-01-01'\n    RETURNING report_id INTO v_report_id;\n\n    RETURN v_report_id;\nEND;\n$$;\n\n-- Test trigger data: close employee 10001's previous current salary and insert high salary\nUPDATE employees.salary\nSET to_date = DATE '2024-01-31'\nWHERE employee_id = 10001\n  AND to_date = DATE '9999-01-01'\n  AND from_date <> DATE '2024-02-01';\n\nINSERT INTO employees.salary (employee_id, amount, from_date, to_date)\nVALUES (10001, 125000, DATE '2024-02-01', DATE '9999-01-01')\nON CONFLICT (employee_id, from_date) DO UPDATE\nSET amount = EXCLUDED.amount,\n    to_date = EXCLUDED.to_date;\n\n-- Refresh all executive materialized views after the test data change\nREFRESH MATERIALIZED VIEW employees.exec_department_summary;\nREFRESH MATERIALIZED VIEW employees.exec_hiring_trends;\nREFRESH MATERIALIZED VIEW employees.exec_salary_distribution;\n\n-- Execute the monthly report function for January 2024\nDROP TABLE IF EXISTS pg_temp.generated_report_id;\nCREATE TEMP TABLE generated_report_id AS\nSELECT employees.generate_monthly_report(DATE '2024-01-01') AS report_id;\n\n-- Performance indexes\nCREATE INDEX IF NOT EXISTS idx_salary_alerts_status\n    ON employees.salary_alerts (status);\n\nCREATE INDEX IF NOT EXISTS idx_monthly_reports_report_date_department_count\n    ON employees.monthly_reports (report_date, department_count);\n\n-- Verification output\nSELECT jsonb_pretty(\n    jsonb_build_object(\n        'materialized_view_row_counts', jsonb_build_object(\n            'exec_department_summary', (SELECT COUNT(*) FROM employees.exec_department_summary),\n            'exec_hiring_trends', (SELECT COUNT(*) FROM employees.exec_hiring_trends),\n            'exec_salary_distribution', (SELECT COUNT(*) FROM employees.exec_salary_distribution)\n        ),\n        'employee_10001_current_salary', (\n            SELECT to_jsonb(s)\n            FROM (\n                SELECT employee_id, amount, from_date, to_date\n                FROM employees.salary\n                WHERE employee_id = 10001\n                  AND to_date = DATE '9999-01-01'\n                ORDER BY from_date DESC\n                LIMIT 1\n            ) s\n        ),\n        'latest_salary_alert_for_test', (\n            SELECT to_jsonb(sa)\n            FROM (\n                SELECT employee_id, salary_amount, alert_date, status\n                FROM employees.salary_alerts\n                WHERE employee_id = 10001\n                  AND salary_amount = 125000\n                ORDER BY alert_date DESC\n                LIMIT 1\n            ) sa\n        ),\n        'generated_monthly_report', (\n            SELECT to_jsonb(mr)\n            FROM employees.monthly_reports mr\n            WHERE mr.report_id = (SELECT report_id FROM generated_report_id)\n        ),\n        'indexes_created', (\n            SELECT jsonb_agg(indexname ORDER BY indexname)\n            FROM pg_indexes\n            WHERE schemaname = 'employees'\n              AND indexname IN (\n                  'idx_salary_alerts_status',\n                  'idx_monthly_reports_report_date_department_count'\n              )\n        )\n    )\n) AS verification;"
    },
