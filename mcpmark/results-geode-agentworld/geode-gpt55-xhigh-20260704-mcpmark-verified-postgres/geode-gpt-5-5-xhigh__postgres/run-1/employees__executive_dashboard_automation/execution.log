       \\\"status\\\": \\\"new\\\",\\\\n        \\\"alert_date\\\": \\\"2026-07-03T20:33:22.611347+00:00\\\",\\\\n        \\\"employee_id\\\": 10001,\\\\n        \\\"salary_amount\\\": 125000\\\\n    },\\\\n    \\\"materialized_view_row_counts\\\": {\\\\n        \\\"exec_hiring_trends\\\": 16,\\\\n        \\\"exec_department_summary\\\": 9,\\\\n        \\\"exec_salary_distribution\\\": 5\\\\n    },\\\\n    \\\"employee_10001_current_salary\\\": {\\\\n        \\\"amount\\\": 125000,\\\\n        \\\"to_date\\\": \\\"9999-01-01\\\",\\\\n        \\\"from_date\\\": \\\"2024-02-01\\\",\\\\n        \\\"employee_id\\\": 10001\\\\n    }\\\\n}'}]\", \"annotations\": null, \"_meta\": null}]}, \"isError\": false}"
